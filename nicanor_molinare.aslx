  <!-- ==================== FUNCIONES ==================== -->

  <function name="IniciarJuego">
      ClearScreen
      JS.eval ("$('body').css({'background-color':'#0a0a0a'}); $('#gameBorder').css({'background-color':'#0a0a0a','background-image':'none'}); $('#gameContent').css({'background-color':'#0a0a0a','color':'#d4d4c8','font-family':'Georgia, serif','font-size':'13px','line-height':'1.7'}); $('#txtCommand').css({'background-color':'#1a1a1a','color':'#d4d4c8','border':'1px solid #333','font-family':'Georgia, serif','border-radius':'4px','padding':'8px 12px','font-size':'13px'}); $('#status').css({'background-color':'#111','color':'#888'}); $('.ui-accordion').css({'background-color':'#111'}); $('h1,h2,h3').css({'color':'#cc4444'}); $('#gamePanes').css({'background-color':'#111'}); $('.ui-widget-content').css({'background-color':'#111','color':'#999'}); $('.ui-widget-header').css({'background-color':'#1a0000','color':'#cc4444','border':'1px solid #330000'}); $('#location').css({'background':'linear-gradient(135deg,#0a0000,#1a0505)','color':'#cc8866','border':'1px solid #331111','font-family':'Georgia, serif','font-size':'14px','letter-spacing':'2px','padding':'8px 15px','text-shadow':'0 0 10px rgba(204,68,68,0.3)'}); $('#txtCommand').attr('placeholder','Escribe aqui...');")
      JS.eval ("var s=document.createElement('style'); s.textContent='body,#gameBorder,#gameContent{background-color:#0a0a0a !important;background-image:none !important} #divOutput{padding:10px 20px !important} #divOutput a{color:#cc4444 !important;text-decoration:none !important} .ui-widget-content a{color:#cc4444 !important} #txtCommandDiv{border-top:1px solid #222 !important;padding:10px !important} .ui-accordion-header{background:#1a0a0a !important;color:#cc8866 !important;border:1px solid #331111 !important} .ui-accordion-content{background:#0f0f0f !important;border:1px solid #221111 !important} #location{background:linear-gradient(135deg,#0a0000,#1a0505) !important;color:#cc8866 !important;border:1px solid #331111 !important;font-family:Georgia,serif !important;font-size:14px !important;letter-spacing:2px !important;padding:8px 15px !important;text-shadow:0 0 10px rgba(204,68,68,0.3) !important} #location .ui-widget-header{background:transparent !important;border:none !important}'; document.head.appendChild(s);")
      JS.eval ("try{window.NMA={};NMA.ctx=new (window.AudioContext||window.webkitAudioContext)();NMA.gain=NMA.ctx.createGain();NMA.gain.gain.value=0.03;NMA.gain.connect(NMA.ctx.destination);NMA.osc1=NMA.ctx.createOscillator();NMA.osc1.type='sine';NMA.osc1.frequency.value=55;NMA.osc1.connect(NMA.gain);NMA.osc1.start();NMA.horror=0;NMA.updateAudio=function(h){if(h>=7&amp;&amp;!NMA.osc2){NMA.osc1.frequency.value=40;NMA.osc2=NMA.ctx.createOscillator();NMA.osc2.type='sine';NMA.osc2.frequency.value=43;NMA.osc2.connect(NMA.gain);NMA.osc2.start();}if(h>=14&amp;&amp;!NMA.osc3){NMA.osc3=NMA.ctx.createOscillator();NMA.osc3.type='sawtooth';NMA.osc3.frequency.value=30;var g2=NMA.ctx.createGain();g2.gain.value=0.02;NMA.osc3.connect(g2);g2.connect(NMA.ctx.destination);NMA.osc3.start();}NMA.horror=h;};}catch(e){}")
      msg ("")
      msg ("        &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650;")
      msg ("")
      msg ("              N  I  C  A  N  O  R")
      msg ("            M  O  L  I  N  A  R  E")
      msg ("")
      msg ("          Un juego de terror psicologico")
      msg ("")
      msg ("         No todo lo que recuerdas es real.")
      msg ("         No todo lo que olvidas se ha ido.")
      msg ("")
      msg ("        &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650; &#9660; &#9650;")
      msg ("")
      game.acto = 1
      msg ("Dona Carmen te mira desde el otro lado del mostrador de recepcion. Sus ojos, hundidos y oscuros, parecen conocerte desde antes de que llegaras.")
      msg ("")
      msg ("\"Necesito tu nombre para el registro, querido. Como te llamas?\"")
      msg ("")
      get input {
        game.nombre_jugador = result
        msg ("")
        msg ("Carmen escribe tu nombre lentamente en un libro viejo. La tinta parece hundirse en el papel como si la pagina la absorbiera.")
        msg ("")
        msg ("\"" + game.nombre_jugador + "...\" repite ella, saboreando cada silaba. \"Un nombre hermoso. Ahora dime, cual es tu fecha de nacimiento? Es para nuestros registros.\"")
        msg ("")
        get input {
          game.fecha_nacimiento = result
          msg ("")
          msg ("Carmen asiente despacio y cierra el libro con un golpe seco que resuena por todo el vestibulo.")
          msg ("")
          msg ("\"Perfecto, " + game.nombre_jugador + ". Tu habitacion esta lista. Siempre lo estuvo.\"")
          msg ("")
          msg ("Te entrega una llave oxidada. El numero de la habitacion esta borrado.")
          msg ("")
          msg ("\"Bienvenido a Nicanor Molinare. Esperamos que tu estancia sea... memorable.\"")
          msg ("")
          msg ("=========== ACTO 1 - LA LLEGADA ===========")
          msg ("")
          MoveObject (player, recepcion)
        }
      }
  </function>

  <function name="IncrementarHorror" parameters="cantidad">
    game.horror = game.horror + cantidad
    if (game.horror > 20) {
      game.horror = 20
    }
    if (game.horror >= 5 and not game.mostro_hito_5) {
      game.mostro_hito_5 = true
      msg ("Sientes un escalofrio que te recorre la espalda. Algo no esta bien en esta casa.")
    }
    if (game.horror >= 10 and not game.mostro_hito_10) {
      game.mostro_hito_10 = true
      msg ("Las paredes parecen mas cercanas que antes. El aire huele a tierra mojada y a algo dulce que no puedes identificar. Algo podrido, quizas.")
    }
    if (game.horror >= 12 and not game.archivo_creado) {
      CrearArchivoExterno
    }
    if (game.horror >= 14 and not game.mostro_hito_14) {
      game.mostro_hito_14 = true
      msg ("Tu vision se distorsiona por un instante. Las sombras se mueven cuando no las miras directamente. Estas seguro de que alguien te observa desde dentro de las paredes.")
    }
    if (game.horror >= 15 and not game.nota_inventario_agregada) {
      AgregarNotaInventario
    }
    if (game.horror >= 18 and not game.mostro_hito_18) {
      game.mostro_hito_18 = true
      msg ("Ya no distingues lo real de lo imaginado. El suelo vibra bajo tus pies como si la casa respirara. Escuchas tu propio nombre pronunciado al reves, una y otra vez, desde algun lugar debajo del suelo.")
    }
  </function>

  <function name="CrearArchivoExterno">
    if (not game.archivo_creado) {
      game.archivo_creado = true
      game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
      JS.eval ("try { var fso = new ActiveXObject('Scripting.FileSystemObject'); var f = fso.CreateTextFile('nota_para_ti.txt', true); f.WriteLine('Sé que estás leyendo esto fuera del juego.'); f.WriteLine('Eso no te va a salvar.'); f.WriteLine('La puerta del sótano se abrió cuando abriste este archivo.'); f.WriteLine('Nos vemos adentro.'); f.WriteLine(''); f.WriteLine('— D.C.'); f.Close(); } catch(e) {}")
      msg ("")
      msg ("[ Se ha creado un archivo en tu computadora. Tal vez deberías buscarlo. ]")
      msg ("")
      msg ("Si no puedes encontrarlo, esto es lo que dice:")
      msg ("")
      msg ("\"Sé que estás leyendo esto fuera del juego. Eso no te va a salvar. La puerta del sótano se abrió cuando abriste este archivo. Nos vemos adentro. — D.C.\"")
    }
  </function>

  <function name="AgregarNotaInventario">
    if (not game.nota_inventario_agregada) {
      game.nota_inventario_agregada = true
      game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
      create ("nota_arrugada", "object")
      nota_arrugada.parent = player
      nota_arrugada.alias = "Nota arrugada"
      nota_arrugada.look = "Desdoblas la nota con manos temblorosas. La caligrafía es tuya, aunque no recuerdas haberla escrito. Dice: 'Deja de jugar. Esto no es un juego. Nunca lo fue.'"
      nota_arrugada.take = false
      nota_arrugada.displayverbs = Split("Mirar;Examinar", ";")
      msg ("")
      msg ("Sientes algo en tu bolsillo que no estaba antes. Es una nota arrugada.")
    }
  </function>

  <function name="VerificarFinales">
    if (game.horror >= 18 and game.abrio_sotano and not game.ayudo_sofia and not game.ayudo_carmen) {
      FinalEscape
    }
    else if (game.horror >= 15 and game.ayudo_carmen and game.hablo_sofia_capa3) {
      FinalAceptacion
    }
    else if (game.horror >= 10 and game.horror &lt; 15 and not game.encontro_diario and not game.abrio_sotano) {
      FinalOlvido
    }
    else if (game.horror >= 15 and game.salvo_sofia and game.abrio_sotano) {
      FinalSacrificio
    }
    else if (game.easter_eggs_encontrados >= 15) {
      FinalVerdad
    }
  </function>

  <function name="FinalEscape">
    ClearScreen
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("        FINAL 1 - E S C A P E")
    msg ("")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("Corres.")
    msg ("")
    msg ("No miras atras. No puedes. Tus piernas se mueven solas, impulsadas por un terror que ya no tiene nombre. La puerta principal cede con un crujido que suena como un hueso rompiendose y sales a la noche.")
    msg ("")
    msg ("El camino de tierra se extiende ante ti como una lengua palida bajo la luna. Caminas durante horas. El pueblo no aparece. El bosque no termina. Las estrellas estan en posiciones que no reconoces.")
    msg ("")
    msg ("Cuando el amanecer llega - si es que es un amanecer, porque la luz tiene un tono verdoso que no es natural - ves una casa al final del camino.")
    msg ("")
    msg ("Es Nicanor Molinare.")
    msg ("")
    msg ("Diferente, piensas al principio. Pero la puerta es igual. El mostrador es igual. Y detras del mostrador hay una mujer mayor, con ojos hundidos y oscuros, que te mira como si te conociera desde antes de que llegaras.")
    msg ("")
    msg ("\"Bienvenido,\" dice. \"Te estabamos esperando, " + game.nombre_jugador + ".\"")
    msg ("")
    msg ("No es Carmen. Pero sonrie como Carmen. Y el libro de registro ya tiene tu nombre escrito.")
    msg ("")
    msg ("Bienvenido a casa.")
    msg ("")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("              F  I  N")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    finish
  </function>

  <function name="FinalAceptacion">
    ClearScreen
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("      FINAL 2 - A C E P T A C I O N")
    msg ("")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("Te sientas en la mecedora del vestibulo. La misma mecedora donde viste a Carmen sentarse tantas veces, meciendose con un ritmo que imitaba la respiracion de la casa.")
    msg ("")
    msg ("Y la sientes. La paz. No la paz de quien ha encontrado respuestas, sino la paz de quien ha dejado de buscarlas.")
    msg ("")
    msg ("La casa te abraza. Las paredes se calientan. Las sombras retroceden. Por primera vez, el olor dulce del aire no te da nauseas - te reconforta.")
    msg ("")
    msg ("Carmen se acerca y te pone una mano en el hombro. Su tacto es frio, pero amable.")
    msg ("")
    msg ("\"Ya lo entiendes,\" susurra. \"Siempre fuiste parte de esta casa. Solo necesitabas recordarlo.\"")
    msg ("")
    msg ("Ella se desvanece. Como humo. Como un recuerdo.")
    msg ("")
    msg ("Y tu te quedas. Porque alguien tiene que quedarse. Alguien tiene que recibir al proximo huesped.")
    msg ("")
    msg ("La puerta se abre. Entra alguien nuevo, con una maleta vieja y ojos cansados.")
    msg ("")
    msg ("Te levantas de la mecedora. Sonries.")
    msg ("")
    msg ("\"Bienvenido a Nicanor Molinare,\" dices. Y lo sientes verdadero.")
    msg ("")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("              F  I  N")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    finish
  </function>

  <function name="FinalOlvido">
    ClearScreen
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("        FINAL 3 - O L V I D O")
    msg ("")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("Todo se vuelve blanco.")
    msg ("")
    msg ("No es una luz cegadora ni una explosion. Es mas como si alguien hubiera borrado el mundo con una goma de borrar, empezando por los bordes y avanzando hacia el centro.")
    msg ("")
    msg ("El ultimo pensamiento que tienes antes de que todo desaparezca es que esto ya lo has vivido antes.")
    msg ("")
    msg (". . .")
    msg ("")
    msg ("Abres los ojos.")
    msg ("")
    msg ("Estas de pie frente a un mostrador de recepcion. Una mujer mayor te mira con ojos hundidos y oscuros.")
    msg ("")
    msg ("\"Bienvenido a Nicanor Molinare,\" dice. \"Como te llamas, querido?\"")
    msg ("")
    msg ("No recuerdas. No recuerdas nada.")
    msg ("")
    msg ("Pero algo en el fondo de tu mente, algo antiguo y enterrado, te dice que ya has estado aqui.")
    msg ("")
    msg ("========= ACTO 1 - BIENVENIDO. (DE NUEVO.) =========")
    msg ("")
    ResetearFlags
    MoveObject (player, recepcion)
  </function>

  <function name="ResetearFlags">
    game.horror = 0
    game.turnos = 0
    game.acto = 1
    game.encontro_diario = false
    game.abrio_sotano = false
    game.carmen_ofrecio_vela = false
    game.tiene_vela = false
    game.tiene_linterna = false
    game.linterna_con_pilas = false
    game.pilas_disponibles = false
    game.llave_atico_encontrada = false
    game.tiene_llave_atico = false
    game.tiene_llave_carmen = false
    game.tiene_llave_sala_oculta = false
    game.cajas_movidas = false
    game.bebio_frasco = false
    game.frasco_disponible = false
    game.cofre_abierto = false
    game.hablo_amigo_imaginario = false
    game.hablo_sofia_capa3 = false
    game.mostro_hito_5 = false
    game.mostro_hito_10 = false
    game.mostro_hito_14 = false
    game.mostro_hito_18 = false
    game.archivo_creado = false
    game.nota_inventario_agregada = false
    game.ui_inicializada = false
    game.comio_estofado = 0
    foreach (obj, ScopeInventory()) {
      MoveObject (obj, recepcion)
    }
  </function>

  <function name="FinalSacrificio">
    ClearScreen
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("      FINAL 4 - S A C R I F I C I O")
    msg ("")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("\"Corre, Sofia! No mires atras!\"")
    msg ("")
    msg ("Tu voz suena distorsionada en el sotano, rebotando contra las paredes humedas como si las piedras la masticaran antes de devolverla.")
    msg ("")
    msg ("Sofia te mira una ultima vez. Sus ojos - los ojos de una nina que nunca debio estar aqui - estan llenos de algo que podria ser gratitud o podria ser lastima.")
    msg ("")
    msg ("\"Gracias,\" dice. Y sube las escaleras corriendo.")
    msg ("")
    msg ("Tu te quedas abajo. La oscuridad se cierra a tu alrededor como un puno. Sientes las manos frias de la casa cerrandose sobre tus hombros, jalandote hacia abajo, siempre hacia abajo.")
    msg ("")
    msg ("Pero no importa. Porque arriba, Sofia cruza la puerta principal.")
    msg ("")
    msg ("Y afuera hay un campo real. Con hierba real. Y un cielo que tiene el color correcto.")
    msg ("")
    msg ("Sofia corre por el campo. No mira atras. El viento le despeina el cabello y por primera vez en mucho tiempo, sonrie.")
    msg ("")
    msg ("Muy abajo, en la oscuridad, tu tambien sonries.")
    msg ("")
    msg ("Es lo ultimo que haces.")
    msg ("")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("              F  I  N")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    finish
  </function>

  <function name="FinalVerdad">
    ClearScreen
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("      FINAL 5 - L A   V E R D A D")
    msg ("")
    msg ("&#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670; &#9671; &#9670;")
    msg ("")
    msg ("La pantalla parpadea.")
    msg ("")
    msg ("No la pantalla del juego. TU pantalla. La que estas mirando ahora mismo.")
    msg ("")
    msg ("" + game.nombre_jugador + ".")
    msg ("")
    msg ("Si, te estoy hablando a ti. No al personaje. A ti.")
    msg ("")
    msg ("Encontraste todos los secretos. Leiste las notas. Abriste el archivo. Miraste el agua. Hablaste con el amigo imaginario. Contaste los turnos.")
    msg ("")
    msg ("Pensaste que era un juego. Que las palabras en la pantalla eran solo eso - palabras. Texto programado por alguien para entretenerte un rato.")
    msg ("")
    msg ("Pero dime algo, " + game.nombre_jugador + ": por que seguiste jugando? Por que no cerraste la ventana cuando las cosas se pusieron extranas? Por que buscaste mas secretos en vez de menos?")
    msg ("")
    msg ("Nicanor Molinare nunca fue un lugar. Es una idea. Y las ideas no se pueden cerrar con una puerta.")
    msg ("")
    msg ("Los personajes que conociste eran reflejos:")
    msg ("")
    msg ("  Carmen  - La Memoria. Lo que eliges recordar y lo que eliges olvidar.")
    msg ("  Martin  - El Registro. La necesidad de documentar para probar que existimos.")
    msg ("  Lucia   - El Eco. Las voces de los que ya no estan pero siguen resonando.")
    msg ("  Ramon   - El Tiempo. Que no avanza ni retrocede, solo se acumula.")
    msg ("  Sofia   - La Verdad. Que siempre parece una nina, fragil y facil de ignorar.")
    msg ("")
    msg ("Y tu, " + game.nombre_jugador + ", eres el Huesped. El que llega, el que busca, el que decide si se queda o se va.")
    msg ("")
    msg ("Pero ya tomaste tu decision, verdad? Llegaste hasta aqui.")
    msg ("")
    msg ("Gracias por jugar. Gracias por buscar la verdad.")
    msg ("")
    msg ("La puerta esta abierta. Puedes irte cuando quieras.")
    msg ("")
    msg ("...verdad?")
    msg ("")
    msg ("=========== C R E D I T O S ===========")
    msg ("")
    msg ("       Nicanor Molinare")
    msg ("  Un juego de terror psicologico")
    msg ("")
    msg ("   Gracias por descubrir la verdad.")
    msg ("========================================")
    finish
  </function>

  <function name="PlaySonido" parameters="tipo">
    JS.eval("try{if(!window.NMA||!NMA.ctx)return;var ctx=NMA.ctx;if('" + tipo + "'=='golpe'){var b=ctx.createBuffer(1,ctx.sampleRate*0.1,ctx.sampleRate);var d=b.getChannelData(0);for(var i=0;i&lt;d.length;i++)d[i]=(Math.random()*2-1)*Math.exp(-i/1000);var s=ctx.createBufferSource();s.buffer=b;var f=ctx.createBiquadFilter();f.type='lowpass';f.frequency.value=200;s.connect(f);f.connect(ctx.destination);s.start();}if('" + tipo + "'=='chirrido'){var o=ctx.createOscillator();o.type='sawtooth';o.frequency.value=300;var g=ctx.createGain();g.gain.value=0.1;o.connect(g);g.connect(ctx.destination);o.start();o.frequency.exponentialRampToValueAtTime(100,ctx.currentTime+0.5);g.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+0.8);o.stop(ctx.currentTime+0.8);}if('" + tipo + "'=='susurro'){var b2=ctx.createBuffer(1,ctx.sampleRate*0.5,ctx.sampleRate);var d2=b2.getChannelData(0);for(var j=0;j&lt;d2.length;j++)d2[j]=(Math.random()*2-1)*0.05;var s2=ctx.createBufferSource();s2.buffer=b2;var f2=ctx.createBiquadFilter();f2.type='lowpass';f2.frequency.value=800;s2.connect(f2);f2.connect(ctx.destination);s2.start();}if('" + tipo + "'=='teclas'){var o2=ctx.createOscillator();o2.type='square';o2.frequency.value=800;var g2=ctx.createGain();g2.gain.value=0.05;o2.connect(g2);g2.connect(ctx.destination);o2.start();g2.gain.setValueAtTime(0.05,ctx.currentTime);g2.gain.exponentialRampToValueAtTime(0.001,ctx.currentTime+0.05);o2.stop(ctx.currentTime+0.05);}}catch(e){}")
  </function>

  <function name="InsertarRecuerdoFalso" parameters="tipo">
    msg ("")
    msg ("--- RECUERDO ---")
    if (tipo = "diario") {
      msg ("Recuerdas vagamente haber hablado con un sexto huesped. Un hombre alto, sin cara, que se sentaba en la silla del comedor y no hablaba. Cuando fue eso? Fue real?")
    }
    else if (tipo = "sotano") {
      msg ("Recuerdas el jardin de noche. Habia estrellas. Habia una puerta en el cielo. Cuando saliste de noche?")
    }
    else if (tipo = "sofia") {
      msg ("Recuerdas que Carmen lloraba. Estaba de rodillas en la cocina, llorando sobre algo que sostenia en los brazos. Que era? No lo recuerdas.")
    }
    msg ("--- FIN DEL RECUERDO ---")
    msg ("")
  </function>

  <!-- ==================== COMANDOS ==================== -->

  <command name="quien_soy">
    <pattern>quien soy;quién soy;¿quién soy?</pattern>
    <script>
      if (not GetBoolean(game, "quien_soy_usado")) {
        game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
        SetObjectFlagOn (game, "quien_soy_usado")
      }
      if (game.horror &lt;= 5) {
        msg ("Eres " + game.nombre_jugador + ". Un viajero cansado que busca refugio en Nicanor Molinare. O al menos eso crees.")
      }
      else if (game.horror &lt;= 10) {
        msg ("Eres " + game.nombre_jugador + ". ¿Verdad? Tu nombre suena extraño cuando lo piensas demasiado. Como una palabra repetida hasta perder significado.")
      }
      else if (game.horror &lt;= 15) {
        msg ("¿Quién eres? La pregunta resuena en tu cabeza como un eco en un pozo vacío. El espejo más cercano no refleja tu cara — refleja a alguien que se te parece, pero con los ojos equivocados.")
      }
      else {
        msg ("Ya no sabes. El nombre '" + game.nombre_jugador + "' es solo un sonido. Las letras de tu fecha de nacimiento — " + game.fecha_nacimiento + " — podrían ser las de cualquiera. O las de nadie. ¿Alguna vez fuiste real?")
      }
    </script>
  </command>

  <command name="firmar_libro">
    <pattern>firmar libro;escribir en libro;firmar;escribir en el libro</pattern>
    <script>
      if (not player.parent = sala_oculta) {
        msg ("No hay ningún libro aquí donde escribir.")
      }
      else {
        msg ("El libro de registro está abierto frente a ti. La última página está en blanco, esperando. Una pluma antigua descansa junto a él, con tinta que parece demasiado oscura para ser tinta.")
        msg ("")
        msg ("¿Qué escribes en el libro?")
        get input {
          if (LCase(result) = "libertad") {
            msg ("")
            msg ("Escribes 'LIBERTAD' con letras grandes y temblorosas. La tinta se hunde en el papel y por un momento, toda la casa tiembla.")
            msg ("")
            FinalEscape
          }
          else if (LCase(result) = LCase(game.nombre_jugador)) {
            msg ("")
            msg ("Escribes tu propio nombre. La tinta se extiende por la página como raíces, y sientes que algo dentro de ti se asienta, se calma, se rinde.")
            msg ("")
            FinalAceptacion
          }
          else if (LCase(result) = "ella" or LCase(result) = "sofía" or LCase(result) = "sofia") {
            if (game.salvo_sofia) {
              msg ("")
              msg ("Escribes su nombre. La tinta brilla por un momento con una luz que no debería existir en esta oscuridad.")
              msg ("")
              FinalSacrificio
            }
            else {
              msg ("")
              msg ("Escribes '" + result + "'. La tinta se seca inmediatamente, como si la página la rechazara. No pasa nada.")
            }
          }
          else {
            msg ("")
            msg ("Escribes '" + result + "' en el libro. Las letras se desvanecen lentamente, absorbidas por el papel. La página queda en blanco de nuevo, como si nunca hubieras escrito nada.")
          }
        }
      }
    </script>
  </command>

  <command name="hablar_amigo">
    <pattern>hablar con amigo;hablar con el amigo;amigo imaginario;hablar amigo</pattern>
    <script>
      if (not player.parent = habitacion_sofia) {
        msg ("No hay ningún amigo imaginario aquí. Al menos no uno que quiera hablar contigo.")
      }
      else {
        msg ("Te arrodillas junto a la esquina de la habitación donde Sofía dice que vive su amigo. El papel tapiz está desgarrado aquí, revelando una pared oscura y húmeda debajo.")
        msg ("")
        msg ("\"Hola,\" dices, sintiéndote ridículo.")
        msg ("")
        msg ("Silencio.")
        msg ("")
        msg ("Luego, un susurro. No viene de la pared. Viene de debajo del suelo.")
        msg ("")
        msg ("\"Hola, " + game.nombre_jugador + ". Te he estado esperando.\"")
        msg ("")
        msg ("\"Sofía es buena compañía, pero ella no puede oírme como tú. Tú puedes porque ya tienes un pie aquí abajo.\"")
        msg ("")
        msg ("\"¿Quieres saber un secreto? El código del sótano es el año en que Carmen dejó de envejecer. Pregúntale a Martín. Él lo registró todo.\"")
        msg ("")
        msg ("\"Nos vemos pronto. Más pronto de lo que crees.\"")
        msg ("")
        msg ("El susurro se apaga. El silencio que queda es peor que cualquier sonido.")
        game.hablo_amigo_imaginario = true
        if (not GetBoolean(game, "amigo_easter_egg")) {
          SetObjectFlagOn (game, "amigo_easter_egg")
          game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
        }
        IncrementarHorror (2)
      }
    </script>
  </command>

  <command name="ayuda_override">
    <pattern>ayuda</pattern>
    <script>
      game.veces_ayuda = game.veces_ayuda + 1
      if (game.veces_ayuda &lt;= 3) {
        msg ("═══════════════════════════════════════")
        msg ("  AYUDA — Nicanor Molinare")
        msg ("═══════════════════════════════════════")
        msg ("")
        msg ("Comandos útiles:")
        msg ("  - MIRAR / EXAMINAR: Observa tu entorno u objetos.")
        msg ("  - HABLAR CON [persona]: Intenta hablar con alguien.")
        msg ("  - TOMAR / COGER [objeto]: Recoge un objeto.")
        msg ("  - USAR [objeto]: Usa un objeto de tu inventario.")
        msg ("  - IR [dirección]: Muévete (norte, sur, este, oeste, arriba, abajo).")
        msg ("  - INVENTARIO: Revisa lo que llevas.")
        msg ("  - QUIEN SOY: Recuerda quién eres. O intenta.")
        msg ("")
        msg ("Consejo: Examina todo. Habla con todos. No confíes en nada.")
      }
      else {
        msg ("Nadie puede oírte. La última persona que pidió ayuda sigue en el cuarto frío.")
        if (not GetBoolean(game, "ayuda_easter_egg")) {
          SetObjectFlagOn (game, "ayuda_easter_egg")
          game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
        }
      }
    </script>
  </command>

  <command name="mirar_agua">
    <pattern>mirar agua;mirar el agua;ver agua;ver el agua</pattern>
    <script>
      if (not player.parent = bano_primer_piso) {
        msg ("No hay agua aquí que puedas mirar.")
      }
      else if (game.horror &lt; 9) {
        msg ("El agua del lavabo está sucia y estancada. No hay mucho que ver.")
      }
      else {
        msg ("Te inclinas sobre el lavabo y miras el agua estancada.")
        msg ("")
        msg ("Tu reflejo te devuelve la mirada. Pero algo está mal.")
        msg ("")
        msg ("Tu reflejo sonríe. Tú no estás sonriendo.")
        msg ("")
        msg ("Lentamente, muy lentamente, tu reflejo comienza a hundirse. Como si el agua lo jalara desde abajo. La cara sonriente se sumerge centímetro a centímetro, y lo último que ves antes de que desaparezca son los ojos — abiertos, fijos en ti, sin parpadear.")
        msg ("")
        msg ("El agua queda quieta. Tu reflejo ya no está.")
        msg ("")
        msg ("Cuando te miras las manos, están mojadas. No recuerdas haberlas metido en el agua.")
        if (not GetBoolean(game, "agua_easter_egg")) {
          SetObjectFlagOn (game, "agua_easter_egg")
          game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
        }
        IncrementarHorror (1)
      }
    </script>
  </command>

  <!-- ==================== TURNSCRIPTS ==================== -->

  <turnscript name="contador_turnos">
    <enabled />
    <script>
      game.turnos = game.turnos + 1
      if (game.turnos % 100 = 0) {
        msg ("")
        msg ("(Has estado aquí " + game.turnos + " turnos. Los demás aguantaron menos.)")
        msg ("")
        if (not GetBoolean(game, "turnos_easter_egg")) {
          SetObjectFlagOn (game, "turnos_easter_egg")
          game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
        }
      }
    </script>
  </turnscript>

  <turnscript name="verificar_horror">
    <enabled />
    <script>
      if (game.horror >= 15) {
        if (not game.acto = 4) {
          game.acto = 4
          JS.eval ("$('#gameContent').css({'color':'#b8a8a8'}); $('body').css({'background-color':'#080404'}); $('#gameContent').css({'background-color':'#080404'}); $('#gameBorder').css({'background-color':'#080404'});")
          msg ("")
          msg ("========== ACTO 4 - EL DESCENSO ==========")
          msg ("")
        }
      }
      else if (game.horror >= 14) {
        if (not game.acto = 3) {
          game.acto = 3
          JS.eval ("$('#gameContent').css({'color':'#c4b4a4'}); $('body').css({'background-color':'#090606'}); $('#gameContent').css({'background-color':'#090606'}); $('#gameBorder').css({'background-color':'#090606'});")
          msg ("")
          msg ("======= ACTO 3 - LO QUE HAY DEBAJO =======")
          msg ("")
        }
      }
      else if (game.horror >= 7) {
        if (not game.acto = 2) {
          game.acto = 2
          JS.eval ("$('#gameContent').css({'color':'#ccc4b8'}); $('body').css({'background-color':'#0a0808'}); $('#gameContent').css({'background-color':'#0a0808'}); $('#gameBorder').css({'background-color':'#0a0808'});")
          msg ("")
          msg ("========== ACTO 2 - LAS GRIETAS ==========")
          msg ("")
        }
      }
    </script>
  </turnscript>

  <turnscript name="notas_fantasma">
    <enabled />
    <script>
      if (game.horror >= 7) {
        if (game.turnos % 20 = 0) {
          notas = Split("SAL AHORA;NO CONFÍES EN CARMEN;EL SÓTANO MIENTE;YA ESTUVISTE AQUÍ", ";")
          indice = GetRandomInt(0, 3)
          nota_texto = StringListItem(notas, indice)
          msg ("")
          msg ("Encuentras una nota en el suelo que no estaba antes. Dice: '" + nota_texto + "'. Esta firmada con tus iniciales.")
          msg ("")
          if (not GetBoolean(game, "notas_fantasma_easter_egg")) {
            SetObjectFlagOn (game, "notas_fantasma_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
        }
      }
    </script>
  </turnscript>

  <turnscript name="susurros">
    <enabled />
    <script>
      if (game.horror >= 11) {
        dado = GetRandomInt(1, 5)
        if (dado = 1) {
          msg ("")
          msg ("Mientras caminas, escuchas un susurro detras de ti. Dice tu nombre. " + game.nombre_jugador + ". No hay nadie.")
          msg ("")
          if (not GetBoolean(game, "susurros_easter_egg")) {
            SetObjectFlagOn (game, "susurros_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
        }
      }
    </script>
  </turnscript>

  <turnscript name="game_over_falso">
    <enabled />
    <script>
      if (game.horror >= 18) {
        dado = GetRandomInt(1, 10)
        if (dado = 1) {
          ClearScreen
          msg ("")
          msg ("")
          msg ("")
          msg ("    G A M E   O V E R")
          msg ("")
          msg ("    Gracias por jugar Nicanor Molinare.")
          msg ("")
          msg ("")
          wait {
            ClearScreen
            msg ("")
            msg ("Es broma. No puedes irte.")
            msg ("")
            if (not GetBoolean(game, "gameover_easter_egg")) {
              SetObjectFlagOn (game, "gameover_easter_egg")
              game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
            }
          }
        }
      }
    </script>
  </turnscript>

  <turnscript name="hora_real_check">
    <enabled />
    <script>
      if (game.turnos % 10 = 0) {
        if (player.parent = pasillo_primer_piso or player.parent = tu_habitacion or player.parent = habitacion_martin or player.parent = habitacion_lucia or player.parent = habitacion_ramon or player.parent = habitacion_sofia or player.parent = bano_primer_piso) {
          JS.eval ("var h = new Date().getHours(); if (h >= 0 &amp;&amp; h &lt;= 4) { ASLEvent('HoraReal_Callback', 'noche'); } else { ASLEvent('HoraReal_Callback', 'dia'); }")
        }
      }
    </script>
  </turnscript>

  <turnscript name="actualizar_ui">
    <enabled />
    <script><![CDATA[
      if (not player.parent = game) {
        room_id = player.parent.name
        if (not GetBoolean(game, "ui_inicializada")) {
          SetObjectFlagOn(game, "ui_inicializada")
          JS.eval("window.NM={}; NM.rf={jardin_frontal:'ext',camino_pueblo:'ext',plaza_pueblo:'ext',calle_pueblo:'ext',camino_regreso:'ext',recepcion:'pb',sala_estar:'pb',comedor:'pb',cocina:'pb',bano_visitas:'pb',pasillo_servicio:'pb',lavadero:'pb',pasillo_primer_piso:'p1',tu_habitacion:'p1',habitacion_martin:'p1',habitacion_lucia:'p1',habitacion_ramon:'p1',habitacion_sofia:'p1',bano_primer_piso:'p1',escalera_segundo_piso:'p2',atico:'p2',habitacion_carmen:'p2',cuarto_servicio:'p2',escalera_sotano:'sot',bodega:'sot',cuarto_frio:'sot',sala_oculta:'sot'}; NM.fn={ext:'EXTERIOR',pb:'PLANTA BAJA',p1:'PRIMER PISO',p2:'SEGUNDO PISO',sot:'SOTANO'};")
          JS.eval("NM.ms={ext:'     Regreso\n        |\n      Calle\n        |\n      Plaza\n        |\n     Camino\n        |\n     Jardin\n        |\n     CASA ^',pb:'  Sala       Lavadero\n   |            |\n   |        P.Servicio\n   |            |\n  Bano--Recepcion--Comedor--Cocina',p1:' Bano1P TuHab  Sofia\n    \\     |    /\n   Pasillo 1er Piso\n    /     |    \\\n  Ramon Martin Lucia',p2:'  Atico    Carmen\n     \\      /\n   Escalera 2P\n       |\n   C.Servicio',sot:'     Bodega\n       |\n   Esc.Sotano\n       |\n     C.Frio\n       |\n   Sala Oculta'};")
          JS.eval("NM.rl={jardin_frontal:'Jardin',camino_pueblo:'Camino',plaza_pueblo:'Plaza',calle_pueblo:'Calle',camino_regreso:'Regreso',recepcion:'Recepcion',sala_estar:'Sala',comedor:'Comedor',cocina:'Cocina',bano_visitas:'Bano',pasillo_servicio:'P.Servicio',lavadero:'Lavadero',pasillo_primer_piso:'Pasillo 1er Piso',tu_habitacion:'TuHab',habitacion_martin:'Martin',habitacion_lucia:'Lucia',habitacion_ramon:'Ramon',habitacion_sofia:'Sofia',bano_primer_piso:'Bano1P',escalera_segundo_piso:'Escalera 2P',atico:'Atico',habitacion_carmen:'Carmen',cuarto_servicio:'C.Servicio',escalera_sotano:'Esc.Sotano',bodega:'Bodega',cuarto_frio:'C.Frio',sala_oculta:'Sala Oculta'};")
          JS.eval("NM.updateMap=function(rid){var f=NM.rf[rid];if(!f)return;var m=NM.ms[f];var l=NM.rl[rid];if(l){m=m.replace(l,'['+l+']');}var h='<div style=\'text-align:center;color:#cc4444;font-size:11px;letter-spacing:2px;margin-bottom:8px;font-family:Georgia,serif;\'>'+NM.fn[f]+'</div>';h+='<pre style=\'font-family:Consolas,monospace;font-size:10px;color:#888;line-height:1.5;margin:0;padding:5px;white-space:pre;\'>'+m+'</pre>';var ex='';if(f=='pb')ex='^ Primer Piso   v Exterior';if(f=='p1')ex='^ Segundo Piso   v Planta Baja';if(f=='p2')ex='v Primer Piso';if(f=='sot')ex='^ Lavadero';if(f=='ext')ex='^ Casa';if(ex)h+='<div style=\'text-align:center;margin-top:5px;color:#555;font-size:9px;font-style:italic;\'>'+ex+'</div>';var c=document.getElementById('nm-map');if(c)c.innerHTML=h;};")
          JS.eval("NM.doAct=function(v){var c=document.getElementById('txtCommand');if(c){c.value=v+' ';c.focus();}};")
          JS.eval("(function(){var p=document.getElementById('gamePanes');if(!p)return;var mc=document.createElement('div');mc.id='nm-map';mc.style.cssText='background:#0f0f0f;border:1px solid #331111;padding:10px;margin:5px;border-radius:4px;';p.insertBefore(mc,p.firstChild);var ap=document.createElement('div');ap.id='nm-actions';ap.style.cssText='background:#0f0f0f;border:1px solid #331111;padding:10px;margin:5px;border-radius:4px;';var t=document.createElement('div');t.style.cssText='text-align:center;color:#cc4444;font-size:11px;letter-spacing:2px;margin-bottom:8px;font-family:Georgia,serif;';t.textContent='ACCIONES';ap.appendChild(t);var bd=document.createElement('div');bd.style.cssText='display:flex;flex-wrap:wrap;gap:4px;justify-content:center;';var acts=[['Examinar','examinar'],['Tomar','tomar'],['Hablar con','hablar con'],['Abrir','abrir'],['Usar','usar'],['Leer','leer'],['Mirar','mirar']];for(var i=0;i<acts.length;i++){(function(label,cmd){var b=document.createElement('button');b.textContent=label;b.style.cssText='background:#1a0a0a;color:#cc8866;border:1px solid #331111;padding:4px 8px;font-size:10px;cursor:pointer;border-radius:3px;font-family:Georgia,serif;';b.onmouseover=function(){this.style.background='#2a1515';};b.onmouseout=function(){this.style.background='#1a0a0a';};b.onclick=function(){NM.doAct(cmd);};bd.appendChild(b);})(acts[i][0],acts[i][1]);}ap.appendChild(bd);mc.parentNode.insertBefore(ap,mc.nextSibling);})();")
          JS.eval("try{$('#gamePanes').children().not('#nm-map,#nm-actions').each(function(){var el=$(this);var t=el.text().toLowerCase();if(t.indexOf('inventario')>=0||t.indexOf('inventory')>=0||el.attr('id')==='inventoryAccordion'){return;}el.hide();});$('#placesObjectsAccordion,#compassAccordion').hide();$('#placesObjectsAccordion').prev().hide();$('#compassAccordion').prev().hide();}catch(e){}")
        }
        JS.eval("if(window.NM&&NM.updateMap)NM.updateMap('" + room_id + "');")
      }
    ]]></script>
  </turnscript>

  <turnscript name="efectos_cordura">
    <enabled />
    <script><![CDATA[
      if (game.horror >= 10) {
        JS.eval("if(!document.getElementById('nm-shake')){var s=document.createElement('style');s.id='nm-shake';s.textContent='@keyframes nmshake{0%{transform:translateX(0)}25%{transform:translateX(-1px)}75%{transform:translateX(1px)}100%{transform:translateX(0)}} #divOutput{animation:nmshake 0.3s infinite}';document.head.appendChild(s);}")
      }
      if (game.horror >= 14) {
        JS.eval("if(!document.getElementById('nm-pulse')){var s=document.createElement('style');s.id='nm-pulse';s.textContent='@keyframes nmpulse{0%{background-color:#080404}50%{background-color:#0a0606}100%{background-color:#080404}} body,#gameBorder,#gameContent{animation:nmpulse 4s infinite !important}';document.head.appendChild(s);}")
      }
      if (game.horror >= 17) {
        dado = GetRandomInt(1, 10)
        if (dado = 1) {
          JS.eval("$('#gameContent').css('font-size','16px');setTimeout(function(){$('#gameContent').css('font-size','13px');},2000);")
          msg ("")
          msg ("(Algo respiro a traves de la pantalla.)")
          msg ("")
        }
      }
      if (game.horror >= 19) {
        JS.eval("if(!NM.titleInterval){var titles=['Nicanor Molinare','TE ESTOY MIRANDO','" + game.nombre_jugador + "','NO CIERRES ESTA VENTANA'];var idx=0;NM.titleInterval=setInterval(function(){document.title=titles[idx%titles.length];idx++;},30000);}")
      }
      if (game.horror >= 13) {
        dado2 = GetRandomInt(1, 12)
        if (dado2 = 1) {
          frases = Split("no abras esa puerta;sal de aqui;el te ve;estas solo;no confies en nadie", ";")
          indice = GetRandomInt(0, 4)
          frase = StringListItem(frases, indice)
          JS.eval("(function(){var cmd=document.getElementById('txtCommand');if(!cmd)return;var txt='" + frase + "';var i=0;var iv=setInterval(function(){if(i<txt.length){cmd.value+=txt.charAt(i);i++;}else{clearInterval(iv);setTimeout(function(){cmd.value='';},3000);}},100);})();")
        }
      }
      if (game.horror >= 16) {
        dado3 = GetRandomInt(1, 20)
        if (dado3 = 1) {
          JS.eval("$('body,#gameBorder,#gameContent').css('background-color','#ffffff');$('#gameContent').css('color','#000000');setTimeout(function(){$('body,#gameBorder,#gameContent').css('background-color','#080404');$('#gameContent').css('color','#d4d4c8');},100);")
          msg ("(Parpadeo la pantalla o parpadeaste tu?)")
        }
      }
      JS.eval("if(window.NMA&&NMA.updateAudio)NMA.updateAudio(" + game.horror + ");")
    ]]></script>
  </turnscript>

  <turnscript name="cerrar_falso">
    <enabled />
    <script><![CDATA[
      if (game.horror >= 15) {
        if (GetRandomInt(1, 33) = 1) {
          if (not game.easter_cerrar) {
            game.easter_cerrar = true
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
          msg ("")
          msg ("Cerrando Nicanor Molinare...")
          wait {
            msg ("Error: Permiso denegado. La aplicacion se niega a cerrarse.")
            wait {
              msg ("")
              msg ("Buen intento, " + game.nombre_jugador + ". Pero este no es tu juego. Es el mio. — La Casa")
              msg ("")
            }
          }
        }
      }
    ]]></script>
  </turnscript>

  <turnscript name="easter_nombre_letras">
    <enabled />
    <script><![CDATA[
      if (game.horror >= 12 and not game.easter_nombre) {
        if (GetRandomInt(1, 15) = 1) {
          game.easter_nombre = true
          game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          if (LengthOf(game.nombre_jugador) = 6) {
            msg ("")
            msg ("Curioso. Tu nombre tiene 6 letras. Como Carmen. Como Martin. Como Sofia. Todos los nombres aqui tienen 6 letras. Coincidencia?")
            msg ("")
          }
          else {
            msg ("")
            msg ("Curioso. Todos los nombres de los huespedes tienen 6 letras. Todos menos el tuyo. Eres diferente. O eso quieres creer.")
            msg ("")
          }
        }
      }
    ]]></script>
  </turnscript>

  <function name="HoraReal_Callback" parameters="momento">
    if (momento = "noche") {
      if (player.parent = pasillo_primer_piso or player.parent = tu_habitacion or player.parent = habitacion_sofia or player.parent = bano_primer_piso) {
        if (GetRandomInt(1, 3) = 1) {
          msg ("")
          msg ("Son las tantas de la madrugada. En la vida real. Y aquí estás, jugando esto. A esta hora las paredes son más delgadas entre tu mundo y el nuestro. ¿Escuchas eso? Pasos. No son del juego. Compruébalo.")
          msg ("")
          if (not GetBoolean(game, "hora_real_easter_egg")) {
            SetObjectFlagOn (game, "hora_real_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
        }
      }
    }
  </function>
  <!-- ============================================================ -->
  <!-- PARTE 2: HABITACIONES EXTERIORES Y PLANTA BAJA               -->
  <!-- ============================================================ -->

  <!-- ==================== EXTERIOR ==================== -->

  <object name="jardin_frontal">
    <inherit name="editor_room" />
    <alias>Jardín Frontal</alias>
    <description type="script"><![CDATA[
      if (game.horror < 5) {
        msg ("Un jardín amplio y cuidado se extiende frente a la casa. Un sendero de piedra serpentea entre rosales y hortensias que perfuman el aire con una dulzura casi empalagosa. Una puerta de hierro forjado marca el límite de la propiedad, sus barrotes cubiertos de hiedra. La luz del sol baña cada rincón con una calidez reconfortante, y las abejas zumban perezosamente entre los pétalos. Todo parece sacado de una postal de otro siglo.")
      } else if (game.horror < 9) {
        msg ("El jardín frontal se extiende ante ti, pero algo ha cambiado. Las flores siguen ahí, hermosas, aunque sus colores parecen demasiado intensos, casi artificiales. El sendero de piedra parece más largo de lo que recuerdas. La puerta de hierro chirría suavemente aunque no hay viento. Las abejas han desaparecido. Un silencio pesado cuelga sobre los rosales como una red invisible.")
      } else if (game.horror < 13) {
        msg ("El jardín ha perdido toda pretensión de belleza. Las flores se inclinan hacia ti cuando pasas, como si te siguieran. El sendero de piedra tiene grietas que no estaban antes, y entre ellas crece algo oscuro y húmedo. La puerta de hierro está oxidada hasta los huesos, sus barrotes retorcidos en ángulos imposibles. El aire huele a tierra removida, a algo enterrado que no debería estarlo.")
      } else {
        msg ("El jardín es un cementerio que finge ser un jardín. Las flores son de un rojo enfermizo, del color exacto de la sangre seca. El sendero de piedra parece hundirse ligeramente bajo tus pies, como si caminases sobre algo blando. La puerta de hierro muestra símbolos que antes no estaban ahí. Y en un rincón, entre los rosales muertos, hay algo nuevo: una lápida de piedra gris que juras que antes no existía.")
      }
    ]]></description>

    <object name="flores">
      <inherit name="editor_object" />
      <alias>flores</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Rosales rojos y blancos, hortensias azuladas, margaritas silvestres. Un jardín mantenido con esmero y dedicación. Las flores están perfectas, como si las hubiesen plantado esta misma mañana.")
        } else if (game.horror < 13) {
          msg ("Las flores se inclinan hacia ti de forma casi imperceptible. Sus pétalos tienen venas oscuras que antes no habías notado. Algunas rosas rojas parecen latir suavemente, como pequeños corazones vegetales.")
        } else {
          msg ("Las flores están marchitas pero no muertas. Se retuercen lentamente, abriéndose y cerrándose como bocas diminutas. Sus raíces sobresalen de la tierra, pálidas y gruesas, como dedos que buscan algo que agarrar.")
        }
      ]]></look>
    </object>

    <object name="camino_piedra">
      <inherit name="editor_object" />
      <alias>camino de piedra</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Un sendero de piedras lisas y bien colocadas que lleva desde la puerta de hierro hasta la entrada de la casa. Las piedras están gastadas por décadas de pasos, pulidas hasta brillar suavemente bajo la luz. Musgo verde crece entre las juntas, dándole un aspecto encantador.")
        } else {
          msg ("Las piedras del camino están agrietadas y desiguales. Algunas se han hundido, otras sobresalen en ángulos incómodos. Las juntas están rellenas de algo oscuro que no es musgo. Si miras de reojo, las piedras parecen reorganizarse cuando no las observas directamente.")
        }
      ]]></look>
    </object>

    <object name="puerta_hierro">
      <inherit name="editor_object" />
      <alias>puerta de hierro</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Una puerta de hierro forjado con elaborados arabescos. La hiedra la envuelve parcialmente, dándole un aspecto romántico. Se abre y se cierra con facilidad, aunque emite un leve chirrido. Más allá de ella, un camino de tierra se pierde entre los árboles.")
        } else if (game.horror < 13) {
          msg ("La puerta de hierro está más oxidada de lo que recuerdas. Los arabescos parecen formar figuras que se retuercen: rostros con las bocas abiertas en gritos silenciosos. La hiedra la aprieta como si intentase estrangularla. Cuando la tocas, el metal está frío incluso bajo el sol.")
        } else {
          msg ("Los barrotes de la puerta se han curvado hacia dentro, como costillas de una jaula diseñada para mantener algo dentro, no fuera. Los arabescos forman claramente palabras en un idioma que no reconoces. La hiedra ha muerto pero sigue aferrada al hierro, seca y quebradiza como huesos viejos.")
        }
      ]]></look>
    </object>

    <object name="tumba_jardin">
      <inherit name="editor_object" />
      <alias>lápida</alias>
      <look type="script"><![CDATA[
        if (game.horror >= 13) {
          msg ("Te acercas a la lápida de piedra gris entre los rosales. Está cubierta de musgo y liquen, pero las letras talladas son perfectamente legibles.")
          msg ("")
          msg ("  " + game.nombre_jugador)
          msg ("  Fecha de nacimiento: una que conoces demasiado bien.")
          msg ("  Fecha de defunción: hoy.")
          msg ("")
          msg ("El suelo frente a la lápida está removido. Fresco. Como si alguien hubiese cavado recientemente.")
          if (not game.vio_tumba) {
            game.vio_tumba = true
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
            msg ("")
            msg ("Un escalofrío te recorre de pies a cabeza. Esto no puede ser real.")
            IncrementarHorror (2)
          }
        } else {
          msg ("No ves ninguna lápida. Solo rosales y tierra húmeda.")
        }
      ]]></look>
      <scenery />
    </object>

    <exit alias="norte" to="recepcion">
      <inherit name="northdirection" />
    </exit>
    <exit alias="sur" to="camino_pueblo">
      <inherit name="southdirection" />
      <script type="script"><![CDATA[
        if (game.pueblo_desaparecido) {
          msg ("¿Pueblo? ¿Qué pueblo? Miras hacia el sur y solo ves niebla. Un camino que no lleva a ninguna parte. Pero aun así... tus pies se mueven solos.")
          msg ("")
        }
        if (game.visito_pueblo) {
          game.visito_pueblo_2 = true
        }
        game.visito_pueblo = true
        MoveObject (player, camino_pueblo)
      ]]></script>
    </exit>
  </object>

  <object name="camino_pueblo">
    <inherit name="editor_room" />
    <alias>Camino al Pueblo</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Un camino de tierra compactada se extiende hacia el sur, flanqueado por árboles altos y delgados que forman un túnel natural de sombras y luz moteada. No hay pájaros cantando. No hay brisa moviendo las hojas. El silencio es tan absoluto que puedes escuchar tu propia sangre circulando. El camino parece no haber sido transitado en mucho tiempo; la hierba crece entre las rodadas de un carro que pasó hace décadas.")
      } else {
        msg ("El camino de tierra se adentra en una oscuridad que no debería existir a esta hora del día. Los árboles a ambos lados se inclinan sobre el sendero como figuras encapuchadas que observan tu paso. No hay sonido alguno: ni pájaros, ni insectos, ni viento. Solo el crujir de tus propios pasos sobre la tierra seca. Cuanto más caminas, más sientes que el camino se alarga, que los árboles se multiplican, que nunca llegarás a ningún sitio.")
      }
    ]]></description>

    <object name="arboles">
      <inherit name="editor_object" />
      <alias>árboles</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Álamos y robles viejos flanquean el camino. Sus troncos son gruesos y retorcidos por la edad. Las hojas están completamente inmóviles, como si el tiempo se hubiese detenido en sus ramas. Ni una sola hoja se mueve. Es antinatural.")
        } else {
          msg ("Los árboles parecen más cerca del camino que antes. Sus ramas se extienden como brazos huesudos, y en la corteza de varios troncos distingues formas que parecen rostros con las bocas abiertas. Uno de los árboles tiene marcas de uñas, muchas, a la altura de una persona que intentase trepar desesperadamente.")
        }
      ]]></look>
    </object>

    <object name="cartel_pueblo">
      <inherit name="editor_object" />
      <alias>cartel</alias>
      <look type="script"><![CDATA[
        msg ("Un cartel de madera podrida señala hacia el sur. Las letras, apenas visibles bajo capas de pintura descascarillada, dicen:")
        msg ("")
        msg ("  VALLE QUIETO - 2 km")
        msg ("")
        if (game.horror < 7) {
          msg ("La pintura es tan antigua que se deshace al tacto. ¿Cuánto tiempo lleva este cartel aquí? Debajo de la pintura descascarillada parece haber otra capa, más antigua, con un nombre diferente que no alcanzas a leer.")
        } else {
          msg ("Debajo de la pintura descascarillada hay otra capa con otro nombre: 'VALLE DE LOS CALLADOS'. Y debajo de esa, otra más: 'VALLE SIN RETORNO'. Cada capa es más antigua que la anterior. ¿Cuántas veces han renombrado este lugar?")
        }
      ]]></look>
    </object>

    <exit alias="norte" to="jardin_frontal">
      <inherit name="northdirection" />
    </exit>
    <exit alias="sur" to="plaza_pueblo">
      <inherit name="southdirection" />
    </exit>
  </object>

  <object name="plaza_pueblo">
    <inherit name="editor_room" />
    <alias>Plaza del Pueblo</alias>
    <description type="script"><![CDATA[
      msg ("Una plaza vacía se abre ante ti como la palma de una mano muerta. En el centro, una fuente de piedra que lleva décadas sin agua. A su alrededor, edificios de fachadas descoloridas con las contraventanas cerradas a cal y canto. No hay nadie. No hay ropa tendida, ni macetas en las ventanas, ni el más mínimo signo de vida humana. El silencio es tan profundo que sientes presión en los tímpanos, como si estuvieses bajo el agua.")
      if (game.horror >= 7) {
        msg ("")
        msg ("Podrías jurar que una de las contraventanas se movió cuando no mirabas directamente. Y el reloj de la iglesia, en lo alto de un campanario invisible, marca una hora que no existe.")
      }
      if (game.horror >= 13) {
        msg ("")
        msg ("En las paredes de los edificios hay mensajes escritos con algo oscuro: 'NO TE VAYAS', 'QUÉDATE', 'ERES NUESTRO'. La caligrafía es infantil.")
      }
    ]]></description>

    <object name="fuente_seca">
      <inherit name="editor_object" />
      <alias>fuente seca</alias>
      <look type="script"><![CDATA[
        msg ("Una fuente circular de piedra labrada, seca como un hueso. En el fondo se acumulan hojas secas, polvo y monedas. Te inclinas para verlas mejor: hay pesetas, maravedíes, reales de vellón... monedas de siglos diferentes, como si la gente hubiese lanzado deseos a esta fuente durante trescientos años.")
        if (game.horror >= 10) {
          msg ("")
          msg ("Entre las monedas hay algo que brilla de forma diferente. Es una moneda moderna, de este año. En su reverso, alguien ha grabado tu nombre con un alfiler.")
        }
      ]]></look>
    </object>

    <object name="edificios">
      <inherit name="editor_object" />
      <alias>edificios</alias>
      <look type="script"><![CDATA[
        msg ("Edificios de dos plantas con fachadas de estuco agrietado y descolorido. Todas las puertas están cerradas. Todas las ventanas, tapadas con contraventanas de madera. Intentas empujar una puerta: no cede. Intentas otra: lo mismo. Es como si los edificios fuesen bloques sólidos de piedra disfrazados de casas.")
        if (game.horror >= 7) {
          msg ("")
          msg ("Acercas el oído a una de las puertas. Al principio no oyes nada. Luego, muy débilmente, algo que podría ser una respiración. O muchas respiraciones sincronizadas.")
        }
      ]]></look>
    </object>

    <object name="banco_plaza">
      <inherit name="editor_object" />
      <alias>banco</alias>
      <look type="script"><![CDATA[
        msg ("Un banco de hierro y madera frente a la fuente, desgastado por generaciones de vecinos que se sentaban a ver pasar la vida. La madera está astillada y la pintura verde se pela en láminas finas. En el respaldo, docenas de iniciales grabadas a cuchillo: parejas de enamorados, fechas de veranos lejanos.")
        if (game.horror >= 10) {
          msg ("")
          msg ("La última inscripción grabada es reciente. La madera aún está clara donde el cuchillo cortó. Dice: '" + game.nombre_jugador + " estuvo aquí'. No recuerdas haber grabado nada.")
        }
      ]]></look>
    </object>

    <exit alias="norte" to="camino_pueblo">
      <inherit name="northdirection" />
    </exit>
    <exit alias="este" to="calle_pueblo">
      <inherit name="eastdirection" />
    </exit>
  </object>

  <object name="calle_pueblo">
    <inherit name="editor_room" />
    <alias>Calle del Pueblo</alias>
    <description type="script"><![CDATA[
      msg ("Una calle estrecha y empedrada, la única del pueblo, flanqueada por comercios cerrados cuyos carteles se han desteñido hasta la ilegibilidad. El polvo lo cubre todo: los escaparates, los marcos de las puertas, los adoquines. Tus pisadas levantan pequeñas nubes que tardan demasiado en posarse, como si la gravedad aquí fuese ligeramente diferente.")
      if (game.horror < 7) {
        msg ("La sensación de abandono es abrumadora. Este lugar lleva muerto mucho tiempo. Te preguntas adónde fueron todos.")
      } else {
        msg ("No están abandonados. Están esperando. Cada ventana oscura es un ojo que te observa. Cada puerta cerrada contiene algo que quiere salir pero aún no es el momento. Sientes la atención de decenas de presencias invisibles clavada en tu nuca como agujas de hielo.")
      }
      if (game.horror >= 13) {
        msg ("")
        msg ("Un cartel en una de las tiendas se ha vuelto legible de repente. Dice: 'CARNICERÍA'. En el escaparate polvoriento hay formas pálidas que podrían ser maniquíes. Podrían.")
      }
    ]]></description>

    <object name="tiendas">
      <inherit name="editor_object" />
      <alias>tiendas</alias>
      <look type="script"><![CDATA[
        msg ("Comercios de otro siglo: una mercería, lo que parece una ferretería, algo que pudo ser una panadería. Todos cerrados. Los carteles son ilegibles bajo capas de mugre y tiempo. Los escaparates están tan sucios que solo puedes ver sombras borrosas detrás del cristal.")
        if (game.horror >= 10) {
          msg ("")
          msg ("Limpias con la manga una esquina de un escaparate. Detrás del cristal, en la penumbra, hay una figura sentada en una silla. Inmóvil. Antes de que puedas determinar qué es, la mugre vuelve a cubrir el cristal como si nunca lo hubieses limpiado.")
        }
      ]]></look>
    </object>

    <object name="ventanas_oscuras">
      <inherit name="editor_object" />
      <alias>ventanas oscuras</alias>
      <look type="script"><![CDATA[
        msg ("Las ventanas de los pisos superiores son rectángulos de oscuridad absoluta. No hay cortinas, ni cristales rotos, ni reflejos. Solo vacío negro que absorbe la luz.")
        if (game.horror < 7) {
          msg ("Crees ver movimiento detrás de una ventana. Luego nada. Probablemente fue tu imaginación.")
        } else {
          msg ("Hay movimiento detrás de varias ventanas. Sombras que se desplazan lentamente de un lado a otro, como personas caminando en círculos dentro de habitaciones a oscuras. No es tu imaginación. Desearías que lo fuese.")
        }
      ]]></look>
    </object>

    <object name="farola">
      <inherit name="editor_object" />
      <alias>farola</alias>
      <look type="script"><![CDATA[
        msg ("Una farola de hierro fundido con un fanal de cristal opaco. No funciona, obviamente. No hay cables eléctricos en todo el pueblo. En la base de la farola, medio enterrada en el polvo, hay una placa de bronce: 'Donación de la familia Valdecueva, 1923'.")
        if (game.horror >= 7) {
          msg ("")
          msg ("La farola emite un zumbido grave, casi inaudible, como si la electricidad intentase fluir por cables que ya no existen. El fanal tiene una grieta en forma de espiral que no viste antes.")
        }
      ]]></look>
    </object>

    <exit alias="oeste" to="plaza_pueblo">
      <inherit name="westdirection" />
    </exit>
    <exit alias="sur" to="camino_regreso">
      <inherit name="southdirection" />
    </exit>
  </object>

  <object name="camino_regreso">
    <inherit name="editor_room" />
    <alias>Camino de Regreso</alias>
    <description type="script"><![CDATA[
      msg ("Sigues caminando. El camino se curva suavemente a la derecha. Luego a la izquierda. Llevas un buen rato andando pero el paisaje no cambia. Los mismos árboles, las mismas piedras, la misma luz oblicua.")
      msg ("")
      msg ("Caminas más rápido. El camino se curva otra vez. Y otra. Empiezas a reconocer marcas en los árboles. Has pasado por aquí antes. El camino describe un círculo perfecto.")
      msg ("")
      msg ("Y entonces ves la casa. Nicanor Molinare, con su fachada elegante y sus ventanas iluminadas, aparece ante ti como si nunca te hubieses marchado. El camino siempre te trae de vuelta.")
      msg ("")
      msg ("Bienvenido de vuelta. Todos vuelven.")
      game.pueblo_desaparecido = true
      if (not GetBoolean(game, "easter_camino_regreso")) {
        game.easter_camino_regreso = true
        game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
      }
      IncrementarHorror (1)
      MoveObject (player, recepcion)
    ]]></description>
  </object>

  <!-- ==================== PLANTA BAJA ==================== -->

  <object name="recepcion">
    <inherit name="editor_room" />
    <alias>Recepción</alias>
    <description type="script"><![CDATA[
      if (game.horror < 4) {
        msg ("La recepción de Nicanor Molinare te envuelve con una calidez reconfortante. Un mostrador de madera oscura y noble preside la estancia, detrás del cual cuelgan llaves de latón en un tablero numerado. Varias pinturas al óleo adornan las paredes empapeladas con motivos florales, mostrando paisajes del valle en diferentes estaciones. Una lámpara de aceite sobre el mostrador emite una luz dorada y estable. Desde algún lugar llega un delicioso aroma a pan recién horneado y estofado casero.")
      } else if (game.horror < 7) {
        msg ("La recepción parece la misma de siempre, pero algo no encaja. La luz de la lámpara de aceite parpadea a intervalos irregulares, proyectando sombras que danzan en las paredes. Las pinturas al óleo... ¿no mostraban paisajes diferentes antes? Podrías jurarlo. El mostrador de madera cruje suavemente aunque nadie lo toca. El aroma a pan se mezcla ahora con otro olor, más profundo, más antiguo. Como libros viejos y humedad.")
      } else if (game.horror < 10) {
        msg ("Las paredes de la recepción parecen más cercanas que ayer. El empapelado floral se ha oscurecido y las flores del estampado parecen marchitas. El mostrador tiene marcas de arañazos que antes no estaban ahí. Las pinturas muestran los mismos paisajes pero bajo cielos tormentosos y sin personas. La lámpara de aceite arde con una llama azulada que no debería existir. Y en el libro de registro, cada vez que pasas la vista por encima, juras que hay más nombres que la última vez que lo viste.")
      } else {
        msg ("La recepción es una versión enferma de sí misma. El empapelado se despega en tiras que cuelgan como piel muerta. Las pinturas al óleo muestran escenas que no estaban antes: figuras sin rostro en paisajes carbonizados, una casa que arde en un valle de ceniza. El mostrador supura una sustancia oscura por las grietas de la madera. La lámpara de aceite está apagada pero de algún modo hay luz, una luz gris y uniforme que no proyecta sombras. El libro de registro sangra tinta negra por los bordes.")
      }
    ]]></description>

    <object name="libro_registro">
      <inherit name="editor_object" />
      <alias>libro de registro</alias>
      <look type="script"><![CDATA[
        msg ("Abres el pesado libro de registro encuadernado en cuero. Las páginas están amarillentas y cubiertas de firmas en tinta desvaída. Los últimos registros legibles son:")
        msg ("")
        msg ("  - Martín Blackwood, 14 de octubre de 1983")
        msg ("  - Elena Voss, 3 de marzo de 1991")
        msg ("  - Ricardo Hale, 22 de julio de 2001")
        msg ("  - Isabel Crane, 9 de noviembre de 2015")
        msg ("  - " + game.nombre_jugador + ", " + "fecha de hoy")
        if (game.horror >= 16) {
          msg ("")
          msg ("Espera. Hay otro nombre, justo encima del tuyo, escrito con una caligrafía que se parece inquietantemente a la tuya:")
          msg ("")
          msg ("  - " + game.nombre_jugador + ", una semana antes de tu llegada.")
          msg ("")
          msg ("La tinta aún está fresca.")
          if (not GetBoolean(game, "vio_libro_registro_sexto")) {
            game.vio_libro_registro_sexto = true
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
            IncrementarHorror (1)
          }
        }
      ]]></look>
    </object>

    <object name="mostrador">
      <inherit name="editor_object" />
      <alias>mostrador</alias>
      <look type="script"><![CDATA[
        msg ("Un mostrador de madera oscura, gastado por incontables manos que se han apoyado en él a lo largo de décadas. La superficie está pulida por el uso, con pequeños surcos donde los huéspedes tamboreaban los dedos esperando ser atendidos. Detrás, un tablero con ganchos de latón sostiene llaves numeradas. Algunas faltan.")
        if (game.horror >= 7) {
          msg ("")
          msg ("Los surcos en la madera forman patrones. No son aleatorios. Si entrecierras los ojos, parecen letras. Palabras. 'AYUDA'. 'NO SALGAS'. 'ÉL ESCUCHA'. Grabadas por uñas desesperadas a lo largo de muchos años.")
        }
      ]]></look>
    </object>

    <object name="pinturas_recepcion">
      <inherit name="editor_object" />
      <alias>pinturas</alias>
      <look type="script"><![CDATA[
        if (game.horror < 4) {
          msg ("Cuatro pinturas al óleo en marcos dorados. Muestran el valle en cada estación: primavera con flores silvestres, verano con campos dorados, otoño con hojas carmesí, invierno con nieve prístina. Son hermosas, pintadas con gran habilidad y detalle. En cada una aparece Nicanor Molinare al fondo, pequeña y acogedora.")
        } else if (game.horror < 7) {
          msg ("Las cuatro pinturas muestran las mismas estaciones, pero... ¿la primavera no tenía más flores antes? ¿El verano no era más brillante? Los colores se han apagado sutilmente. Y en la pintura de invierno, juras que hay huellas en la nieve que antes no estaban. Huellas que van hacia la casa pero ninguna que salga.")
        } else if (game.horror < 13) {
          msg ("Las pinturas han cambiado. Ya no hay duda. La primavera muestra flores marchitas. El verano está nublado. El otoño muestra árboles desnudos y retorcidos. El invierno muestra la casa rodeada de figuras oscuras en la nieve. Y en las cuatro pinturas, hay una ventana iluminada en el ático. Una ventana que no recuerdas en la casa real.")
        } else {
          msg ("Las pinturas muestran la misma escena en las cuatro estaciones: Nicanor Molinare envuelta en llamas negras que no dan luz. Frente a ella, una hilera de figuras inmóviles observa el fuego sin intentar apagarlo. Una de las figuras se parece a ti.")
        }
      ]]></look>
    </object>

    <exit alias="sur" to="jardin_frontal">
      <inherit name="southdirection" />
      <script type="script"><![CDATA[
        if (game.pueblo_desaparecido) {
          msg ("Sientes un escalofrío al dirigirte hacia la puerta. Algo en tu interior te dice que fuera ya no queda nada. Pero tus pies avanzan de todas formas.")
          msg ("")
        }
        MoveObject (player, jardin_frontal)
      ]]></script>
    </exit>
    <exit alias="norte" to="sala_estar">
      <inherit name="northdirection" />
    </exit>
    <exit alias="este" to="comedor">
      <inherit name="eastdirection" />
    </exit>
    <exit alias="oeste" to="bano_visitas">
      <inherit name="westdirection" />
    </exit>
    <exit alias="subir" to="pasillo_primer_piso">
      <inherit name="updirection" />
    </exit>
  </object>

  <object name="sala_estar">
    <inherit name="editor_room" />
    <alias>Sala de Estar</alias>
    <description type="script"><![CDATA[
      if (game.horror < 4) {
        msg ("Una sala amplia y acogedora, dominada por una chimenea de piedra donde crepita un fuego cálido. Dos sofás tapizados en tela granate flanquean una mesita baja con un jarrón de flores secas. Una gran estantería de roble ocupa toda una pared, repleta de libros de lomos gastados. Un cuadro al óleo de un paisaje montañoso cuelga sobre la chimenea. La luz del fuego baña todo con un resplandor anaranjado que invita a sentarse y perderse en la lectura.")
      } else if (game.horror < 7) {
        msg ("La sala de estar mantiene su aspecto acogedor, pero los detalles inquietan. La chimenea arde con un fuego que nunca necesita más leña. Los sofás tienen marcas de uso en asientos donde juras que nadie se ha sentado. La estantería de roble cruje levemente, como si los libros se reacomodaran solos. El cuadro sobre la chimenea muestra el mismo paisaje de siempre, aunque las nubes parecen haberse movido.")
      } else if (game.horror < 13) {
        msg ("La sala de estar es una parodia de confort. El fuego de la chimenea arde sin producir calor, sus llamas de un azul enfermizo. Los sofás tienen hendiduras profundas, marcas de cuerpos que no puedes ver pero que sientes observándote. Los libros de la estantería cambian de posición cuando no los miras. El cuadro muestra ahora un valle arrasado bajo un cielo rojo, y en primer plano, una figura solitaria que camina hacia la casa.")
      } else {
        msg ("No quieres estar aquí. La chimenea vomita un fuego negro que se mueve contra la gravedad. Los sofás respiran. La estantería gime bajo el peso de libros que parecen palpitar. El cuadro sobre la chimenea te muestra a ti, de espaldas, entrando en la casa por primera vez. Pintado con una precisión imposible. Al pie del cuadro, en letras pequeñas: 'Huésped número " + game.nombre_jugador + ". Permanente.'")
      }
    ]]></description>

    <object name="chimenea">
      <inherit name="editor_object" />
      <alias>chimenea</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Una chimenea de piedra gris con un buen fuego crepitando alegremente. Los troncos arden con un calor reconfortante que se siente en todo el cuerpo. La repisa está adornada con pequeñas figuras de porcelana: un pastor, una pastora, un cordero. Encima, el cuadro de paisaje.")
        } else {
          msg ("El fuego arde, pero no produce calor. Acercas las manos y solo sientes frío. Las llamas se mueven de forma extraña, como grabaciones reproducidas al revés. Los troncos no se consumen; llevan ardiendo desde que llegaste y no han menguado ni un milímetro. Las figuras de porcelana de la repisa han cambiado de posición. El pastor mira ahora hacia la pared. La pastora no tiene cara.")
        }
      ]]></look>
    </object>

    <object name="sofas">
      <inherit name="editor_object" />
      <alias>sofás</alias>
      <look type="script"><![CDATA[
        if (game.horror < 10) {
          msg ("Dos sofás amplios tapizados en terciopelo granate, mullidos y cómodos. El tipo de sofá que te atrapa durante horas una tarde lluviosa. Los cojines están perfectamente colocados, como si alguien los hubiese arreglado justo antes de que llegaras.")
        } else {
          msg ("Los sofás tienen hendiduras en los asientos, marcas de cuerpos invisibles que se hunden en el terciopelo gastado. Mientras miras, una de las hendiduras se hace más profunda, como si alguien se estuviese sentando lentamente. Un cojín se desplaza un centímetro hacia la derecha. Solo.")
        }
      ]]></look>
    </object>

    <object name="cuadro_sala">
      <inherit name="editor_object" />
      <alias>cuadro</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Un óleo de buen tamaño que muestra un valle verde bajo un cielo de verano. Montañas azuladas al fondo, un río serpenteante, y en un claro, una casa que se parece mucho a esta. La pintura es detallada y hermosa, aunque no lleva firma.")
        } else {
          msg ("El cuadro ha cambiado. El valle sigue ahí pero bajo un cielo gris plomizo. El río está seco. La casa del claro tiene las ventanas rotas. No llevas aquí tanto tiempo... ¿cómo puede haber cambiado la pintura?")
        }
        msg ("")
        msg ("El marco dorado está ligeramente separado de la pared. Parece que hay algo detrás.")
      ]]></look>
    </object>

    <object name="reverso_cuadro">
      <inherit name="editor_object" />
      <alias>detrás del cuadro</alias>
      <alt type="simplestringlist">reverso del cuadro;detras del cuadro;reverso;parte trasera del cuadro</alt>
      <look type="script"><![CDATA[
        msg ("Apartas el cuadro de la pared con cuidado. En la parte trasera, pegada al bastidor con cera antigua, hay una página amarillenta cubierta de escritura apretada.")
        if (not game.encontro_pagina_3) {
          msg ("")
          msg ("¡Es una página de un diario! La arrancas cuidadosamente del bastidor.")
          msg ("")
          msg ("La página dice: 'Día 47. Los libros se mueven. Cada noche cambian de orden. He intentado leerlos en el orden correcto pero siempre cambian. ¿Y si el orden correcto es el inverso? El último primero. El primero al final. Como todo en esta casa. Todo está al revés.'")
          game.encontro_pagina_3 = true
          game.paginas_diario = game.paginas_diario + 1
          if (game.paginas_diario >= 3) {
            game.encontro_diario = true
            IncrementarHorror (4)
            msg ("")
            msg ("Has reunido las tres páginas del diario. Las palabras del antiguo huésped cobran un sentido terrible. Esta casa no es lo que parece. Nunca lo fue.")
          }
        } else {
          msg ("Ya tomaste la página que estaba aquí. Solo queda la marca en el bastidor donde estuvo pegada.")
        }
      ]]></look>
    </object>

    <object name="estanteria">
      <inherit name="editor_object" />
      <alias>estantería</alias>
      <look type="script"><![CDATA[
        msg ("Una gran estantería de roble macizo que ocupa toda la pared norte. Está repleta de libros, pero cinco de ellos destacan por sus lomos más brillantes y sus títulos legibles, como si quisieran ser leídos:")
        msg ("")
        msg ("  1. 'Crónicas de Valle Quieto'")
        msg ("  2. 'El Huésped Eterno'")
        msg ("  3. 'Memorias de la Casa'")
        msg ("  4. 'Puertas Sin Salida'")
        msg ("  5. 'El Último Registro'")
        msg ("")
        msg ("Los demás libros tienen los títulos borrados o escritos en idiomas irreconocibles. Estos cinco parecen los únicos que importan.")
      ]]></look>
    </object>

    <object name="libro_5">
      <inherit name="editor_object" />
      <alias>El Último Registro</alias>
      <alt type="simplestringlist">ultimo registro;libro 5;quinto libro</alt>
      <look type="script"><![CDATA[
        msg ("'El Último Registro'. Un tomo delgado encuadernado en cuero negro. Contiene listas de nombres, fechas de llegada y... nada más. No hay fechas de salida. Ninguna. Cientos de nombres y ninguno se fue jamás.")
        if (not HasInt(game, "libro_secuencia")) {
          game.libro_secuencia = 0
        }
        if (game.libro_secuencia = 0) {
          game.libro_secuencia = 1
          msg ("")
          msg ("Algo hace clic suavemente en la estantería, como un mecanismo antiguo que se activa.")
        } else {
          game.libro_secuencia = 0
          msg ("")
          msg ("Los libros parecen reorganizarse solos en el estante. Oyes un chasquido, como si un mecanismo se reiniciase.")
        }
      ]]></look>
    </object>

    <object name="libro_4">
      <inherit name="editor_object" />
      <alias>Puertas Sin Salida</alias>
      <alt type="simplestringlist">puertas sin salida;libro 4;cuarto libro</alt>
      <look type="script"><![CDATA[
        msg ("'Puertas Sin Salida'. Un ensayo filosófico sobre la naturaleza de los lugares cerrados. Cada capítulo describe una habitación diferente de la que es imposible escapar. El último capítulo se titula 'La Casa' y está en blanco. Todas las páginas, vacías, esperando ser escritas.")
        if (not HasInt(game, "libro_secuencia")) {
          game.libro_secuencia = 0
        }
        if (game.libro_secuencia = 1) {
          game.libro_secuencia = 2
          msg ("")
          msg ("Otro clic en la estantería. Más fuerte esta vez. Algo se está abriendo.")
        } else {
          game.libro_secuencia = 0
          msg ("")
          msg ("Los libros parecen reorganizarse solos en el estante. Oyes un chasquido, como si un mecanismo se reiniciase.")
        }
      ]]></look>
    </object>

    <object name="libro_3">
      <inherit name="editor_object" />
      <alias>Memorias de la Casa</alias>
      <alt type="simplestringlist">memorias de la casa;libro 3;tercer libro</alt>
      <look type="script"><![CDATA[
        if (not HasInt(game, "libro_secuencia")) {
          game.libro_secuencia = 0
        }
        if (game.libro_secuencia = 2) {
          game.libro_secuencia = 3
          msg ("Sacas 'Memorias de la Casa' del estante y notas que es demasiado ligero. Lo abres y descubres por qué: es hueco. Las páginas fueron recortadas para crear un compartimento secreto.")
          msg ("")
          msg ("¡Dentro hay una llave oxidada con una etiqueta que dice 'ÁTICO'!")
          msg ("")
          msg ("Tomas la llave. Tus manos tiemblan.")
          game.llave_atico_encontrada = true
          game.tiene_llave_atico = true
          exit_atico.locked = false
        } else if (game.llave_atico_encontrada) {
          msg ("'Memorias de la Casa'. El libro hueco donde encontraste la llave del ático. El compartimento vacío te mira como una boca abierta.")
        } else {
          game.libro_secuencia = 0
          msg ("'Memorias de la Casa'. Intentas abrirlo pero las páginas parecen pegadas entre sí. No puedes leerlo. El libro vibra ligeramente en tus manos, como si contuviera algo vivo.")
          msg ("")
          msg ("Los libros parecen reorganizarse solos en el estante. Oyes un chasquido, como si un mecanismo se reiniciase.")
        }
      ]]></look>
    </object>

    <object name="libro_2">
      <inherit name="editor_object" />
      <alias>El Huésped Eterno</alias>
      <alt type="simplestringlist">huesped eterno;libro 2;segundo libro</alt>
      <look type="script"><![CDATA[
        msg ("'El Huésped Eterno'. Una novela sobre un viajero que llega a una posada y nunca puede marcharse. Cada vez que intenta irse, el camino lo devuelve al punto de partida. Con cada intento, la posada cambia, se vuelve más oscura, más hambrienta. El viajero termina por amar su prisión.")
        if (not HasInt(game, "libro_secuencia")) {
          game.libro_secuencia = 0
        }
        if (game.libro_secuencia = 3) {
          game.libro_secuencia = 4
          msg ("")
          msg ("El argumento de este libro te resulta dolorosamente familiar.")
        } else if (game.libro_secuencia < 3) {
          game.libro_secuencia = 0
          msg ("")
          msg ("Los libros parecen reorganizarse solos en el estante. Oyes un chasquido, como si un mecanismo se reiniciase.")
        }
      ]]></look>
    </object>

    <object name="libro_1">
      <inherit name="editor_object" />
      <alias>Crónicas de Valle Quieto</alias>
      <alt type="simplestringlist">cronicas de valle quieto;libro 1;primer libro</alt>
      <look type="script"><![CDATA[
        msg ("'Crónicas de Valle Quieto'. Una historia del pueblo escrita en un estilo seco y académico. Fundado en 1742. Prosperó con la minería. Decayó misteriosamente a finales del siglo XIX cuando los habitantes empezaron a desaparecer. El último censo registrado data de 1947: población cero.")
        msg ("")
        msg ("El año 1947 está subrayado tres veces con tinta roja.")
      ]]></look>
    </object>

    <exit alias="sur" to="recepcion">
      <inherit name="southdirection" />
    </exit>
  </object>

  <object name="comedor">
    <inherit name="editor_room" />
    <alias>Comedor</alias>
    <description type="script"><![CDATA[
      if (game.horror < 4) {
        msg ("Un comedor elegante con una mesa larga de caoba preparada para seis comensales. Manteles de lino blanco, cubiertos de plata, copas de cristal tallado. Un candelabro de cristal pende del techo alto, proyectando arcoíris diminutos en las paredes. En una esquina, un reloj de péndulo marca el tiempo con un tictac rítmico y reconfortante. El ambiente es cálido, como si una cena estuviese a punto de comenzar.")
      } else if (game.horror < 7) {
        msg ("El comedor mantiene su elegancia, pero hay detalles que perturban. La mesa está puesta para seis pero nunca has visto más de tres personas en la casa. Los cubiertos de plata están siempre relucientes, como si alguien los puliera cada hora. El candelabro tintinea suavemente sin que haya corriente de aire. El reloj de péndulo a veces da la hora incorrecta, un minuto de más, una hora de menos.")
      } else if (game.horror < 10) {
        msg ("La mesa del comedor está puesta para seis. Siempre seis. Pero ahora los platos tienen restos de comida que nadie recuerda haber servido. Los cubiertos de plata están empañados, como si manos invisibles los usasen cuando no miras. El candelabro proyecta sombras que no corresponden con ningún objeto de la habitación. El reloj de péndulo muestra horas imposibles: las 25:61, las 13:87.")
      } else {
        msg ("El comedor huele a comida podrida y cera derretida. La mesa está puesta para seis, pero en cada plato hay restos irreconocibles de algo orgánico que no quieres identificar. Los cubiertos de plata están manchados de algo oscuro. El candelabro gira lentamente sobre su eje, aunque no hay viento ni mecanismo visible. Y el reloj de péndulo...")
        msg ("")
        msg ("El reloj marca tu hora. La hora exacta. Y debajo de las manecillas, en la esfera, alguien ha grabado: '...es la hora. Tu hora.'")
      }
    ]]></description>

    <object name="mesa_comedor">
      <inherit name="editor_object" />
      <alias>mesa del comedor</alias>
      <look type="script"><![CDATA[
        msg ("Una mesa larga de caoba barnizada, con capacidad para seis comensales. Está perfectamente puesta con manteles de lino, servilletas dobladas en forma de lirio, cubiertos de plata alineados con precisión milimétrica. Seis sillas de respaldo alto, tapizadas en terciopelo verde oscuro, esperan a sus ocupantes.")
        msg ("")
        msg ("Debajo de la mesa, en la cara inferior del tablero, hay algo tallado en la madera.")
      ]]></look>
    </object>

    <object name="debajo_mesa">
      <inherit name="editor_object" />
      <alias>debajo de la mesa</alias>
      <alt type="simplestringlist">cara inferior de la mesa;tallado en la mesa;bajo la mesa</alt>
      <look type="script"><![CDATA[
        msg ("Te agachas y miras la cara inferior de la mesa. En la madera, alguien ha tallado con un cuchillo un número con trazo tembloroso:")
        msg ("")
        msg ("  1")
        msg ("")
        msg ("Solo un uno. ¿El primer dígito de algo? Hay marcas de más intentos de tallar algo, pero la madera está demasiado dura y los cortes son superficiales e ilegibles.")
        game.digito_1_encontrado = true
      ]]></look>
    </object>

    <object name="reloj_comedor">
      <inherit name="editor_object" />
      <alias>reloj de péndulo</alias>
      <alt type="simplestringlist">reloj;pendulo</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Un majestuoso reloj de péndulo con caja de caoba y esfera de porcelana esmaltada. Los números romanos están pintados en oro y las manecillas son de hierro forjado. El péndulo oscila con una regularidad hipnótica, y cada hora el reloj emite un sonido grave y profundo que resuena en toda la planta baja.")
        } else if (game.horror < 10) {
          msg ("El reloj de péndulo marca las 25:61. Eso no es posible. Miras de nuevo: ahora marca las 13:87. Parpadeas: 00:00. Los números cambian cada vez que apartas la vista y vuelves a mirar. El péndulo oscila, pero a un ritmo irregular, acelerando y frenando como el latido de un corazón enfermo.")
        } else {
          game.reloj_easter_visto = true
          msg ("El reloj de péndulo ha dejado de jugar. Ahora muestra la hora exacta, al segundo. No debería poder hacer eso; es un reloj mecánico del siglo XIX. Y en la esfera, grabado con una caligrafía fina como un cabello, dice:")
          msg ("")
          msg ("  '...es la hora. Tu hora.'")
          msg ("")
          msg ("El péndulo se detiene un instante. Luego sigue. Marca el tiempo que te queda.")
          if (not GetBoolean(game, "easter_reloj_comedor")) {
            game.easter_reloj_comedor = true
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
        }
      ]]></look>
    </object>

    <object name="candelabro">
      <inherit name="editor_object" />
      <alias>candelabro</alias>
      <look type="script"><![CDATA[
        msg ("Un candelabro de cristal tallado que pende del techo por una cadena de bronce. Decenas de prismas de cristal atrapan la luz y la descomponen en arcoíris diminutos que danzan en las paredes y el techo. Es una pieza hermosa, probablemente del siglo XVIII.")
        if (game.horror >= 7) {
          msg ("")
          msg ("Los arcoíris se mueven siguiendo un patrón. No es aleatorio. Si los sigues con la vista, deletrean letras en las paredes. Pero las letras se disuelven antes de que puedas leerlas, como palabras escritas en agua.")
        }
      ]]></look>
    </object>

    <object name="cubiertos">
      <inherit name="editor_object" />
      <alias>cubiertos</alias>
      <look type="script"><![CDATA[
        msg ("Cubiertos de plata maciza con el monograma 'NM' grabado en cada pieza. Nicanor Molinare. Están perfectamente alineados junto a cada plato: tenedor a la izquierda, cuchillo y cuchara a la derecha. Cuando los tocas, están fríos. Muy fríos. Como si hubiesen estado guardados en hielo.")
        if (game.horror >= 10) {
          msg ("")
          msg ("Uno de los cuchillos tiene algo en la hoja. Lo miras de cerca. Es un reflejo, pero no el tuyo. El rostro en la plata es el de alguien que se parece a ti pero más viejo, más delgado, con los ojos hundidos y una expresión de resignación absoluta.")
        }
      ]]></look>
    </object>

    <exit alias="oeste" to="recepcion">
      <inherit name="westdirection" />
    </exit>
    <exit alias="este" to="cocina">
      <inherit name="eastdirection" />
    </exit>
  </object>

  <object name="cocina">
    <inherit name="editor_room" />
    <alias>Cocina</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Una cocina amplia y rústica que huele a estofado y hierbas frescas. Ollas de cobre cuelgan de ganchos en la pared, brillando como soles pequeños. Un fogón de leña grande ocupa una esquina, con una olla de hierro que burbujea perpetuamente. Manojos de hierbas aromáticas cuelgan del techo secándose al calor. Estantes con tarros de conservas y especias cubren las paredes. Es el corazón cálido de la casa, el lugar donde Doña Carmen ejerce su dominio.")
      } else if (game.horror < 14) {
        msg ("La cocina mantiene su aspecto pero los detalles se han torcido. Las ollas de cobre están manchadas de algo que no es comida. El fogón arde con una llama constante que nadie alimenta. Las hierbas colgantes están secas y quebradizas, de un color pardo enfermizo. El estofado burbujea como siempre, pero el líquido es más espeso, más oscuro, y contiene trozos de algo que prefieres no identificar. Los tarros de la despensa tienen etiquetas que empiezan a revelar cosas perturbadoras.")
      } else {
        msg ("La cocina es una carnicería disfrazada. Las ollas de cobre están oxidadas y grasientas. El fogón vomita un calor sofocante y antinatural. Las hierbas del techo son restos secos de algo que no es vegetal. El estofado burbujea con violencia, salpicando gotas oscuras que se mueven solas por la superficie del fogón. Y los tarros de la despensa... los tarros tienen nombres. Nombres de personas. Nombres de huéspedes anteriores. Uno de ellos tiene tu nombre, esperando ser llenado.")
      }
    ]]></description>

    <object name="fogon">
      <inherit name="editor_object" />
      <alias>fogón</alias>
      <alt type="simplestringlist">estufa;cocina de leña;horno</alt>
      <look type="script"><![CDATA[
        msg ("Un fogón de hierro fundido grande y pesado, de los que se usaban en las cocinas señoriales del siglo pasado. El fuego arde bajo la olla con una constancia sobrenatural. No recuerdas haber visto a nadie añadir leña, y sin embargo las llamas nunca menguan.")
        if (game.horror >= 7) {
          msg ("")
          msg ("El estofado burbujea con un sonido que se parece demasiado a una voz murmurando. Si acercas el oído, casi puedes distinguir palabras entre los borboteos. Palabras en un idioma que no reconoces pero que, de algún modo, entiendes: 'Más. Necesito más.'")
        }
      ]]></look>
    </object>

    <object name="vela_cocina">
      <inherit name="editor_object" />
      <alias>vela</alias>
      <take type="script"><![CDATA[
        if (game.carmen_ofrecio_vela) {
          msg ("Tomas la vela del estante. Su llama arde firme e inmóvil, completamente indiferente al movimiento. No titila, no parpadea, no se inclina. Es como si la llama estuviese pintada en el aire.")
          game.tiene_vela = true
          MoveObject (this, player)
        } else {
          msg ("No ves ninguna vela por aquí. Quizás debas hablar con Carmen primero.")
        }
      ]]></take>
      <look type="script"><![CDATA[
        if (game.carmen_ofrecio_vela) {
          msg ("Una vela gruesa de cera amarillenta, ya encendida. Su llama es extrañamente estable, como si estuviese protegida por un cristal invisible. Doña Carmen la dejó aquí para ti.")
        } else {
          msg ("No ves nada especial.")
        }
      ]]></look>
      <scenery />
    </object>

    <object name="hierbas">
      <inherit name="editor_object" />
      <alias>hierbas</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Manojos de romero, tomillo, laurel y salvia cuelgan del techo, secándose lentamente al calor del fogón. Su aroma es intenso y reconfortante, mezclándose con el olor del estofado en una sinfonía olfativa que te hace sentir hambre.")
        } else if (game.horror < 14) {
          msg ("Las hierbas colgantes están más secas y oscuras de lo normal. Algunas no las reconoces: tienen hojas de formas extrañas, con venas púrpuras y un olor amargo que recuerda a la tierra mojada de un cementerio. ¿Qué clase de recetas usa Doña Carmen?")
        } else {
          msg ("Lo que cuelga del techo no son hierbas. Son mechones. Mechones de cabello de diferentes colores y texturas, atados con cordel y colgados a secar como si fuesen romero o tomillo. Decenas de ellos. Algunos son muy antiguos; otros parecen recientes.")
        }
      ]]></look>
    </object>

    <object name="despensa">
      <inherit name="editor_object" />
      <alias>despensa</alias>
      <alt type="simplestringlist">tarros;conservas</alt>
      <look type="script"><![CDATA[
        msg ("Estantes llenos de tarros de cristal con conservas, encurtidos y sustancias de colores diversos. Algunos tarros tienen etiquetas escritas a mano con letra apretada.")
        if (game.horror < 7) {
          msg ("")
          msg ("Las etiquetas dicen cosas normales: 'Mermelada de mora', 'Pepinillos en vinagre', 'Tomate frito'. Todo parece casero y bien conservado.")
        } else {
          msg ("")
          msg ("Las etiquetas de algunos tarros son inquietantes. 'Esencia de M.B.', 'Extracto de E.V.', 'Reducción de R.H.'. Iniciales. Iniciales que coinciden con nombres del libro de registro.")
          msg ("")
          msg ("Un frasco en particular llama tu atención. Su etiqueta dice: 'Esencia - 4'. El número cuatro está escrito con tinta roja.")
          game.digito_3_encontrado = true
        }
        if (game.frasco_disponible) {
          msg ("")
          msg ("Al fondo de la despensa hay un frasco nuevo que no estaba antes. Su etiqueta dice: 'Para " + game.nombre_jugador + ". Beber en caso de necesidad.'")
        }
      ]]></look>
    </object>

    <object name="frasco_jugador">
      <inherit name="editor_object" />
      <alias>frasco con tu nombre</alias>
      <alt type="simplestringlist">frasco;tu frasco</alt>
      <scenery />
      <take type="script"><![CDATA[
        if (not game.frasco_disponible) {
          msg ("No ves ningún frasco con tu nombre.")
        } else {
          msg ("Tomas el frasco. El líquido dentro es espeso y oscuro, del color del vino añejo. Está tibio al tacto, como si tuviese su propia temperatura.")
          MoveObject (this, player)
        }
      ]]></take>
      <look type="script"><![CDATA[
        msg ("Un frasco de cristal grueso con un líquido oscuro y viscoso. La etiqueta dice 'Para " + game.nombre_jugador + ". Beber en caso de necesidad.' El líquido se mueve lentamente dentro del frasco, incluso cuando lo mantienes quieto, como si tuviese voluntad propia.")
      ]]></look>
      <use type="script"><![CDATA[
        if (not game.bebio_frasco) {
          msg ("Te llevas el frasco a los labios y bebes. El líquido es denso y cálido, con un sabor que no puedes identificar: dulce y amargo a la vez, como miel mezclada con ceniza. Una oleada de calor te recorre el cuerpo desde el estómago hasta las puntas de los dedos.")
          msg ("")
          msg ("Te sientes... fuerte. Más presente. Como si tu cuerpo pesara más, como si estuvieses más anclado a la realidad. La sensación es reconfortante y aterradora al mismo tiempo.")
          game.bebio_frasco = true
        } else {
          msg ("El frasco está vacío. Lo agitas pero no queda ni una gota.")
        }
      ]]></use>
    </object>

    <object name="cuchillos">
      <inherit name="editor_object" />
      <alias>cuchillos</alias>
      <look type="script"><![CDATA[
        msg ("Un soporte magnético en la pared sostiene seis cuchillos de diferentes tamaños, desde un pequeño cuchillo de pelar hasta un imponente cuchillo de carnicero. Todos están afilados hasta lo imposible; podrías afeitarte con cualquiera de ellos. Las hojas brillan con un fulgor que no corresponde a su evidente antigüedad.")
        if (game.horror >= 10) {
          msg ("")
          msg ("El cuchillo más grande tiene manchas oscuras incrustadas en la junta entre la hoja y el mango. Manchas que no saldrían con ningún lavado.")
        }
      ]]></look>
      <take type="script"><![CDATA[
        msg ("Extiendes la mano hacia los cuchillos pero algo te detiene. No es miedo exactamente, es más como si tus músculos se negasen a obedecer. Tus dedos se quedan a centímetros de la hoja, temblando. Una voz en tu cabeza, que no es la tuya, susurra: 'Todavía no.'")
      ]]></take>
    </object>

    <exit alias="oeste" to="comedor">
      <inherit name="westdirection" />
    </exit>
    <exit alias="norte" to="pasillo_servicio">
      <inherit name="northdirection" />
    </exit>
  </object>

  <object name="bano_visitas">
    <inherit name="editor_room" />
    <alias>Baño de Visitas</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Un baño pequeño pero limpio, con azulejos blancos que brillan bajo la luz de una bombilla desnuda. Un lavabo de porcelana con grifos de bronce, un inodoro discreto en un rincón, y sobre el lavabo, un espejo ovalado con marco de plata deslustrada. Una pastilla de jabón artesanal descansa en una jabonera de cerámica. Todo huele a limpio, a lavanda y a algo ligeramente medicinal.")
      } else if (game.horror < 13) {
        msg ("El baño de visitas ha perdido su aspecto inmaculado. Los azulejos blancos tienen grietas finas como telarañas, y entre las juntas crece algo oscuro que no es moho. El agua del grifo sale con un tinte rosado apenas perceptible. La bombilla parpadea con un ritmo que recuerda a un código morse. Y el espejo... el espejo te espera. Siempre te está esperando.")
      } else {
        msg ("Los azulejos están agrietados y manchados de algo que parece óxido pero no lo es. El agua sale del grifo sin que nadie lo abra, goteando con un ritmo constante como un reloj orgánico. Las manchas entre las juntas forman patrones, letras, nombres de personas que estuvieron aquí antes que tú. Y el espejo sobre el lavabo brilla con una luz propia que no tiene origen. Tu reflejo te devuelve la mirada con una expresión que no es exactamente la tuya.")
      }
    ]]></description>

    <object name="espejo_visitas">
      <inherit name="editor_object" />
      <alias>espejo</alias>
      <look type="script"><![CDATA[
        if (not HasInt(game, "veces_espejo_visitas")) {
          game.veces_espejo_visitas = 0
        }
        game.veces_espejo_visitas = game.veces_espejo_visitas + 1
        if (game.veces_espejo_visitas = 1) {
          msg ("Te miras en el espejo ovalado. Tu reflejo te devuelve la mirada con normalidad. Pareces cansado, con ojeras que no recuerdas tener. El marco de plata está deslustrado por el tiempo, con pequeños grabados de hojas y flores.")
        } else if (game.veces_espejo_visitas = 2) {
          msg ("Vuelves a mirarte en el espejo. Tu reflejo tarda una fracción de segundo en imitarte. Probablemente fue tu imaginación. Pero tus ojeras son más profundas que la última vez, ¿no?")
        } else if (game.veces_espejo_visitas = 3) {
          msg ("El espejo de nuevo. Tu reflejo se mueve contigo, pero hay algo raro. La habitación reflejada no es exactamente igual a la real. Hay una puerta detrás de ti en el reflejo que no existe en la realidad. Miras atrás. No hay puerta. Miras el espejo. Ahí está.")
        } else if (game.veces_espejo_visitas = 4) {
          msg ("Miras el espejo otra vez. Tu reflejo tiene las pupilas demasiado grandes, demasiado oscuras. La puerta que solo existe en el reflejo está entreabierta ahora. Algo se mueve detrás de ella. No quieres saber qué es. Pero miras igual.")
        } else if (game.veces_espejo_visitas = 5) {
          msg ("Te acercas al espejo por quinta vez. Tu reflejo...")
          msg ("")
          msg ("Tu reflejo sonríe.")
          msg ("")
          msg ("Tú no estás sonriendo.")
          msg ("")
          msg ("Tu reflejo levanta una mano y te saluda lentamente. Tus manos están inmóviles a tus costados. La puerta en el reflejo está completamente abierta y la oscuridad detrás de ella se derrama como tinta. Tu reflejo sigue sonriendo, con una expresión de una ternura obscena, y articula en silencio una palabra que lees en sus labios: 'Bienvenido.'")
          if (not GetBoolean(game, "easter_espejo_encontrado")) {
            game.easter_espejo_encontrado = true
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
            IncrementarHorror (2)
          }
        } else {
          msg ("Tu reflejo en el espejo te mira con esa sonrisa que no es tuya. Cada vez que miras, la puerta del reflejo está más abierta, la oscuridad más cerca. Tu reflejo articula algo diferente cada vez, pero siempre sin sonido. Hoy dice: 'Pronto.'")
        }
      ]]></look>
    </object>

    <object name="lavabo_visitas">
      <inherit name="editor_object" />
      <alias>lavabo</alias>
      <look type="script"><![CDATA[
        msg ("Un lavabo de porcelana blanca con grifos de bronce en forma de cabezas de cisne. La porcelana está fría al tacto, como si nunca hubiese conocido el agua caliente. Abres el grifo y sale agua cristalina que no tiene temperatura: ni fría ni caliente. Ausente de sensación térmica, como si fuese un líquido de otro mundo.")
        if (game.horror >= 7) {
          msg ("")
          msg ("El agua tiene un tinte rosado que aparece y desaparece. Cuando la dejas correr un rato, el desagüe emite un sonido grave, como un suspiro largo y profundo que viene desde muy abajo.")
        }
      ]]></look>
    </object>

    <object name="azulejos">
      <inherit name="editor_object" />
      <alias>azulejos</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Azulejos blancos cuadrados, limpios y brillantes. Cubren las paredes hasta media altura, sobre un zócalo de madera pintada. Las juntas están perfectamente selladas y blanqueadas. Todo está impecable, casi obsesivamente limpio.")
        } else {
          msg ("Los azulejos blancos tienen grietas finas que forman patrones. Al principio parecen aleatorios, pero si te fijas, las grietas trazan letras. Manchas entre las juntas que no son moho forman palabras: 'AYÚDAME', 'ESTOY AQUÍ', 'NO ME OLVIDES'. Escritas con algo que se parece a la sangre seca pero que prefieres creer que es óxido.")
        }
      ]]></look>
    </object>

    <exit alias="este" to="recepcion">
      <inherit name="eastdirection" />
    </exit>
  </object>

  <object name="pasillo_servicio">
    <inherit name="editor_room" />
    <alias>Pasillo de Servicio</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Un pasillo estrecho y bajo, diseñado para que la servidumbre se moviera entre la cocina y las dependencias de servicio sin ser vista por los huéspedes. El techo está tan bajo que casi lo rozas con la cabeza. Las paredes son de yeso encalado, sin decoración alguna. Una única bombilla desnuda proporciona una luz amarillenta y débil. El suelo de baldosas de barro cruje bajo tus pies con cada paso.")
      } else if (game.horror < 14) {
        msg ("El pasillo de servicio parece más largo que la última vez. El techo está más bajo, estás seguro. Tienes que agachar la cabeza para avanzar. La bombilla parpadea con un ritmo errático y las sombras saltan en las paredes como animales asustados. Las tuberías expuestas a lo largo del techo vibran y emiten un zumbido grave que sientes en los dientes. El aire huele a cerrado, a encierro, a algo vivo atrapado entre las paredes.")
      } else {
        msg ("El pasillo se ha convertido en una garganta. Las paredes se estrechan, el techo desciende, y tienes que caminar encorvado con los hombros rozando el yeso. La bombilla está fundida pero aún emite un resplandor enfermizo, como el brillo de un ojo inyectado en sangre. Las tuberías no solo vibran: respiran. Se contraen y expanden rítmicamente, como venas de un organismo gigante. Y detrás de las paredes, claramente audible, alguien respira contigo. Inspira cuando inspiras. Exhala cuando exhalas.")
      }
    ]]></description>

    <object name="tuberias">
      <inherit name="editor_object" />
      <alias>tuberías</alias>
      <look type="script"><![CDATA[
        msg ("Tuberías de hierro y cobre corren a lo largo del techo, expuestas y sin aislar. Algunas están oxidadas y gotean un líquido parduzco en intervalos irregulares. De cuando en cuando vibran violentamente, como si algo se moviera dentro de ellas a gran velocidad.")
        if (game.horror >= 10) {
          msg ("")
          msg ("Apoyas la oreja contra una tubería. Escuchas un fluido moverse dentro, pero no suena como agua. Suena como algo más espeso, más viscoso. Y entre el gorgoteo, algo que se parece a un susurro: tu nombre, repetido una y otra vez, arrastrado por la corriente invisible.")
        }
      ]]></look>
    </object>

    <object name="puerta_servicio">
      <inherit name="editor_object" />
      <alias>puerta de servicio</alias>
      <look type="script"><![CDATA[
        msg ("Una puerta vieja pintada del mismo color que la pared, diseñada para ser invisible. Capas de pintura la han sellado a su marco hasta hacerla parte de la pared misma. No hay pomo visible, solo la silueta de donde estuvo uno. Sea adonde sea que conducía, hace mucho que dejó de ser una opción.")
        if (game.horror >= 7) {
          msg ("")
          msg ("Detrás de la puerta sellada, algo golpea. Tres golpes secos, rítmicos. Luego silencio. Luego tres golpes más. Como si alguien al otro lado estuviera contando los minutos con nudillos pacientes.")
        }
      ]]></look>
    </object>

    <object name="bombilla">
      <inherit name="editor_object" />
      <alias>bombilla</alias>
      <look type="script"><![CDATA[
        msg ("Una bombilla incandescente desnuda, sin pantalla ni protección, que cuelga de un cable retorcido. Su luz es débil y amarillenta, más sombra que iluminación. El cristal está ennegrecido por el calor y el tiempo. Zumba ligeramente, un ruido constante y casi subliminal que se mete en tu cabeza.")
        if (game.horror >= 7) {
          msg ("")
          msg ("La bombilla parpadea siguiendo un patrón. Largo, corto, corto. Largo. Corto, largo. Morse. Si supieses morse, entenderías el mensaje. Quizá es mejor no saberlo.")
        }
      ]]></look>
    </object>

    <exit alias="sur" to="cocina">
      <inherit name="southdirection" />
    </exit>
    <exit alias="norte" to="lavadero">
      <inherit name="northdirection" />
    </exit>
  </object>

  <object name="lavadero">
    <inherit name="editor_room" />
    <alias>Lavadero</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Una habitación amplia y húmeda que sirve como lavadero. Grandes pilas de piedra alineadas contra una pared, cuerdas de tender cruzando el techo de lado a lado, y un suelo de baldosas irregulares cubierto parcialmente por una alfombra vieja y descolorida. El aire está cargado de humedad y huele a jabón de sosa y lejía. Prendas diversas cuelgan de las cuerdas, secándose con una lentitud perezosa.")
      } else if (game.horror < 10) {
        msg ("El lavadero está más oscuro y húmedo de lo que debería. Las pilas de piedra tienen manchas que no quieren salir con ningún restregado. Las cuerdas de tender están cargadas de ropa que no reconoces: prendas de estilos de diferentes décadas, camisas de cuello alto, faldas de volantes, pantalones de pana. Toda la ropa está limpia pero tiene un olor dulzón, como flores marchitas. La alfombra del suelo está arrugada en una esquina, como si alguien la hubiese movido recientemente.")
      } else {
        msg ("El lavadero es una cámara de humedad sofocante. Las pilas de piedra están agrietadas y el agua estancada en ellas es de un color oscuro e indefinible. La ropa en las cuerdas es de todas las épocas: camisas victorianas junto a blusas de los años sesenta, mandiles del siglo XIX junto a camisetas modernas. Algunas prendas son de talla infantil y están manchadas de algo oscuro que no es barro. La alfombra del suelo está completamente apartada, revelando las baldosas y... algo más.")
      }
    ]]></description>

    <object name="lavabos_lavadero">
      <inherit name="editor_object" />
      <alias>pilas de piedra</alias>
      <alt type="simplestringlist">lavabos;pilas;piletas</alt>
      <look type="script"><![CDATA[
        msg ("Grandes pilas de piedra tallada, del tipo que se usaban para lavar la ropa a mano. El fondo está desgastado por décadas de restregado. Una de las pilas tiene agua estancada, gris y opaca, con una película iridiscente en la superficie, como gasolina derramada.")
        if (game.horror >= 10) {
          msg ("")
          msg ("Metes la mano en el agua estancada. Está tibia. Tus dedos tocan algo en el fondo: algo suave, esponjoso, orgánico. Lo sacas. Es un trozo de tela empapada. Cuando lo despliegas, ves que es una etiqueta de ropa con un nombre bordado: el tuyo.")
        }
      ]]></look>
    </object>

    <object name="ropa_tendida">
      <inherit name="editor_object" />
      <alias>ropa tendida</alias>
      <alt type="simplestringlist">ropa;prendas</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Sábanas blancas, toallas, algunas prendas de vestir. Todo colgado con pinzas de madera, secándose al aire húmedo del lavadero. La ropa parece limpia y bien cuidada.")
        } else if (game.horror < 10) {
          msg ("La ropa es de diferentes épocas. Camisas con cuello de pajarita junto a jerseys modernos. Faldas de vuelo de los años cincuenta junto a vaqueros desgastados. ¿De quién es toda esta ropa? No puede ser de los mismos dueños.")
        } else {
          msg ("La ropa cuelga inmóvil como ahorcados en una horca invisible. Hay prendas de todas las épocas y tallas, incluidas varias de niño pequeño. Algunas están manchadas de un marrón oscuro que no es chocolate ni barro ni óxido. Una de las prendas es exactamente igual a la que llevas puesta ahora. Misma talla, misma marca, mismos desgastes en los mismos sitios.")
        }
      ]]></look>
    </object>

    <object name="alfombra_lavadero">
      <inherit name="editor_object" />
      <alias>alfombra</alias>
      <look type="script"><![CDATA[
        if (not GetBoolean(game, "trampilla_revelada")) {
          msg ("Una alfombra vieja y descolorida que cubre parte del suelo del lavadero. Sus bordes están deshilachados y sus colores, que algún día fueron rojos y dorados, ahora son parduzcos y tristes. Parece fuera de lugar aquí, como si alguien la hubiese puesto para cubrir algo.")
          msg ("")
          msg ("Agarras una esquina y tiras. La alfombra se desliza revelando lo que escondía: una trampilla de madera reforzada con herrajes de hierro, empotrada en el suelo. Un candado de combinación de cuatro dígitos la mantiene cerrada.")
          msg ("")
          msg ("Una trampilla secreta. ¿Adónde conduce?")
          game.trampilla_revelada = true
        } else {
          msg ("La alfombra está arrugada en un rincón, donde la dejaste cuando descubriste la trampilla.")
        }
      ]]></look>
    </object>

    <object name="trampilla">
      <inherit name="editor_object" />
      <alias>trampilla</alias>
      <alt type="simplestringlist">trampa;puerta del suelo</alt>
      <look type="script"><![CDATA[
        if (not GetBoolean(game, "trampilla_revelada")) {
          msg ("No ves ninguna trampilla. Solo una alfombra vieja que cubre parte del suelo.")
        } else if (game.abrio_sotano) {
          msg ("La trampilla está abierta, revelando una escalera empinada que desciende a la oscuridad. Un aire frío y húmedo sube desde abajo, trayendo consigo un olor a tierra mojada y algo más, algo metálico y antiguo.")
        } else {
          msg ("Una trampilla de madera gruesa reforzada con herrajes de hierro forjado. Un candado de combinación con cuatro ruedas numeradas la mantiene firmemente cerrada. Las ruedas están oxidadas pero funcionales. Necesitas el código correcto para abrirla.")
        }
      ]]></look>
      <use type="script"><![CDATA[
        if (not GetBoolean(game, "trampilla_revelada")) {
          msg ("No ves ninguna trampilla. Solo una alfombra vieja que cubre parte del suelo.")
        } else if (game.abrio_sotano) {
          msg ("La trampilla ya está abierta. La escalera desciende a la oscuridad.")
        } else {
          msg ("El candado tiene cuatro ruedas con dígitos del 0 al 9. ¿Cuál es la combinación?")
          get input {
            if (result = "1947") {
              msg ("")
              msg ("Giras las ruedas con dedos temblorosos: 1... 9... 4... 7. El candado emite un chasquido oxidado y se abre. Retiras el candado y levantas la trampilla. Una bocanada de aire frío y viciado te golpea la cara.")
              msg ("")
              msg ("Una escalera de madera podrida desciende a una oscuridad absoluta. Desde abajo llega un olor a tierra húmeda, a piedra antigua y a algo indefinible que te eriza el vello de los brazos.")
              game.abrio_sotano = true
              exit_sotano.locked = false
              IncrementarHorror (2)
            } else {
              msg ("")
              msg ("Giras las ruedas pero el candado no cede. La combinación es incorrecta. El metal frío parece vibrar burlonamente bajo tus dedos.")
            }
          }
        }
      ]]></use>
    </object>

    <exit alias="sur" to="pasillo_servicio">
      <inherit name="southdirection" />
    </exit>
    <exit name="exit_sotano" alias="bajar" to="escalera_sotano">
      <inherit name="downdirection" />
      <locked />
      <lockedmessage>La trampilla está cerrada con un candado de cuatro dígitos. Necesitas descubrir el código para abrirla.</lockedmessage>
    </exit>
  </object>
  <!-- ============================================================ -->
  <!-- PARTE 3: PRIMER PISO Y NPCs                                 -->
  <!-- ============================================================ -->

  <!-- ==================== PRIMER PISO ==================== -->

  <object name="pasillo_primer_piso">
    <inherit name="editor_room" />
    <alias>Pasillo del Primer Piso</alias>
    <description type="script"><![CDATA[
      if (game.horror < 4) {
        msg ("Un pasillo largo y bien iluminado con puertas a ambos lados. Una alfombra con patrones geométricos en tonos granates y dorados cubre el suelo de madera. Un gran cuadro al óleo domina la pared del fondo, mostrando un paisaje campestre bañado por la luz del atardecer. Las puertas de las habitaciones tienen números de latón, aunque algunos están torcidos o faltan. El papel tapiz tiene un patrón de flores diminutas que se repite con precisión obsesiva.")
      } else if (game.horror < 7) {
        msg ("El pasillo del primer piso se extiende ante ti. La alfombra tiene un patrón que juras que era diferente la última vez que la miraste — los rombos ahora parecen ojos, los triángulos parecen dientes. El cuadro del fondo ha cambiado sutilmente: hay una figura en el paisaje que antes no estaba ahí, pequeña y distante, mirando en tu dirección. Las bombillas parpadean cada pocos segundos, y en esos instantes de oscuridad, el pasillo parece más largo.")
      } else if (game.horror < 10) {
        msg ("El pasillo parece más estrecho que antes. ¿Se movieron las paredes? Las puertas de las habitaciones están más juntas y más lejos a la vez, como si el espacio se doblara sobre sí mismo. La alfombra tiene manchas húmedas que no estaban antes, de un color oscuro que no quieres identificar. El cuadro del fondo muestra una figura que ahora está en primer plano, presionando contra el lienzo desde dentro, con las manos extendidas y la boca abierta en un grito silencioso.")
      } else if (game.horror < 14) {
        msg ("Las p̷a̶r̵e̶d̵e̶s̷ del pasillo respiran. No es una metáfora — se expanden y contraen rítmicamente, como los pulmones de algo enorme. La alfombra se ha hundido en el centro, formando un surco que parece un camino gastado por millones de pasos. El cuadro... ya no es un cuadro. Es una ventana a algún otro lugar, oscuro y vasto, y la figura del otro lado te mira con ojos que reconoces. Son los tuyos.")
      } else {
        msg ("\"¿Sigues explorando, " + game.nombre_jugador + "? Curioso. Los demás dejaron de intentarlo mucho antes.\" El pasillo se tuerce en ángulos que no deberían existir. La alfombra se ha disuelto en algo orgánico y pulsante. Las puertas de las habitaciones aparecen y desaparecen sin lógica. El cuadro ya no está. En su lugar hay un espejo que muestra una versión del pasillo donde tú no existes, donde nunca exististe.")
      }
    ]]></description>

    <object name="cuadro_pasillo">
      <inherit name="editor_object" />
      <alias>cuadro del pasillo</alias>
      <alt type="simplestringlist">cuadro;pintura;painting</alt>
      <look type="script"><![CDATA[
        if (game.horror < 4) {
          msg ("Un hermoso cuadro al óleo que muestra un valle verde bajo una luz dorada de atardecer. Un río serpentea entre colinas suaves. Es una escena pacífica, casi hipnótica. El marco es de madera tallada con motivos florales, oscurecida por los años.")
        } else if (game.horror < 7) {
          msg ("El mismo paisaje, pero hay algo nuevo. Una figura diminuta en la orilla del río, mirando hacia fuera del cuadro. No estaba antes. Estás seguro. El cielo del atardecer tiene un tono más rojizo, casi sangriento.")
        } else if (game.horror < 10) {
          msg ("La figura del cuadro ahora está en primer plano. Es una mujer con un delantal. Sonríe. Tiene los ojos de Carmen. El paisaje detrás de ella se ha oscurecido, y el río ahora es negro y espeso.")
        } else {
          msg ("La figura presiona contra el lienzo desde dentro, deformando la pintura. Sus manos están extendidas hacia ti. Su boca se abre y cierra, y aunque no hay sonido, puedes leer lo que dice: '" + game.nombre_jugador + ". Ayúdame. Ayúdame. Ayúdame.'")
        }
      ]]></look>
      <displayverbs type="simplestringlist">Examinar;Examinar reverso</displayverbs>
    </object>

    <object name="reverso_cuadro">
      <inherit name="editor_object" />
      <alias>reverso del cuadro</alias>
      <alt type="simplestringlist">detrás del cuadro;detras del cuadro;parte trasera del cuadro;examinar reverso</alt>
      <look type="script"><![CDATA[
        msg ("Levantas el cuadro con cuidado y miras detrás. El reverso del lienzo está manchado de humedad y tiene un número grabado con algo afilado, profundamente marcado en la madera del marco:")
        msg ("")
        msg ("    9")
        msg ("")
        msg ("Alguien talló ese número aquí con desesperación. Las marcas son profundas e irregulares, como si lo hubieran hecho con las uñas.")
        if (not GetBoolean(game, "digito_2_encontrado")) {
          SetObjectFlagOn (game, "digito_2_encontrado")
          msg ("")
          msg ("(Segundo dígito del código descubierto: 9)")
        }
      ]]></look>
    </object>

    <object name="alfombra_pasillo">
      <inherit name="editor_object" />
      <alias>alfombra del pasillo</alias>
      <alt type="simplestringlist">alfombra;carpet</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Una alfombra larga con patrones geométricos en tonos granates y dorados. Los diseños son intrincados y simétricos, tejidos con una habilidad que ya no existe. Está ligeramente desgastada en el centro por años de uso.")
        } else {
          msg ("La alfombra parece diferente cada vez que la miras. Los patrones se reorganizan cuando parpadeas. Los colores granates ahora parecen más oscuros — del color exacto de la sangre seca. Hay un bulto debajo de la alfombra que no habías notado antes.")
        }
      ]]></look>
    </object>

    <object name="debajo_alfombra">
      <inherit name="editor_object" />
      <alias>debajo de la alfombra</alias>
      <alt type="simplestringlist">levantar alfombra;mover alfombra;bajo la alfombra;examinar debajo de la alfombra</alt>
      <look type="script"><![CDATA[
        if (game.encontro_pagina_1) {
          msg ("Ya no hay nada más debajo de la alfombra. Solo polvo y tablas de madera oscura.")
        } else {
          msg ("Levantas la esquina de la alfombra. Debajo, entre el polvo y las tablas del suelo, encuentras una hoja de papel doblada. Es una página arrancada de un diario, amarillenta y quebradiza.")
          msg ("")
          msg ("La página dice: 'Día 47: Carmen me ha contado la verdad sobre la casa. Dice que la casa fue construida sobre algo que ya existía aquí. Algo que necesitaba un cuerpo, una estructura. La casa es ese cuerpo. Y nosotros somos su alimento.'")
          game.encontro_pagina_1 = true
          game.paginas_diario = game.paginas_diario + 1
          msg ("")
          msg ("(Página 1 del diario encontrada. " + game.paginas_diario + " de 3 páginas.)")
          if (game.paginas_diario >= 3) {
            game.encontro_diario = true
            msg ("")
            msg ("¡Has reunido las tres páginas del diario! La historia completa de la casa se revela ante ti.")
            IncrementarHorror (4)
          }
        }
      ]]></look>
    </object>

    <object name="puertas_pasillo">
      <inherit name="editor_object" />
      <alias>puertas del pasillo</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Puertas de madera sólida con números de latón. Cada una lleva a la habitación de un huésped. Los números son: 1, 2, 3, 4 y 5. Tu habitación es la número 1.")
        } else {
          msg ("Las puertas ya no tienen números. En su lugar hay marcas — uñas, quemaduras, arañazos. Algunas puertas parecen más nuevas que otras. Algunas parecen no haber existido siempre.")
        }
      ]]></look>
    </object>

    <exit alias="bajar" to="recepcion">
      <inherit name="downdirection" />
    </exit>
    <exit alias="subir" to="escalera_segundo_piso">
      <inherit name="updirection" />
    </exit>
    <exit alias="norte" to="tu_habitacion">
      <inherit name="northdirection" />
    </exit>
    <exit alias="sur" to="habitacion_martin">
      <inherit name="southdirection" />
    </exit>
    <exit alias="este" to="habitacion_lucia">
      <inherit name="eastdirection" />
    </exit>
    <exit alias="oeste" to="habitacion_ramon">
      <inherit name="westdirection" />
    </exit>
    <exit alias="noreste" to="habitacion_sofia">
      <inherit name="northeastdirection" />
    </exit>
    <exit alias="noroeste" to="bano_primer_piso">
      <inherit name="northwestdirection" />
    </exit>
  </object>

  <!-- ==================== TU HABITACIÓN ==================== -->

  <object name="tu_habitacion">
    <inherit name="editor_room" />
    <alias>Tu Habitación</alias>
    <description type="script"><![CDATA[
      if (game.horror < 4) {
        msg ("Una habitación sencilla pero acogedora. Una cama individual con sábanas blancas, una mesita de noche con un cajón, un armario de madera oscura y una ventana que da al jardín. La luz entra tamizada por unas cortinas de encaje amarillento. Huele a limpio, a lavanda, a hogar prestado. Es el tipo de habitación donde uno podría descansar tranquilo. O eso quisieras creer.")
      } else if (game.horror < 7) {
        msg ("Tu habitación. Hay un objeto en la mesita de noche que no recuerdas haber dejado ahí — un vaso de agua que no pediste, lleno hasta el borde. La cama está ligeramente deshecha en el lado que no usas, como si alguien se hubiera sentado ahí mientras dormías. El armario está entreabierto unos centímetros. La ventana muestra un jardín que no se parece al que viste al llegar.")
      } else if (game.horror < 10) {
        msg ("Tu habitación se siente más pequeña. La cama está deshecha aunque la hiciste esta mañana. El armario está abierto de par en par y la ropa que cuelga dentro no es la tuya — es de otra talla, de otra década, con un estilo que nadie ha usado en años. En la mesita de noche hay un diario que se escribe solo. En la pared, con una letra que reconoces como tuya, alguien escribió: 'NO DUERMAS'.")
      } else {
        msg ("Esto ya no es tu habitación. Es la habitación de todos los que vinieron antes, y la de todos los que vendrán después. La cama tiene la forma de un cuerpo hundida en el colchón — tu forma exacta. Las paredes están cubiertas de escritura — tu letra, repitiendo las mismas frases una y otra vez: 'SALIR SALIR SALIR'. El armario está vacío. Tu ropa ha desaparecido. ¿Alguna vez tuviste ropa?")
      }
    ]]></description>

    <object name="cama">
      <inherit name="editor_object" />
      <alias>cama</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Una cama individual con sábanas blancas bien estiradas. La almohada conserva la forma de tu cabeza. Es cómoda, invitante. Pero algo en ella te inquieta — está demasiado perfecta, como si alguien la hiciera minutos antes de que entraras.")
        } else {
          msg ("La cama está deshecha. Las sábanas tienen manchas amarillentas que no estaban antes. La almohada tiene marcas de lágrimas — no las tuyas. O tal vez sí, de una noche que no recuerdas.")
        }
      ]]></look>
    </object>

    <object name="debajo_cama">
      <inherit name="editor_object" />
      <alias>debajo de la cama</alias>
      <alt type="simplestringlist">bajo la cama;examinar debajo de la cama;mirar debajo de la cama</alt>
      <look type="script"><![CDATA[
        if (game.horror < 12) {
          msg ("Polvo, oscuridad, y el silencio de lo que no quieres encontrar. No hay nada debajo de la cama. Todavía.")
        } else {
          msg ("Te agachas y miras debajo de la cama. Hay una caja de cartón cubierta de polvo.")
          msg ("")
          msg ("La abres con manos temblorosas. Dentro hay objetos personales: unas gafas de montura redonda, un reloj de pulsera detenido a las 3:33, y un diario de cuero gastado.")
          msg ("")
          msg ("Todo pertenece a alguien llamado " + game.nombre_jugador + ".")
          msg ("")
          msg ("Abres el diario. La primera entrada dice:")
          msg ("")
          msg ("'Día 1: Llegué a Nicanor Molinare. Doña Carmen es muy amable. La habitación es sencilla pero acogedora. Me ha dado una llave oxidada con el número borrado. Siento que este será un buen descanso.'")
          msg ("")
          msg ("Es EXACTAMENTE tu experiencia. Palabra por palabra. Pero la tinta está seca y amarillenta. Este diario tiene años.")
          msg ("")
          msg ("La última entrada dice: 'Día 847: He dejado de contar. He dejado de buscar la salida. He dejado de ser yo. Si estás leyendo esto, " + game.nombre_jugador + ", no cometas los mismos errores. El sótano miente. Carmen miente. La casa miente. Pero lo peor es que tú también mientes. Porque ya sabes la verdad y sigues aquí.'")
          if (not GetBoolean(game, "caja_cama_easter_egg")) {
            SetObjectFlagOn (game, "caja_cama_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
          IncrementarHorror (2)
        }
      ]]></look>
    </object>

    <object name="mesita_noche">
      <inherit name="editor_object" />
      <alias>mesita de noche</alias>
      <alt type="simplestringlist">mesita;mesa de noche</alt>
      <look type="script"><![CDATA[
        msg ("Una mesita de noche de madera oscura con un cajón. Tiene una lámpara de pantalla amarillenta que proyecta una luz cálida y triste.")
        if (game.horror >= 10 and not game.pilas_disponibles) {
          msg ("")
          msg ("El cajón está ligeramente abierto. Dentro ves algo que antes no estaba: un par de pilas AA. ¿De dónde salieron?")
          game.pilas_disponibles = true
          if (game.tiene_linterna) {
            msg ("")
            msg ("¡Colocas las pilas en la linterna! La luz cobra vida con un zumbido eléctrico.")
            game.linterna_con_pilas = true
          }
        } else if (game.pilas_disponibles) {
          msg ("El cajón está vacío.")
        }
      ]]></look>
    </object>

    <object name="armario">
      <inherit name="editor_object" />
      <alias>armario</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Un armario de madera oscura con una puerta que chirría al abrirse. Dentro cuelga tu ropa, oliendo ligeramente a alcanfor y a años. Hay perchas vacías que esperan más ropa que nunca llegará.")
        } else {
          msg ("Abres el armario. La ropa no es tuya. Es de alguien de tu misma talla exacta, pero de otra década. Camisas con cuellos de otra época, pantalones con un corte que nadie usa desde los años setenta. Y en cada bolsillo que revisas, encuentras lo mismo: una nota escrita con tu letra que dice 'NO ABRAS EL SÓTANO'.")
        }
      ]]></look>
    </object>

    <object name="diario_personal">
      <inherit name="editor_object" />
      <alias>diario personal</alias>
      <alt type="simplestringlist">diario;mi diario</alt>
      <look type="script"><![CDATA[
        if (game.horror < 4) {
          msg ("Un diario en blanco que encontraste en la mesita al llegar. Las páginas están vacías, esperando ser llenadas con las memorias de tu estancia.")
        } else if (game.horror < 7) {
          msg ("El diario tiene entradas que no recuerdas haber escrito. 'Día 2: Carmen hizo estofado. Los otros huéspedes son agradables. Martín escribe todo el día. Lucía es simpática pero no recuerda su apellido. Ramón cuenta marcas en la pared. Sofía juega sola.' La letra es tuya, pero no recuerdas haber escrito esto.")
        } else if (game.horror < 14) {
          msg ("Las entradas del diario ahora incluyen fechas futuras. La de mañana dice: 'Descubrí algo en el sótano. No debí haber bajado. Las paredes tienen oídos y los oídos tienen bocas.' La de pasado mañana simplemente dice: 'Ya es demasiado tarde' escrito cien veces, cada vez más pequeño, hasta que las letras son puntos microscópicos.")
        } else {
          msg ("La última entrada del diario dice: 'No confíes en nadie. Ni siquiera en ti. Especialmente en ti. Porque tú eres la casa y la casa eres tú y nunca hubo diferencia. — " + game.nombre_jugador + " (la versión que recordaba)'")
          msg ("")
          msg ("Debajo, en otra letra que también es la tuya pero más temblorosa:")
          msg ("")
          msg ("'P.D.: Si estás leyendo esto, ya es la cuarta vez. O la quinta. Perdí la cuenta. Cierra el diario. Cierra el juego. Vete.'")
        }
      ]]></look>
    </object>

    <exit alias="sur" to="pasillo_primer_piso">
      <inherit name="southdirection" />
    </exit>
  </object>

  <!-- ==================== HABITACIÓN DE MARTÍN ==================== -->

  <object name="habitacion_martin">
    <inherit name="editor_room" />
    <alias>Habitación de Martín</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("La habitación de Martín es un caos creativo. Pilas de manuscritos cubren cada superficie disponible — la cama, el escritorio, el suelo. Una máquina de escribir antigua ocupa el centro del escritorio como un altar. Papeles arrugados rodean la papelera como ofrendas fallidas. Las paredes tienen notas clavadas con chinchetas: ideas, frases sueltas, esquemas de tramas. Todo huele a tinta, a papel viejo y a café frío. Es la habitación de un hombre obsesionado con contar una historia.")
      } else if (game.horror < 14) {
        msg ("Los manuscritos de Martín se han multiplicado. Las pilas tocan el techo. La máquina de escribir tiene una página a medio escribir que cambia cada vez que miras. Las notas en las paredes ya no son ideas de novela — son observaciones detalladas de ti: tu forma de caminar, las palabras que usas, las habitaciones que visitas primero. Hay un diagrama de toda la casa con tus movimientos trazados en tinta roja.")
      } else {
        msg ("La habitación de Martín ya no es una habitación. Es un archivo. Cada pared está cubierta de texto mecanografiado de suelo a techo. Los manuscritos forman columnas que sostienen el techo como pilares de papel. La máquina de escribir teclea sola, un ritmo constante e incansable, escribiendo tu historia mientras la vives. Cada decisión que tomas aparece en el papel antes de que la tomes. Martín está sentado en la esquina, mirando la máquina con ojos vacíos.")
      }
    ]]></description>

    <object name="manuscritos">
      <inherit name="editor_object" />
      <alias>manuscritos</alias>
      <alt type="simplestringlist">manuscrito;páginas;paginas</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Pilas de páginas mecanografiadas. Lees un fragmento al azar: 'El viajero llegó al pueblo al anochecer, con el polvo del camino cubriéndole los hombros y una sed que no era solo de agua. Buscaba algo que no podía nombrar, algo que había perdido sin saber que lo tenía.' Es una prosa decente, genérica. La novela de un escritor frustrado que busca su voz.")
        } else if (game.horror < 14) {
          msg ("Lees el manuscrito más reciente. Tu sangre se hiela.")
          msg ("")
          msg ("'El huésped examinó los manuscritos con dedos temblorosos. Cada página describía sus acciones con una precisión escalofriante. Su llegada. La conversación con Carmen. La llave oxidada. El diario que se escribía solo. Todo estaba ahí, escrito antes de que sucediera.'")
          msg ("")
          msg ("Estás leyendo una descripción exacta de lo que estás haciendo AHORA MISMO.")
        } else {
          msg ("El último manuscrito está fechado mañana. Describe tu descenso al sótano. Describe lo que encuentras. Describe tu reacción. Describe este momento exacto en el que lees estas palabras y sientes que el suelo se abre bajo tus pies.")
          msg ("")
          msg ("La última línea dice: 'Y entonces " + game.nombre_jugador + " comprendió que la historia no tenía final. Porque el final y el principio eran la misma página.'")
        }
      ]]></look>
    </object>

    <object name="maquina_escribir">
      <inherit name="editor_object" />
      <alias>máquina de escribir</alias>
      <alt type="simplestringlist">maquina de escribir;máquina;maquina;typewriter</alt>
      <look type="script"><![CDATA[
        if (game.horror < 8) {
          msg ("Una máquina de escribir Olivetti de los años cincuenta, negra y pesada como un yunque. Las teclas están gastadas por millones de pulsaciones. Hay una hoja en blanco insertada, esperando. De vez en cuando, una tecla se hunde sola con un clic suave, como si la máquina soñara.")
        } else {
          msg ("Te inclinas para leer la página en la máquina. La tinta aún está húmeda.")
          msg ("")
          msg ("'Y entonces el jugador examinó la máquina de escribir, esperando encontrar algo. Lo encontró. Esto. Estas palabras. Que fueron escritas antes de que tú decidieras venir aquí. Antes de que abrieras el juego. Antes de que eligieras este camino. Cada tecla que presionaste fue predicha. Cada habitación que visitaste fue preparada. No eres un jugador. Eres un personaje que cree ser un jugador. Y esa es la peor clase de prisión.'")
          if (not GetBoolean(game, "maquina_easter_egg")) {
            SetObjectFlagOn (game, "maquina_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
          IncrementarHorror (1)
        }
      ]]></look>
    </object>

    <object name="nota_martin">
      <inherit name="editor_object" />
      <alias>nota de Martín</alias>
      <alt type="simplestringlist">nota;nota martin</alt>
      <look><![CDATA[Una nota escrita a mano con la letra apretada de Martín: "He descubierto algo sobre los libros de la sala de estar. Cinco libros, cinco claves. La verdad se lee de atrás hacia adelante. Empieza por el final, por 'El Último Registro', y retrocede. El tercer libro en orden inverso es el que importa. Está hueco. Dentro hay algo que necesitarás para llegar más arriba. — M."]]></look>
    </object>

    <object name="papeles_arrugados">
      <inherit name="editor_object" />
      <alias>papeles arrugados</alias>
      <look><![CDATA[Borradores descartados esparcidos por el suelo como hojas secas. Cada uno cuenta la misma historia con un final diferente: en uno el viajero escapa, en otro se queda, en otro descubre que nunca existió, en otro destruye la casa. Todos están tachados con una X furiosa. Todos excepto uno, que simplemente dice: "No hay final. Nunca lo hubo."]]></look>
    </object>

    <!-- NPC: MARTÍN -->
    <object name="martin">
      <inherit name="editor_object" />
      <inherit name="namedmale" />
      <alias>Martín</alias>
      <alt type="simplestringlist">escritor;Martin</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Un hombre de unos cuarenta años con ojeras profundas y dedos permanentemente manchados de tinta. Tiene el cabello despeinado y los ojos de alguien que no ha dormido bien en semanas. Viste una camisa arrugada y un chaleco de lana con agujeros. A pesar de todo, su expresión es amable, la de alguien perdido en sus pensamientos pero contento de ser encontrado.")
        } else if (game.horror < 14) {
          msg ("Martín ha envejecido. No es posible que haya envejecido tanto en tan poco tiempo, pero las arrugas son más profundas, el cabello más gris, los ojos más hundidos. Sus dedos se mueven constantemente, como si tecleara sobre una máquina invisible. Murmura frases que reconoces — son descripciones de lo que acabas de hacer.")
        } else {
          msg ("Martín está sentado en la esquina, balanceándose adelante y atrás. Sus ojos están fijos en la máquina de escribir, que teclea sola. Sus labios se mueven al ritmo de las teclas, formando las mismas palabras que aparecen en el papel. Ya no es un escritor. Es un transcriptor. Un médium entre la casa y la página.")
        }
      ]]></look>
      <speak type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Martín levanta la vista de sus papeles y sonríe con cansancio.")
          msg ("")
          msg ("\"¡Ah, perdona! Estaba sumergido en el capítulo doce. ¿O era el trece? Los números se me mezclan aquí.\"")
          msg ("")
          msg ("\"Soy escritor. Bueno, intento serlo. Llevo meses trabajando en esta novela. La casa me da la tranquilidad que necesito para escribir. Sin distracciones, sin ruido, sin... bueno, sin nada, la verdad.\"")
          msg ("")
          msg ("\"Trata sobre un viajero que llega a un lugar remoto buscando inspiración. Irónico, ¿no? Escribir una novela sobre escribir una novela. Mi editor dice que es 'meta'. Yo creo que es desesperación.\"")
          msg ("")
          msg ("\"Los otros huéspedes son agradables. Carmen cocina de maravilla — su estofado es legendario. Ramón tiene historias increíbles de sus viajes. Lucía es joven y optimista, lo cual es refrescante. Y la pequeña Sofía... tiene una imaginación desbordante. A veces me asusta lo que dibuja.\"")
          msg ("")
          msg ("\"Si necesitas algo para leer, en la sala de estar hay una estantería interesante. Cinco libros. Ninguno es lo que parece.\"")
          msg ("")
          msg ("\"Bueno, debo volver al trabajo. Esta novela no se escribirá sola.\" Hace una pausa y frunce el ceño. \"Aunque a veces parece que sí lo hace.\"")
        } else if (game.horror < 14) {
          msg ("Martín te mira con ojos febriles. Tiene círculos oscuros bajo los párpados y un temblor constante en las manos.")
          msg ("")
          msg ("\"La casa me inspira. Las palabras fluyen solas. Nunca he escrito tanto ni tan rápido. Es como si las ideas vinieran de algún lugar debajo del suelo.\"")
          msg ("")
          msg ("\"¿Sabes? He empezado a llamar al personaje principal como tú. " + game.nombre_jugador + ". Espero que no te moleste. Es que... se te parece mucho. Hace las mismas cosas que tú. Va a los mismos lugares. Dice las mismas palabras.\"")
          msg ("")
          msg ("\"A veces la máquina teclea sola por las noches. Las primeras veces pensé que eran ratas sobre las teclas. Pero las ratas no escriben párrafos completos, ¿verdad?\"")
          msg ("")
          msg ("\"El final ya está escrito, ¿sabes? No por mí. Por... alguien. O algo. Solo falta que el personaje lo descubra por sí mismo. Que tú lo descubras.\"")
          msg ("")
          msg ("\"¿Has bajado al sótano? No, no vayas. O sí. No importa. Si está escrito que vayas, irás. Y si está escrito que no, no lo harás. Nada de lo que hagamos importa. Todo ya está en el papel.\"")
          msg ("")
          msg ("Se da la vuelta y sigue tecleando. Pero sus dedos no tocan las teclas — se mueven a centímetros de ellas, y las teclas se hunden solas.")
          game.ayudo_martin = true
        } else {
          msg ("Martín te agarra del brazo antes de que puedas hablar. Sus ojos están inyectados en sangre y su aliento huele a tinta.")
          msg ("")
          msg ("\"Escúchame. No tengo mucho tiempo antes de que me haga escribir otra cosa.\"")
          msg ("")
          msg ("\"No controlo lo que escribo. Nunca lo controlé. Desde el primer día, la máquina escribió por mí. Yo solo pasaba las páginas y firmaba con mi nombre.\"")
          msg ("")
          msg ("\"Todo lo que ha pasado — tu llegada, las notas, el diario, los espejos — ya estaba escrito. Cada palabra. Cada decisión que tomaste fue predicha. Cada 'descubrimiento' fue plantado para que lo encontraras en el momento exacto.\"")
          msg ("")
          msg ("\"¿Quieres saber el final? No. No quieres. Créeme.\"")
          msg ("")
          msg ("Su agarre se afloja. Mira la máquina de escribir con algo parecido al amor, o al terror.")
          msg ("")
          msg ("\"No soy el autor. Nunca lo fui. Solo soy otro personaje. Como tú. Como Carmen. Como todos. La diferencia es que yo lo sé. Y saber es la peor clase de condena.\"")
          msg ("")
          msg ("Vuelve a su escritorio y la máquina comienza a teclear. Esta vez, puedes leer lo que escribe desde donde estás. Dice: '" + game.nombre_jugador + " habló con Martín. Martín le dijo la verdad. Pero la verdad no cambiará nada. Nunca lo hace.'")
          game.ayudo_martin = true
          IncrementarHorror (1)
        }
      ]]></speak>
      <displayverbs type="simplestringlist">Examinar;Hablar</displayverbs>
    </object>

    <exit alias="norte" to="pasillo_primer_piso">
      <inherit name="northdirection" />
    </exit>
  </object>

  <!-- ==================== HABITACIÓN DE LUCÍA ==================== -->

  <object name="habitacion_lucia">
    <inherit name="editor_room" />
    <alias>Habitación de Lucía</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("La habitación de Lucía es casi espartana. Una cama perfectamente hecha, una maleta sin abrir junto a la puerta, y nada más. Ni fotos, ni libros, ni objetos personales. Las paredes están desnudas y las cortinas descorridas dejan entrar una luz que parece demasiado brillante para ser natural. Es la habitación de alguien que no planea quedarse. O de alguien que nunca llegó del todo.")
      } else if (game.horror < 14) {
        msg ("La habitación de Lucía sigue casi vacía, pero ahora esa vacuidad se siente intencional, ominosa. La maleta sigue sin abrir — como si Lucía supiera que no tiene sentido desempacar. La ventana muestra un paisaje diferente cada vez que la miras: a veces un campo, a veces una ciudad, a veces nada. Las paredes tienen marcas tenues, casi invisibles, como si alguien hubiera escrito algo y luego lo hubiera borrado a conciencia.")
      } else {
        msg ("La habitación de Lucía huele a ozono, como después de una tormenta que nunca ocurrió. La maleta se ha abierto sola pero está vacía — completamente vacía, como si nunca hubiera contenido nada. La cama ya no parece una cama sino una camilla. Y Lucía está sentada en el borde, mirando la pared con ojos que ya no son del todo humanos.")
      }
    ]]></description>

    <object name="maleta_lucia">
      <inherit name="editor_object" />
      <alias>maleta de Lucía</alias>
      <alt type="simplestringlist">maleta</alt>
      <look type="script"><![CDATA[
        if (game.horror < 10) {
          msg ("Una maleta de cuero marrón con etiquetas de equipaje en blanco. Nunca se abrió. Los cierres están oxidados como si llevaran años sin moverse, pero Lucía dice que llegó hace unos días. Las etiquetas no tienen nombre, ni destino, ni origen. Como si la maleta hubiera viajado desde la nada hasta la nada.")
        } else {
          msg ("La maleta ahora está abierta. Dentro no hay ropa, ni objetos, ni recuerdos. Solo una nota doblada que dice: 'Las etiquetas ahora muestran nombres de ciudades que no existen: Noquedan, Sinretorno, Yanoestás.' Debajo de la nota, en el forro de la maleta, alguien cosió un nombre con hilo rojo: " + game.nombre_jugador + ".")
        }
      ]]></look>
    </object>

    <object name="cama_lucia">
      <inherit name="editor_object" />
      <alias>cama de Lucía</alias>
      <look><![CDATA[Hecha con una precisión que roza lo obsesivo. Las esquinas de las sábanas forman ángulos perfectos. La almohada no tiene ninguna marca, como si nadie hubiera dormido nunca en ella. Si la tocas, está fría — no la frialdad de las sábanas limpias, sino la frialdad de algo que nunca estuvo vivo.]]></look>
    </object>

    <object name="ventana_lucia">
      <inherit name="editor_object" />
      <alias>ventana de Lucía</alias>
      <alt type="simplestringlist">ventana</alt>
      <look type="script"><![CDATA[
        paisaje = GetRandomInt(1, 4)
        if (paisaje = 1) {
          msg ("La ventana muestra un campo de trigo dorado bajo un cielo azul. Una escena idílica. Pero ayer mostraba una calle de ciudad. Y antes de eso, un océano.")
        } else if (paisaje = 2) {
          msg ("La ventana muestra una calle vacía de una ciudad que no reconoces. Los edificios son altos y grises, sin ventanas. No hay personas. No hay coches. Solo silencio concreto.")
        } else if (paisaje = 3) {
          msg ("La ventana muestra un bosque denso y oscuro. Los árboles están demasiado juntos, como si se empujaran unos contra otros. Entre las ramas, algo brilla — ojos, tal vez, reflejando una luz que no existe.")
        } else {
          msg ("La ventana muestra... nada. Un blanco absoluto. Como si al otro lado del cristal no hubiera mundo. Como si la realidad terminara exactamente en el marco de esta ventana.")
        }
      ]]></look>
    </object>

    <!-- NPC: LUCÍA -->
    <object name="lucia">
      <inherit name="editor_object" />
      <inherit name="namedfemale" />
      <alias>Lucía</alias>
      <alt type="simplestringlist">Lucia;estudiante</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Una joven de unos veintipocos años con el cabello recogido en una coleta desordenada y una sonrisa que parece genuina. Viste ropa de universidad — sudadera demasiado grande, vaqueros desgastados, zapatillas. Tiene esa energía nerviosa de los estudiantes en época de exámenes, pero aquí, lejos de todo, parece relajada. Casi demasiado relajada.")
        } else if (game.horror < 14) {
          msg ("Lucía parece... diluida. Como una fotografía sobreexpuesta. Sus rasgos son los mismos, pero más tenues, más vagos, como si estuviera perdiendo definición. Se queda mirando la pared durante largos períodos, con la boca ligeramente abierta y los ojos desenfocados. Cuando vuelve en sí, sonríe como si nada hubiera pasado.")
        } else {
          msg ("Lucía ya no parece una persona. Parece un recuerdo de una persona. Sus bordes están difuminados, su voz tiene eco como si hablara desde el fondo de un pozo. A veces, por un instante, puedes ver a través de ella — literalmente, como si fuera translúcida.")
        }
      ]]></look>
      <speak type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Lucía te saluda con entusiasmo, agitando la mano como si fuerais viejos amigos.")
          msg ("")
          msg ("\"¡Hola! ¿Eres nuevo? Yo soy Lucía. Estudio en la universidad de...\" Se detiene un segundo. \"Bueno, ya sabes. LA universidad. La grande. Con los edificios.\"")
          msg ("")
          msg ("\"Mis amigos deben estar preguntándose dónde estoy. Les escribiré en cuanto tenga señal. El WiFi aquí es inexistente, ¿te has fijado? Pero bueno, así me concentro en los apuntes.\"")
          msg ("")
          msg ("\"Este pueblo es encantador. Tan tranquilo. Perfecto para estudiar. Carmen es un amor — me recuerda a mi abuela. Siempre tiene galletas o estofado preparado.\"")
          msg ("")
          msg ("\"Solo estaré unos días más. Tengo exámenes la semana que viene. O la siguiente. No recuerdo bien las fechas, pero pronto, seguro.\"")
          msg ("")
          msg ("\"¿Has conocido a Sofía? Es una niña adorable. Dice que sus papás están en el pueblo, pero llevan mucho rato, ¿no? Los niños exageran. Seguro que están bien.\"")
          msg ("")
          msg ("Te regala otra sonrisa brillante. Es contagiosa. Casi logras olvidar que hay algo raro en todo esto.")
        } else if (game.horror < 14) {
          msg ("Lucía te mira con ojos que tardan un segundo de más en enfocarse.")
          msg ("")
          msg ("\"¿Sabes? No recuerdo el nombre de mi universidad. Es raro, ¿verdad? Estuve ahí tres años. O cuatro. O... ¿cuántos años dura una carrera?\"")
          msg ("")
          msg ("\"Mi apellido es...\" Frunce el ceño. Abre la boca. La cierra. \"Es... empezaba por... no importa. Los apellidos son solo etiquetas, ¿no?\"")
          msg ("")
          msg ("\"Esta casa cuida de los suyos,\" dice de repente, con una voz que no es del todo la suya. Luego parpadea. \"Perdona, ¿qué decía? Ah sí, mis exámenes.\"")
          msg ("")
          msg ("Lucía se queda mirando la pared durante un largo momento. Sus ojos están completamente vacíos, como ventanas de una casa abandonada. Su sonrisa se congela en su cara como una máscara de cera.")
          msg ("")
          msg ("Treinta segundos pasan. Un minuto.")
          msg ("")
          msg ("De repente vuelve en sí y sonríe como si nada hubiera pasado.")
          msg ("")
          msg ("\"A veces pierdo el hilo. ¿De qué hablábamos? ¿Cuánto tiempo llevo aquí? ¿Días? ¿Semanas? El tiempo aquí es como gelatina — se deforma cuando lo tocas.\"")
          game.ayudo_lucia = true
        } else {
          msg ("Lucía te habla, pero su voz viene con retraso, como un audio desincronizado con la imagen.")
          msg ("")
          msg ("\"Yo... estaba aquí... antes que tú. Estaré aquí... después.\"")
          msg ("")
          msg ("\"No soy... real. ¿Sabes lo que es un eco? Cuando gritas en una montaña y tu voz vuelve, pero distorsionada, más débil, menos tuya. Yo soy eso. Un eco de alguien que estuvo aquí. De alguien que se fue.\"")
          msg ("")
          msg ("\"O que nunca se fue. No estoy segura. La diferencia entre irse y quedarse es más delgada de lo que crees en esta casa.\"")
          msg ("")
          msg ("\"¿Recuerdas lo primero que dijo Carmen cuando llegaste? Yo sí. Yo recuerdo todo lo que pasa aquí. Porque soy parte de la casa ahora. Soy una de sus voces.\"")
          msg ("")
          msg ("Lucía te mira con una tristeza que es antigua, mucho más antigua que su cara joven.")
          msg ("")
          msg ("\"Bienvenido a Nicanor Molinare,\" dice, con la voz exacta de Carmen. Cada sílaba, cada inflexión, idéntica. \"Esperamos que tu estancia sea... memorable.\"")
          msg ("")
          msg ("Es exactamente lo que Carmen dijo cuando llegaste. Palabra por palabra.")
          game.ayudo_lucia = true
          IncrementarHorror (1)
        }
      ]]></speak>
      <displayverbs type="simplestringlist">Examinar;Hablar</displayverbs>
    </object>

    <exit alias="oeste" to="pasillo_primer_piso">
      <inherit name="westdirection" />
    </exit>
  </object>

  <!-- ==================== HABITACIÓN DE RAMÓN ==================== -->

  <object name="habitacion_ramon">
    <inherit name="editor_room" />
    <alias>Habitación de Ramón</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("La habitación de Ramón es la de un viajero. Una cama simple, una silla de madera junto a la ventana, y paredes con unas cuantas docenas de marcas de conteo hechas con algo afilado. Una maleta abierta y medio deshecha descansa en la esquina. Huele a tabaco de pipa y a cuero viejo. Es la habitación de un hombre que ha vivido mucho y no tiene prisa por dejar de vivir.")
      } else if (game.horror < 14) {
        msg ("Las marcas en las paredes de Ramón cubren cada centímetro disponible. Suelo, paredes, incluso el techo. Son 847 marcas exactas — las contaste. Cada una tallada con precisión obsesiva, cinco verticales cruzadas por una diagonal. 847 amaneceres. Casi dos años y medio. Pero Ramón dice que lleva 'unos días'. La silla de la ventana tiene surcos profundos en los apoyabrazos, tallados por miles de horas de dedos nerviosos.")
      } else {
        msg ("La habitación de Ramón es una celda. Las marcas en las paredes sangran un líquido oscuro y espeso. Algunas son recientes — la sangre aún está fresca. El suelo tiene un surco circular gastado por mil noches de caminar en círculos. La ventana está tapiada con páginas del diario de Martín. Ramón está sentado en su silla, mirando la pared con los ojos de alguien que dejó de esperar hace mucho tiempo.")
      }
    ]]></description>

    <object name="marcas_pared">
      <inherit name="editor_object" />
      <alias>marcas en la pared</alias>
      <alt type="simplestringlist">marcas;conteo;tally</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Marcas de conteo talladas en la pared con algo afilado — una navaja, quizás, o una uña muy persistente. Cuentas unas pocas docenas. Ramón dice que lleva aquí pocos días y que es un hábito de viajero. Parece razonable.")
        } else {
          msg ("Cuentas las marcas con creciente horror. Son exactamente 847. Cubren las cuatro paredes, el marco de la puerta, el cabecero de la cama, las patas de la silla. 847 marcas. 847 amaneceres. Dos años, tres meses y diecisiete días.")
          msg ("")
          msg ("Pero Ramón dice que lleva 'unos días'.")
          msg ("")
          msg ("Las marcas más recientes están hechas con algo que no es una navaja. Son demasiado irregulares, demasiado desesperadas. Están hechas con las uñas.")
        }
      ]]></look>
    </object>

    <object name="marcas_especiales">
      <inherit name="editor_object" />
      <alias>marcas encerradas en circulo</alias>
      <alt type="simplestringlist">marcas en circulo;grupo de marcas;siete marcas;7 marcas;marcas separadas</alt>
      <look type="script"><![CDATA[
        msg ("Entre las cientos de marcas, hay un grupo separado del resto, mas reciente. Son exactamente 7 marcas encerradas en un circulo rojo — el unico color en toda la pared de marcas grises.")
        msg ("")
        msg ("Debajo, Ramon escribio con letra temblorosa: 'Este es el ultimo numero. El cuarto. No me preguntes como lo se.'")
        if (not game.digito_4_encontrado) {
          game.digito_4_encontrado = true
          msg ("")
          msg ("(Cuarto digito del codigo descubierto: 7)")
        }
      ]]></look>
    </object>

    <object name="almohada_ramon">
      <inherit name="editor_object" />
      <alias>almohada de Ramón</alias>
      <alt type="simplestringlist">almohada;debajo de la almohada;bajo la almohada</alt>
      <look type="script"><![CDATA[
        if (game.encontro_pagina_2) {
          msg ("Ya no hay nada más debajo de la almohada de Ramón.")
        } else {
          msg ("Levantas la almohada de Ramón. Debajo hay una página arrancada de un diario, doblada muchas veces y manchada de lo que podría ser sudor o lágrimas.")
          msg ("")
          msg ("La página dice: 'Día 203: La casa no te deja ir. Lo intenté todo. Las ventanas no se rompen. Las puertas llevan al mismo lugar. El pueblo está vacío, siempre vacío. Carmen dice que es temporal, que el camino se abrirá cuando mejore el tiempo. Pero el tiempo nunca mejora. Y cada mañana despierto en la misma cama, y es el mismo día, y Carmen sonríe y dice bienvenido como si fuera la primera vez.'")
          game.encontro_pagina_2 = true
          game.paginas_diario = game.paginas_diario + 1
          msg ("")
          msg ("(Página 2 del diario encontrada. " + game.paginas_diario + " de 3 páginas.)")
          if (game.paginas_diario >= 3) {
            game.encontro_diario = true
            msg ("")
            msg ("¡Has reunido las tres páginas del diario! La historia completa se revela.")
            IncrementarHorror (4)
          }
        }
      ]]></look>
    </object>

    <object name="silla_ramon">
      <inherit name="editor_object" />
      <alias>silla de Ramón</alias>
      <alt type="simplestringlist">silla</alt>
      <look><![CDATA[Una silla de madera junto a la ventana, desgastada hasta el hueso. Los apoyabrazos tienen surcos profundos tallados por miles de horas de dedos nerviosos rascando la madera. Uno de los apoyabrazos tiene letras talladas: "SALIR". Pero la palabra está tachada. Debajo dice: "QUEDARSE". También tachada. Debajo: "OLVIDAR". No está tachada.]]></look>
    </object>

    <!-- NPC: RAMÓN -->
    <object name="ramon">
      <inherit name="editor_object" />
      <inherit name="namedmale" />
      <alias>Ramón</alias>
      <alt type="simplestringlist">Ramon;viejo;el viejo</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Un hombre mayor, de unos setenta años, con una barba blanca bien recortada y ojos azules que han visto mucho mundo. Viste ropa de viajero — pantalones de pana, camisa de franela, botas de cuero gastado. Tiene las manos curtidas de quien ha trabajado bajo muchos soles. Su expresión es serena, la de alguien en paz con el mundo. O eso aparenta.")
        } else if (game.horror < 14) {
          msg ("Ramón parece más viejo que ayer. Las arrugas son más profundas, la barba más larga y descuidada. Sus ojos azules tienen una opacidad que antes no tenían, como si una niebla los cubriera desde dentro. Mueve los dedos constantemente, contando algo invisible. Siempre contando.")
        } else {
          msg ("Ramón es un esqueleto con piel. Sus ojos son pozos de terror antiguo y acumulado. Cuando te mira, ves en ellos 847 amaneceres idénticos, 847 noches de insomnio, 847 intentos de huir que terminaron en la misma cama, en la misma mañana, con la misma sonrisa de Carmen.")
        }
      ]]></look>
      <speak type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Ramón te recibe con una sonrisa cálida y te ofrece sentarte a su lado.")
          msg ("")
          msg ("\"¡Ah, otro huésped! Siéntate, siéntate. ¿Te ha dado Carmen la habitación buena? Todas son buenas, en realidad. Esta casa tiene algo especial.\"")
          msg ("")
          msg ("\"Yo llevo aquí unos días. Esperando a que mejore el tiempo para seguir camino. He viajado por todo el mundo — India, Japón, Argentina, Marruecos. Pero ningún lugar tan tranquilo como este pueblo.\"")
          msg ("")
          msg ("\"Carmen cocina el mejor estofado que he probado en setenta años de vida. Y he probado muchos estofados, créeme. En Estambul hay uno con cordero que se acerca, pero el de Carmen... tiene algo especial. Un ingrediente secreto, dice ella.\"")
          msg ("")
          msg ("\"Las marcas en la pared son un hábito de viajero. Cuento los días para no perder la noción del tiempo. Aunque aquí, la verdad, el tiempo se pasa volando. Es curioso cómo funciona eso.\"")
          msg ("")
          msg ("\"Si quieres un consejo: disfruta la estancia. Explora la casa. Habla con los demás. Y si Carmen te ofrece estofado, di que sí. Siempre di que sí.\"")
          msg ("")
          msg ("Se recuesta en su silla con la satisfacción de un hombre sin preocupaciones. Pero sus dedos no dejan de moverse, contando algo que solo él puede ver.")
        } else if (game.horror < 14) {
          msg ("Ramón te mira con ojos que tardan demasiado en reconocerte.")
          msg ("")
          msg ("\"¿" + game.nombre_jugador + "? Perdona, te confundí con... con otro que estuvo aquí. Se llamaba... ¿cómo se llamaba? No importa. Ya no está.\"")
          msg ("")
          msg ("\"¿Cuántos días llevo? Pues...\" Mira las marcas en la pared y su expresión se nubla. \"¿Cuatro? ¿O cuatrocientos? Las marcas se multiplican cuando no las miro. Juro que ayer eran menos.\"")
          msg ("")
          msg ("\"Los que estaban antes...\" Se detiene. Su mano tiembla. \"No, nada. Olvídalo. No había nadie antes. Solo nosotros. ¿Verdad?\"")
          msg ("")
          msg ("\"847 marcas. Las conté. Cada una es un amanecer. Pero el sol sale diferente cada vez — a veces por el este, a veces por el norte, a veces por abajo. ¿Alguna vez has visto el sol salir desde abajo?\"")
          msg ("")
          msg ("\"Si ves a Sofía, dile que tenga cuidado con su amigo. El amigo que vive debajo. No me gusta ese amigo. No me gusta nada.\"")
          msg ("")
          msg ("Ramón se gira hacia la ventana tapiada y empieza a contar en voz baja. No está claro si te está ignorando o si ha olvidado que estás aquí.")
          game.ayudo_ramon = true
        } else {
          msg ("Ramón te agarra del brazo con una fuerza sorprendente para un hombre de su edad. Sus ojos están llenos de un terror tan antiguo que tiene capas, como la corteza de un árbol viejo.")
          msg ("")
          msg ("\"¡Escúchame! No tengo mucho tiempo. Cada vez que hablo de esto, la casa me hace olvidar. Pero esta vez voy a decirlo todo antes de que me borre.\"")
          msg ("")
          msg ("\"¡No abras esa puerta! Lo que hay debajo del sótano no quiere ser encontrado. Quiere ser alimentado. ¿Entiendes? No busca compañía. Busca comida. Y nosotros somos el menú.\"")
          msg ("")
          msg ("\"He intentado irme 847 veces. Cada vez — CADA VEZ — despierto en mi cama como si nada. La misma luz. La misma mañana. La misma Carmen en la cocina sonriendo como si fuera la primera vez que me ve. Y cada vez le creo. Cada maldita vez le creo durante unas horas antes de recordar.\"")
          msg ("")
          msg ("\"¿Sabes cuándo dejé de contar? El día 847. Porque ese día desperté y por primera vez no recordé quién era. Solo sabía que tenía que hacer una marca. Y la hice. Y fue la última.\"")
          msg ("")
          msg ("\"El día que dejé de contar fue el día que morí por dentro.\"")
          msg ("")
          msg ("Su agarre se afloja. Sus ojos se desenfocан. La niebla vuelve a cubrirlos.")
          msg ("")
          msg ("\"Perdona, ¿qué decía? Ah sí. El estofado de Carmen. ¿Lo has probado? Es el mejor que...\"")
          msg ("")
          msg ("Ya ha olvidado. La casa le hizo olvidar.")
          game.ayudo_ramon = true
          IncrementarHorror (1)
        }
      ]]></speak>
      <displayverbs type="simplestringlist">Examinar;Hablar</displayverbs>
    </object>

    <exit alias="este" to="pasillo_primer_piso">
      <inherit name="eastdirection" />
    </exit>
  </object>

  <!-- ==================== HABITACIÓN DE SOFÍA ==================== -->

  <object name="habitacion_sofia">
    <inherit name="editor_room" />
    <alias>Habitación de Sofía</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Una habitación infantil llena de color y vida. Juguetes antiguos ocupan cada rincón — muñecas de porcelana con vestidos de otra época, un trompo de madera pintado, un oso de peluche cuyo ojo izquierdo cuelga de un hilo. Las paredes están tapizadas de dibujos hechos con crayones: casas, árboles, familias sonrientes, soles con caras felices. Una cama pequeña con sábanas de flores ocupa el centro. Todo huele a lavanda y a inocencia preservada en ámbar.")
      } else if (game.horror < 14) {
        msg ("La habitación de Sofía ha cambiado. Los juguetes parecen más viejos — las muñecas tienen grietas en la porcelana y ojos que siguen tus movimientos. Los dibujos en las paredes muestran cosas que una niña no debería saber: la casa vista desde arriba rodeada de figuras oscuras, un sótano con algo brillando en la oscuridad, una familia que no sonríe sino que grita. El oso de peluche ha perdido ambos ojos. La cama está perfectamente hecha, como si Sofía no durmiera.")
      } else {
        msg ("Los dibujos en las paredes se mueven cuando no los miras directamente. Las figuras oscuras que rodean la casa en los crayones están más cerca en cada dibujo, como un timelapse del horror. Los juguetes están dispuestos en un círculo perfecto en el centro de la habitación, como en un ritual. Y en el centro del círculo hay un dibujo que no estaba antes — un dibujo de ti, sentado donde estás ahora, con los ojos muy abiertos.")
      }
    ]]></description>

    <object name="juguetes_sofia">
      <inherit name="editor_object" />
      <alias>juguetes de Sofía</alias>
      <alt type="simplestringlist">juguetes;muñecas;trompo;oso</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Muñecas de porcelana con vestidos victorianos, un trompo de madera pintado a mano con colores que se han apagado con los años, un oso de peluche marrón con un ojo colgando. Todos son juguetes de otra época — no de hace años, de hace décadas. Tal vez más. Pero están cuidados con esmero, como si para Sofía fueran nuevos.")
        } else {
          msg ("Los juguetes están dispuestos en un semicírculo, mirando hacia la esquina de la habitación donde Sofía dice que vive su amigo. Las muñecas tienen grietas que parecen sonrisas. El trompo gira solo de vez en cuando, sin que nadie lo toque. El oso de peluche está mojado, como si hubiera llorado.")
        }
      ]]></look>
    </object>

    <object name="dibujos_sofia">
      <inherit name="editor_object" />
      <alias>dibujos de Sofía</alias>
      <alt type="simplestringlist">dibujos;drawings</alt>
      <look type="script"><![CDATA[
        game.examino_dibujos = game.examino_dibujos + 1
        if (game.examino_dibujos = 1) {
          msg ("Dibujos hechos con crayones de colores brillantes. Una casa grande con un jardín, una familia de figuras palito sonrientes, un sol amarillo con cara feliz, flores de todos los colores. Son los dibujos de una niña feliz y creativa. Inocentes. Encantadores.")
        } else if (game.examino_dibujos = 2) {
          msg ("Los dibujos parecen diferentes ahora. La casa del dibujo está rodeada de figuras oscuras — no son árboles, son siluetas humanas. La familia ya no sonríe. El sol tiene una cara que no es feliz sino que parece estar gritando. Las flores son rojas. Solo rojas. Del rojo de la sangre, no del rojo de las rosas.")
        } else {
          if (game.horror >= 10) {
            msg ("Uno de los dibujos te deja completamente helado.")
            msg ("")
            msg ("Es una representación de una pantalla de computadora. La pantalla muestra texto — texto de un juego. Frente a la pantalla hay una figura sentada en una silla, con las manos sobre un teclado.")
            msg ("")
            msg ("La figura eres tú. No tu personaje. TÚ. Sentado frente a tu pantalla real, leyendo estas palabras reales en este momento real.")
            msg ("")
            msg ("Debajo del dibujo, con la letra de Sofía, dice: 'Te veo. Siempre te vi.'")
            if (not GetBoolean(game, "dibujos_easter_egg")) {
              SetObjectFlagOn (game, "dibujos_easter_egg")
              game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
            }
            IncrementarHorror (2)
          } else {
            msg ("Los dibujos son cada vez más perturbadores. La casa ahora tiene ojos en las ventanas. Las figuras oscuras están más cerca. En una esquina del papel, con letra muy pequeña, dice: 'otra vez otra vez otra vez otra vez'.")
          }
        }
      ]]></look>
    </object>

    <object name="cama_sofia">
      <inherit name="editor_object" />
      <alias>cama de Sofía</alias>
      <look><![CDATA[Una cama pequeña con sábanas que huelen a lavanda y a algo más, algo antiguo y dulce como la miel fermentada. Debajo de la almohada asoma algo — si miras más de cerca, es un trozo de papel con un dibujo: la casa vista desde arriba, como un plano arquitectónico, con una X marcando un lugar en el sótano. Una niña de diez años no debería poder dibujar un plano arquitectónico con esa precisión.]]></look>
    </object>

    <!-- NPC: SOFÍA -->
    <object name="sofia">
      <inherit name="editor_object" />
      <inherit name="namedfemale" />
      <alias>Sofía</alias>
      <alt type="simplestringlist">Sofia;niña;nina</alt>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Una niña de unos diez años con el cabello negro hasta los hombros y grandes ojos oscuros que parecen absorber la luz. Viste un vestido blanco con flores azules que parece de otra época — no viejo, sino atemporal. Sus zapatos de charol están impecables. Tiene las manos manchadas de crayones de colores. Sonríe con la inocencia de quien no sabe que el mundo puede ser cruel. O con la astucia de quien lo sabe perfectamente.")
        } else if (game.horror < 14) {
          msg ("Sofía parece la misma de siempre, pero ahora notas detalles que antes pasaste por alto. Sus ojos oscuros son DEMASIADO oscuros — no tienen pupila visible, solo un negro uniforme. Su vestido blanco siempre está limpio, sin importar lo que haga. Y cuando sonríe, sonríe con la boca pero no con los ojos. Los ojos saben algo que la sonrisa intenta ocultar.")
        } else {
          msg ("Sofía es la persona más lúcida de esta casa. Lo ves en sus ojos — esos ojos negros e insondables que llevan más años de los que su cuerpo infantil sugiere. No es una niña. Nunca lo fue. Es algo que eligió la forma de una niña porque las niñas hacen preguntas que los adultos ignoran, y dicen verdades que los adultos descartan como fantasía.")
        }
      ]]></look>
      <speak type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Sofía te mira con esos grandes ojos oscuros y te sonríe.")
          msg ("")
          msg ("\"¡Hola! ¿Eres nuevo? Yo soy Sofía. ¿Quieres jugar?\"")
          msg ("")
          msg ("\"Mis papás están en el pueblo comprando cosas. Vuelven pronto. Siempre dicen que vuelven pronto. Y siempre lo hacen. ¿Verdad?\"")
          msg ("")
          msg ("\"¿Has visto mis dibujos? Dibujé la casa. Es muy bonita, ¿verdad? Tiene muchos cuartos. Algunos están escondidos. Pero yo los conozco todos.\"")
          msg ("")
          msg ("\"A veces juego en el jardín, pero no me gusta ir muy lejos. El pueblo está muy callado. No me gustan los sitios callados. Prefiero los sitios con secretos.\"")
          msg ("")
          msg ("\"Carmen me da galletas de canela. Y me cuenta cuentos antes de dormir. Cuentos de personas que vivieron aquí. Muchas personas. Muchísimas. Carmen dice que la casa las quiere a todas.\"")
          msg ("")
          msg ("\"¿Tú también te vas a quedar mucho tiempo? Ojalá que sí. Me aburro cuando no hay gente nueva.\"")
          msg ("")
          msg ("Vuelve a sus dibujos, tarareando una canción que no reconoces pero que te suena familiar de un modo que te inquieta.")
        } else if (game.horror < 14) {
          msg ("Sofía deja de dibujar y te mira con una seriedad impropia de una niña de diez años.")
          msg ("")
          msg ("\"Mis papás llevan mucho comprando. ¿Cuánto es 'mucho'? Porque a veces 'mucho' son horas y a veces 'mucho' son años. En esta casa es difícil saber.\"")
          msg ("")
          msg ("\"¿Sabes? Mi amigo dice que esta casa tiene 121 años. Es muy vieja. Pero no parece vieja, ¿verdad? Es porque la casa no envejece. La casa come. Y mientras come, se mantiene joven.\"")
          msg ("")
          msg ("\"Mi amigo imaginario vive abajo. Dice que abajo es bonito. Que abajo todo tiene sentido. A veces le oigo hablar por las noches, a través del suelo. Cuenta historias de la gente que bajó. Dice que están contentos.\"")
          msg ("")
          msg ("\"Mira mi dibujo nuevo.\" Te muestra un dibujo de ti dentro de la casa, vista desde arriba, como un laberinto. En una esquina del dibujo hay un texto en letra infantil: 'otra vez'.")
          msg ("")
          msg ("\"Ese eres tú. Te dibujé ayer. O mañana. No me acuerdo. Dice 'otra vez' porque vienes mucho. ¿No te acuerdas? ¿De las otras veces? Yo sí me acuerdo.\"")
          msg ("")
          msg ("\"Si quieres saber el secreto del sótano, necesitas saber que 847 dividido entre 121 es 7. ¿Para qué? No sé. Pero mi amigo dice que es importante.\"")
          game.ayudo_sofia = true
        } else {
          if (game.examino_dibujos >= 3 and game.hablo_amigo_imaginario) {
            msg ("Sofía te mira directamente. Sin sonreír. Sin parpadear. Con la certeza absoluta de alguien que ha esperado este momento durante más tiempo del que puedes comprender.")
            msg ("")
            msg ("\"Ya no necesito fingir. Sé lo que es esta casa. Lo supe desde el principio. Porque yo soy parte de ella. La parte que recuerda.\"")
            msg ("")
            msg ("\"No soy una niña, " + game.nombre_jugador + ". Soy lo que queda de una niña que vivió aquí hace mucho tiempo. Tanto tiempo que mi cara original ya no existe. La casa me dio esta cara nueva, esta voz nueva, estos dibujos. A cambio, yo me quedé. Por voluntad propia.\"")
            msg ("")
            msg ("\"La casa necesita huéspedes para vivir. Cada uno de ustedes es alimento. No en el sentido literal — la casa no come carne. Come tiempo. Come recuerdos. Come la diferencia entre quién eras cuando llegaste y quién serás cuando ya no puedas irte.\"")
            msg ("")
            msg ("\"Yo elegí quedarme porque abajo está mi mamá. De verdad. O lo que queda de ella. La casa la mantuvo viva — a su manera — a cambio de que yo ayudara a recibir a los nuevos huéspedes.\"")
            msg ("")
            msg ("Sofía saca una pequeña llave de debajo de su almohada. Es antigua, de hierro negro, con un diseño que parece un corazón.")
            msg ("")
            msg ("\"Toma. Abre la última puerta. La del sótano, la que está detrás de las cajas. Ahí está el corazón de la casa.\"")
            msg ("")
            game.tiene_llave_sala_oculta = true
            game.hablo_sofia_capa3 = true
            game.ayudo_sofia = true
            msg ("\"No tengas miedo de lo que hay abajo. Ten miedo de lo que pasa cuando sales. Porque nunca sales de verdad. Parte de ti siempre se queda aquí. Y la parte que se va... ya no eres tú.\"")
            msg ("")
            msg ("(Has recibido la Llave de Sofía. Puedes abrir la puerta oculta del cuarto frío.)")
          } else {
            msg ("Sofía te mira con esos ojos negros y niega con la cabeza.")
            msg ("")
            msg ("\"Todavía no estás listo para la verdad. Necesitas ver más. Mis dibujos. Mi amigo. Cuando hayas visto todo, ven a hablar conmigo otra vez.\"")
            msg ("")
            msg ("(Necesitas examinar los dibujos de Sofía al menos 3 veces y hablar con su amigo imaginario antes de que Sofía comparta su secreto.)")
          }
        }
      ]]></speak>
      <displayverbs type="simplestringlist">Examinar;Hablar</displayverbs>
    </object>

    <exit alias="suroeste" to="pasillo_primer_piso">
      <inherit name="southwestdirection" />
    </exit>
  </object>

  <!-- ==================== BAÑO DEL PRIMER PISO ==================== -->

  <object name="bano_primer_piso">
    <inherit name="editor_room" />
    <alias>Baño del Primer Piso</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Un baño amplio con azulejos blancos y negros en patrón de ajedrez. Una bañera de hierro fundido con patas de garra ocupa el centro, flanqueada por un lavabo de porcelana y un espejo ovalado con marco dorado. Las tuberías gorgotean ocasionalmente, como si la casa digiriera algo. El aire está húmedo y tiene un ligero olor a jabón de lavanda. Todo está limpio, casi esterilizado.")
      } else if (game.horror < 14) {
        msg ("El baño se siente diferente. Los azulejos blancos tienen venas finas de un color amarillento, como los ojos de alguien enfermo. La bañera contiene agua turbia que nadie recuerda haber abierto — un agua oscura y densa que no refleja la luz correctamente. El espejo muestra tu reflejo con un segundo de retraso, como si necesitara tiempo para copiarte. Las tuberías ya no gorgotean — gimen.")
      } else {
        msg ("El baño es un lugar que ya no pertenece al mundo de los vivos. Los azulejos se han agrietado formando un patrón que parece un rostro — un rostro enorme que ocupa todo el suelo, con la bañera como su boca abierta. El agua en la bañera es negra y espesa como petróleo. El espejo no muestra tu reflejo — muestra una habitación vacía donde tú deberías estar. Como si ya no existieras.")
      }
    ]]></description>

    <object name="espejo_bano">
      <inherit name="editor_object" />
      <alias>espejo del baño</alias>
      <alt type="simplestringlist">espejo</alt>
      <look type="script"><![CDATA[
        game.veces_espejo_bano = game.veces_espejo_bano + 1
        if (game.veces_espejo_bano < 5) {
          if (game.horror < 7) {
            msg ("Tu reflejo te devuelve la mirada. Te ves cansado — más cansado de lo que deberías después de solo unas horas aquí. Hay sombras bajo tus ojos que no tenías cuando llegaste.")
          } else if (game.horror < 14) {
            msg ("Tu reflejo se mueve con un segundo de retraso. Levantas la mano derecha y tu reflejo levanta la izquierda un latido después. Parpadeas y tu reflejo no parpadea. O parpadea dos veces.")
          } else {
            msg ("El espejo muestra una habitación vacía. Tú no estás en el reflejo. La bañera está ahí, el lavabo está ahí, los azulejos están ahí. Pero tú no. Como si el espejo mostrara la verdad: que ya no estás realmente aquí.")
          }
        } else {
          msg ("Miras el espejo por quinta vez consecutiva.")
          msg ("")
          msg ("Tu reflejo sonríe.")
          msg ("")
          msg ("Tú no estás sonriendo.")
          msg ("")
          msg ("La sonrisa de tu reflejo se ensancha. Se ensancha más de lo que una boca humana debería poder. Y entonces tu reflejo levanta la mano y golpea el cristal desde dentro. Una vez. Dos veces. Tres veces. El cristal no se rompe. Pero la sonrisa no se desvanece.")
          if (not GetBoolean(game, "espejo_easter_egg")) {
            SetObjectFlagOn (game, "espejo_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
          game.veces_espejo_bano = 0
        }
      ]]></look>
    </object>

    <object name="banera">
      <inherit name="editor_object" />
      <alias>bañera</alias>
      <alt type="simplestringlist">tina;bañera</alt>
      <look type="script"><![CDATA[
        if (game.horror < 9) {
          msg ("Una bañera de hierro fundido con patas de garra de león. Está vacía y limpia, pero el desagüe tiene un cerco oscuro que sugiere que algo ha corrido por aquí recientemente. El grifo gotea con un ritmo que parece un código morse.")
        } else {
          msg ("La bañera está llena de agua turbia y oscura. No recuerdas haberla llenado. Nadie recuerda haberla llenado. El agua tiene un color entre marrón y negro, como café frío mezclado con tierra. Su superficie está quieta — demasiado quieta, como si estuviera congelada pero no lo está.")
          msg ("")
          msg ("Puedes intentar mirar el agua más de cerca.")
        }
      ]]></look>
    </object>

    <object name="lavabo_bano">
      <inherit name="editor_object" />
      <alias>lavabo</alias>
      <look><![CDATA[Un lavabo de porcelana blanca con un grifo de bronce oxidado. El agua que sale está fría — siempre fría, sin importar cuánto esperes. En el borde del lavabo hay un cabello largo y negro que no es tuyo. O tal vez sí lo sea, de una versión de ti que estuvo aquí antes.]]></look>
    </object>

    <object name="azulejos_bano">
      <inherit name="editor_object" />
      <alias>azulejos</alias>
      <look type="script"><![CDATA[
        if (game.horror < 7) {
          msg ("Azulejos blancos y negros en patrón de ajedrez. Limpios, relucientes, perfectamente colocados. El tipo de suelo que esperas en un hotel antiguo de buena categoría.")
        } else {
          msg ("Los azulejos tienen grietas finas que forman patrones. Si entrecierras los ojos, las grietas parecen letras. Si entrecierras los ojos un poco más, las letras forman palabras. Las palabras dicen: 'ESTÁS PISANDO MI CARA'.")
        }
      ]]></look>
    </object>

    <exit alias="sureste" to="pasillo_primer_piso">
      <inherit name="southeastdirection" />
    </exit>
  </object>

  <!-- ==================== DOÑA CARMEN (NPC standalone) ==================== -->

  <object name="dona_carmen">
    <inherit name="editor_object" />
    <inherit name="namedfemale" />
    <alias>Doña Carmen</alias>
    <alt type="simplestringlist">Carmen;doña carmen;dona carmen</alt>
    <parent>cocina</parent>
    <look type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Una mujer de unos sesenta años con el cabello recogido en un moño apretado y ojos oscuros que parecen conocerte desde antes de que llegaras. Lleva un delantal floreado sobre un vestido negro, y sus manos — fuertes, curtidas — siempre están haciendo algo: amasando pan, revolviendo la olla, limpiando el mostrador. Sonríe con una calidez maternal que te hace sentir bienvenido. Quizás demasiado bienvenido.")
      } else if (game.horror < 14) {
        msg ("Carmen parece exactamente igual que cuando la conociste. Exactamente. No ha cambiado un solo cabello, una sola arruga, un solo gesto. Mientras todo en la casa muta y se deforma, Carmen es la única constante. Y eso, de algún modo, es lo más aterrador de todo. Sus ojos oscuros te siguen por la habitación con la precisión de una cámara de seguridad.")
      } else {
        msg ("Carmen ya no finge. Su sonrisa sigue ahí, pero es una sonrisa de depredador — amable en la superficie, hambrienta debajo. Se mueve por la cocina con la gracia de alguien que ha repetido estos gestos un millón de veces. Porque los ha repetido un millón de veces. Cada huésped, la misma rutina, la misma sonrisa, el mismo estofado.")
      }
    ]]></look>
    <speak type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Carmen deja lo que está haciendo y te dedica toda su atención. Su sonrisa es cálida como el pan que siempre parece estar horneando.")
        msg ("")
        msg ("\"¿Cómo estás, querido? ¿Tu habitación es de tu agrado? Espero que sí. Cada habitación se adapta a su huésped. Es como si la casa supiera lo que necesitas antes de que tú lo sepas.\"")
        msg ("")
        msg ("\"Este pueblo era hermoso antes. Lleno de vida, de gente, de mercados los domingos. Ahora está más tranquilo. Pero la tranquilidad tiene su encanto, ¿no crees?\"")
        msg ("")
        msg ("\"Los otros huéspedes son encantadores. Martín con sus novelas, Lucía con su juventud, Ramón con sus historias, y la pequeña Sofía... esa niña es especial. Muy especial.\"")
        msg ("")
        msg ("\"He tenido muchos huéspedes a lo largo de los años. Todos se fueron felices. Bueno, todos se fueron. Algunos más felices que otros. Pero todos encontraron lo que buscaban.\"")
        msg ("")
        msg ("\"Esta casa cuida de los suyos, " + game.nombre_jugador + ". Recuérdalo.\"")
        msg ("")
        if (not game.carmen_ofrecio_vela) {
          msg ("\"Ah, antes de que te vayas — ¿necesitas algo para la oscuridad? El segundo piso no tiene buena luz. Tengo una vela aquí que te puede servir.\"")
          game.carmen_ofrecio_vela = true
          msg ("")
          msg ("(Carmen ha hecho aparecer una vela en la cocina. Puedes tomarla.)")
        }
        msg ("\"Si tienes hambre, el estofado estará listo pronto. Siempre está casi listo.\"")
      } else if (game.horror < 14) {
        msg ("Carmen te mira con esos ojos que saben demasiado. Su sonrisa flaquea por un instante — solo un instante — antes de volver con fuerza renovada.")
        msg ("")
        msg ("\"Cuando te fuiste la última vez...\" Se detiene. Parpadea. \"Perdón, quise decir cuando te vayas. Cuando te vayas, te extrañaremos mucho.\"")
        msg ("")
        msg ("\"¿Sabes que hoy es tu cumpleaños, " + game.nombre_jugador + "? Nací el... quiero decir, naciste el " + game.fecha_nacimiento + ". Lo recuerdo porque lo anoté en el registro.\"")
        msg ("")
        msg ("\"¿El sótano?\" Su sonrisa se congela. \"¿Qué sótano? No hay ningún sótano. Esta casa no tiene sótano. ¿Quién te dijo que había un sótano?\"")
        msg ("")
        msg ("Cambia de tema abruptamente.")
        msg ("")
        msg ("\"¿Quieres estofado? El estofado siempre ayuda. El estofado lo cura todo. El estofado te hace olvidar las preguntas que no deberías hacer.\"")
        msg ("")
        msg ("Su voz tiene un tono de advertencia que no tenía antes. No es amenaza. Es miedo. Carmen tiene miedo de algo. Y eso te aterroriza más que cualquier otra cosa.")
        game.ayudo_carmen = true
      } else {
        msg ("Carmen se sienta frente a ti. Por primera vez, deja de sonreír. Y sin la sonrisa, su cara es la de alguien que ha cargado un peso imposible durante un tiempo imposible.")
        msg ("")
        msg ("\"Ya no tiene sentido mentir. Llevas demasiado tiempo aquí para creer mis cuentos. Y yo llevo demasiado tiempo aquí para seguir contándolos.\"")
        msg ("")
        msg ("\"¿Cuánto tiempo llevo en esta casa? Más del que puedes imaginar. Más del que quiero recordar. Empecé como tú — una viajera cansada que buscaba un lugar donde descansar. La casa me acogió. Me alimentó. Me cuidó. Y a cambio...\"")
        msg ("")
        msg ("\"A cambio, yo le traigo huéspedes. La casa necesita huéspedes para existir. Sin ellos se debilita, se apaga, se muere. Y si la casa muere, todo lo que hay dentro muere con ella. Incluidos ustedes. Incluida yo.\"")
        msg ("")
        msg ("\"Los que intentaron irse de verdad...\" Su voz se quiebra. Una lágrima cae por su mejilla — es la primera emoción genuina que le ves. \"Algunos lo lograron. Al menos eso quiero creer. Pero la mayoría... la casa los absorbió. Se convirtieron en parte de ella. En ecos. Como Lucía. Como...\"")
        msg ("")
        msg ("\"No me odies, " + game.nombre_jugador + ". Yo también fui huésped una vez. Yo también busqué la salida. Yo también grité y lloré y arañé las paredes. Pero la casa me ofreció un trato: quedarme, cuidar de ella, traer nuevos huéspedes. Y a cambio, conservo mis recuerdos. Es más de lo que tienen los demás.\"")
        msg ("")
        msg ("\"La pregunta que debes hacerte no es cómo salir. Es qué estás dispuesto a dejar atrás.\"")
        game.ayudo_carmen = true
        IncrementarHorror (1)
      }
    ]]></speak>
    <displayverbs type="simplestringlist">Examinar;Hablar</displayverbs>
  </object>

  <!-- ==================== COMANDO: COMER ESTOFADO ==================== -->

  <command name="comer_estofado">
    <pattern>comer estofado;comer;probar estofado;aceptar estofado;beber estofado</pattern>
    <script><![CDATA[
      if (not player.parent = cocina) {
        msg ("No hay nada que comer aqui.")
      }
      else {
        game.comio_estofado = game.comio_estofado + 1
        if (game.comio_estofado = 1) {
          msg ("Tomas un cucharón del estofado. Está delicioso — reconfortante, cálido, con un sabor a hierbas que no puedes identificar pero que te resulta familiar. Carmen sonríe desde el fogón.")
          msg ("")
          msg ("\"Come, come. Tienes que recuperar fuerzas para el viaje.\"")
        }
        else if (game.comio_estofado = 2) {
          msg ("Repites. El sabor es más intenso esta vez, casi adictivo. Hay un regusto metálico al final que no notaste la primera vez. Carmen no deja de mirarte mientras comes.")
          msg ("")
          msg ("\"Bien, bien. Comes como los buenos huéspedes.\"")
        }
        else if (game.comio_estofado = 3) {
          msg ("La tercera cucharada sabe... diferente. La textura tiene algo que no debería estar ahí. Algo fibroso, algo que se resiste entre tus dientes. Carmen te observa sin parpadear, con una sonrisa que muestra demasiados dientes.")
          msg ("")
          msg ("\"Todos repiten. Pero pocos llegan a la tercera. Eres especial, " + game.nombre_jugador + ".\"")
          IncrementarHorror (1)
        }
        else if (game.comio_estofado = 4) {
          msg ("El estofado tiene un sabor puramente metálico ahora. Como cobre. Como sangre. Y entre la carne hay algo que parece un botón de camisa. Pequeño. Redondo. De hueso.")
          msg ("")
          msg ("Carmen recoge el botón antes de que puedas examinarlo.")
          msg ("")
          msg ("\"Eso no es nada, querido. Solo un hueso del... animal.\"")
          IncrementarHorror (1)
          if (not GetBoolean(game, "estofado_easter_egg")) {
            SetObjectFlagOn (game, "estofado_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
        }
        else if (game.comio_estofado >= 5) {
          if (not game.easter_estofado5) {
            game.easter_estofado5 = true
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
            msg ("Comes otra vez. No sabes por qué. Carmen te observa con una expresión que podría ser orgullo o podría ser hambre.")
            msg ("")
            msg ("\"Eres mi huésped favorito. Los demás nunca repetían tantas veces.\"")
            msg ("")
            msg ("Miras tus manos. Tiemblan. Tu piel se ve más pálida de lo normal. Mucho más pálida.")
            IncrementarHorror (2)
          }
          else {
            msg ("Tu cuerpo se niega. Has comido demasiado estofado. Tu estómago se revuelve al acercarte a la olla.")
          }
        }
      }
    ]]></script>
  </command>

  <!-- ==================== COMANDO: EXAMINAR DEBAJO DE LA MESA ==================== -->

  <command name="examinar_debajo_mesa">
    <pattern>examinar debajo de la mesa;mirar debajo de la mesa;examinar debajo mesa;debajo de la mesa</pattern>
    <script>
      if (player.parent = comedor) {
        msg ("Te agachas y miras debajo de la mesa del comedor. La parte inferior está cubierta de años de polvo y telarañas. Pero en una de las patas, tallado con algo afilado, hay un número:")
        msg ("")
        msg ("    1")
        msg ("")
        msg ("El número está tallado profundamente en la madera, como si alguien lo hubiera hecho con la urgencia de quien esconde un secreto que podría salvar vidas.")
        if (not GetBoolean(game, "digito_1_encontrado")) {
          SetObjectFlagOn (game, "digito_1_encontrado")
          msg ("")
          msg ("(Primer dígito del código descubierto: 1)")
        }
      } else {
        msg ("No hay ninguna mesa aquí debajo de la cual mirar.")
      }
    </script>
  </command>

  <!-- ==================== COMANDO: EXAMINAR REVERSO CUADRO ==================== -->

  <command name="examinar_reverso_cuadro">
    <pattern>examinar reverso;examinar detrás del cuadro;examinar detras del cuadro;mirar detrás del cuadro;reverso del cuadro</pattern>
    <script>
      if (player.parent = pasillo_primer_piso) {
        msg ("Levantas el cuadro con cuidado y miras detrás. El reverso del lienzo está manchado de humedad y tiene un número grabado con algo afilado:")
        msg ("")
        msg ("    9")
        msg ("")
        msg ("Alguien talló ese número con desesperación.")
        if (not GetBoolean(game, "digito_2_encontrado")) {
          SetObjectFlagOn (game, "digito_2_encontrado")
          msg ("")
          msg ("(Segundo dígito del código descubierto: 9)")
        }
      } else if (player.parent = sala_estar) {
        msg ("Levantas el cuadro de la sala y miras detrás.")
        if (game.encontro_pagina_3) {
          msg ("Ya no hay nada más aquí. Solo la marca donde estaba la página del diario.")
        } else {
          msg ("¡Hay una página doblada pegada con cinta al reverso del cuadro! La desprendes con cuidado.")
          msg ("")
          msg ("La página dice: 'Día 412: Lo he entendido todo. La casa no es una casa. Es una boca. Las habitaciones son dientes. Los pasillos son la garganta. Y el sótano es el estómago. Nosotros somos la comida. Carmen es la lengua que nos saborea antes de tragarnos. Si alguien lee esto, que sepa: la única salida es la que la casa no vigila. Pero la casa vigila todo.'")
          game.encontro_pagina_3 = true
          game.paginas_diario = game.paginas_diario + 1
          msg ("")
          msg ("(Página 3 del diario encontrada. " + game.paginas_diario + " de 3 páginas.)")
          if (game.paginas_diario >= 3) {
            game.encontro_diario = true
            msg ("")
            msg ("¡Has reunido las tres páginas del diario!")
            IncrementarHorror (4)
          }
        }
      } else {
        msg ("No hay ningún cuadro aquí para examinar por detrás.")
      }
    </script>
  </command>
  <!-- ============================================================ -->
  <!-- PARTE 4: SEGUNDO PISO, SÓTANO Y CIERRE                      -->
  <!-- ============================================================ -->

  <!-- ==================== SEGUNDO PISO ==================== -->

  <object name="escalera_segundo_piso">
    <inherit name="editor_room" />
    <alias>Escalera al Segundo Piso</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Una escalera estrecha de madera que sube al segundo piso de la casa. Cada escalón cruje de forma diferente bajo tus pies, como si la madera tuviera memoria muscular. Una ventana pequeña y redonda deja entrar un haz de luz polvorienta. El aire es más frío aquí arriba, y huele a desván, a libros olvidados, a tiempo acumulado. Tres puertas se abren desde este rellano: al norte el ático, al este la habitación de Carmen, y al oeste un cuarto de servicio.")
      } else if (game.horror < 14) {
        msg ("Los crujidos de la escalera forman un patrón que reconoces pero no puedes identificar. ¿Es una melodía? ¿Un código? Cada vez que subes, el número de escalones es diferente — diez, doce, quince. La ventana redonda muestra un paisaje que no corresponde a la orientación de la casa. El frío aquí arriba no es el frío del invierno. Es el frío de algo que absorbe calor. Las tres puertas del rellano parecen más juntas que antes.")
      } else {
        msg ("La escalera se ha convertido en una espiral. Juras que antes era recta. Los escalones se hunden bajo tus pies como si fueran de carne blanda. La ventana redonda muestra tu propia cara mirándote desde fuera — pero tú estás dentro. Las tres puertas del rellano respiran, hinchándose y contrayéndose con un ritmo que sincroniza con tu corazón. '" + game.nombre_jugador + "', susurra la madera bajo tus pies. '" + game.nombre_jugador + "', repiten las paredes.")
      }
    ]]></description>

    <object name="escalones_segundo">
      <inherit name="editor_object" />
      <alias>escalones</alias>
      <look><![CDATA[Madera antigua y oscurecida por siglos de uso. Cada escalón tiene una muesca diferente, una cicatriz diferente, como si cada uno guardara la memoria de un huésped diferente. El tercero desde abajo tiene algo tallado: una fecha. 1947.]]></look>
    </object>

    <object name="ventana_escalera">
      <inherit name="editor_object" />
      <alias>ventana de la escalera</alias>
      <alt type="simplestringlist">ventana</alt>
      <look type="script"><![CDATA[
        if (game.horror < 10) {
          msg ("Una ventana redonda, como un ojo de buey, que da al exterior. A través de ella ves el jardín, o lo que asumes que es el jardín. La luz que entra es cálida pero tiene un tinte dorado que no se corresponde con la hora del día.")
        } else {
          msg ("La vista ha cambiado. Ya no es el jardín. Es un bosque que se extiende hasta el horizonte, denso y oscuro, un bosque que no existía cuando llegaste. Entre los árboles hay luces — no estrellas, son demasiado bajas. Son ojos. Cientos de ojos brillando en la oscuridad, mirando la casa. Mirándote a ti.")
        }
      ]]></look>
    </object>

    <object name="polvo_escalera">
      <inherit name="editor_object" />
      <alias>polvo</alias>
      <look><![CDATA[El polvo flota en el aire formando espirales lentas que parecen deliberadas, como si cada mota siguiera una coreografía invisible. Si te quedas quieto el tiempo suficiente, las espirales forman formas — caras, manos, palabras que se disuelven antes de que puedas leerlas.]]></look>
    </object>

    <exit alias="bajar" to="pasillo_primer_piso">
      <inherit name="downdirection" />
    </exit>
    <exit name="exit_atico" alias="norte" to="atico">
      <inherit name="northdirection" />
      <locked />
      <lockedmessage>La puerta del ático está cerrada con llave. Necesitas encontrar la llave — quizás en alguno de los libros de la sala de estar.</lockedmessage>
    </exit>
    <exit name="exit_carmen" alias="este" to="habitacion_carmen">
      <inherit name="eastdirection" />
      <locked />
      <lockedmessage>La puerta de la habitación de Doña Carmen está cerrada con una cerradura especial. Solo alguien de confianza tiene esa llave.</lockedmessage>
    </exit>
    <exit alias="oeste" to="cuarto_servicio">
      <inherit name="westdirection" />
    </exit>
  </object>

  <!-- ==================== ÁTICO ==================== -->

  <object name="atico">
    <inherit name="editor_room" />
    <alias>Ático</alias>
    <description type="script"><![CDATA[
      tiene_luz = false
      if (game.tiene_vela or game.linterna_con_pilas) {
        tiene_luz = true
      }
      if (not tiene_luz) {
        msg ("La oscuridad es total y absoluta. No ves nada — ni tus propias manos frente a tu cara. El aire huele a polvo antiguo, a madera podrida, a secretos guardados durante demasiado tiempo. Necesitas una fuente de luz para explorar este lugar.")
      } else if (game.horror < 10) {
        if (game.tiene_vela) {
          luz = "tu vela"
        } else {
          luz = "tu linterna"
        }
        msg ("La luz de " + luz + " revela un ático amplio y abarrotado. Baúles de viaje apilados contra las paredes, muebles cubiertos con sábanas blancas que parecen fantasmas congelados, cajas de cartón con nombres y fechas escritos en marcador. Las vigas del techo están a la vista, gruesas y oscuras como huesos de un animal gigante. Telarañas cubren cada rincón. En el centro, sobre una mesa polvorienta, descansa un diario de cuero marrón, viejo y gastado.")
      } else if (game.horror < 14) {
        msg ("El ático se extiende más de lo que la geometría de la casa debería permitir. Las sábanas que cubren los muebles tienen forma humana — demasiado humana, con protuberancias donde deberían estar las cabezas, los hombros, las manos extendidas. Los baúles tienen nombres grabados: cientos de nombres, algunos repetidos, algunos tachados, algunos escritos en idiomas que no reconoces. El diario sobre la mesa pulsa con una luz propia, como un corazón de papel.")
      } else {
        msg ("El ático es un mausoleo. Cada baúl contiene la vida completa de un huésped anterior — ropa, cartas, fotografías, diarios. Son cientos. Miles. El ático no debería poder contener tanto, pero se extiende en todas direcciones como una catedral de recuerdos robados. Las sábanas ya no cubren muebles — cubren figuras que se mueven imperceptiblemente, respirando bajo la tela, esperando.")
      }
    ]]></description>

    <object name="diario_viejo">
      <inherit name="editor_object" />
      <alias>diario viejo</alias>
      <alt type="simplestringlist">diario;diario antiguo</alt>
      <look type="script"><![CDATA[
        if (not game.encontro_diario) {
          msg ("Un diario de cuero marrón, antiguo y gastado por el uso. La cubierta tiene las iniciales 'C.V.' grabadas en oro que se ha desvanecido. Al abrirlo, descubres que le faltan tres páginas — arrancadas con violencia, dejando bordes irregulares. Las páginas restantes contienen fragmentos inconexos:")
          msg ("")
          msg ("'...la casa necesita alimentarse...'")
          msg ("'...el sótano es donde vive...'")
          msg ("'...Carmen no es su nombre real...'")
          msg ("'...1947 fue el año en que todo empezó...'")
          msg ("")
          msg ("Sin las tres páginas arrancadas, la historia completa no se revela. Necesitas encontrar esas páginas: una debajo de la alfombra del pasillo, una debajo de la almohada de Ramón, y una detrás del cuadro de la sala de estar.")
        } else {
          msg ("El diario, ahora completo con sus tres páginas reinsertadas, cuenta la historia completa de Nicanor Molinare.")
          msg ("")
          msg ("Fue construida en 1947 por una mujer llamada Carmen Valdés — la primera Carmen. Pero no fue ella quien la diseñó. La casa fue construida sobre algo que ya estaba aquí antes de que el pueblo existiera. Algo antiguo. Algo hambriento.")
          msg ("")
          msg ("'Lo que hay debajo no tiene nombre', escribió Carmen en su diario. 'No es un demonio ni un dios. Es más simple y más terrible que eso. Es una necesidad. Una boca sin cuerpo. Un hambre sin estómago. Y la casa es el cuerpo que construimos para él.'")
          msg ("")
          msg ("'La casa no atrapa a los huéspedes. Los NECESITA. Cada huésped que se queda alimenta a lo que hay debajo. No con sangre ni con carne — con tiempo. Con recuerdos. Con la sustancia invisible que nos hace ser nosotros mismos. La casa come identidad.'")
          msg ("")
          msg ("'Y a cambio, la casa nos mantiene. Nos da un techo, comida, compañía. Nos da la ilusión de que somos personas en un lugar real. Es una simbiosis. Es una trampa. Es un hogar. Las tres cosas a la vez.'")
          msg ("")
          msg ("La última página dice: 'Si estás leyendo esto, ya sabes demasiado para irte y demasiado poco para quedarte. La única salida está abajo. Donde vive la verdad. Donde vive la boca.'")
          IncrementarHorror (3)
        }
      ]]></look>
    </object>

    <object name="baules">
      <inherit name="editor_object" />
      <alias>baúles</alias>
      <alt type="simplestringlist">baules;trunks;cofres</alt>
      <look type="script"><![CDATA[
        msg ("Baúles de viaje apilados contra las paredes del ático. Cada uno tiene un nombre y una fecha grabados en una placa de latón. Abres uno al azar:")
        msg ("")
        opciones = GetRandomInt(1, 4)
        if (opciones = 1) {
          msg ("'Elena Márquez, 1952'. Dentro hay un vestido de verano, un par de zapatos de tacón, y un diario con una sola entrada: 'Carmen dice que mañana puedo irme. Llevo esperando ese mañana tres años.'")
        } else if (opciones = 2) {
          msg ("'Jorge Alvarado, 1978'. Dentro hay una cámara fotográfica, rollos de película sin revelar, y un mapa de la casa con una habitación marcada en rojo que tú no has encontrado.")
        } else if (opciones = 3) {
          msg ("'María Teresa Ruiz, 1991'. Dentro hay ropa de niña — vestidos, zapatos, un oso de peluche. Te recuerda a Sofía. Te recuerda demasiado a Sofía.")
        } else {
          msg ("'" + game.nombre_jugador + "'. Tu nombre. Tu fecha de llegada. Pero este baúl está vacío. Todavía. Tiene una nota que dice: 'Reservado.'")
          IncrementarHorror (1)
        }
      ]]></look>
    </object>

    <object name="sabanas_atico">
      <inherit name="editor_object" />
      <alias>sábanas</alias>
      <alt type="simplestringlist">sabanas;muebles cubiertos</alt>
      <look type="script"><![CDATA[
        if (game.horror < 10) {
          msg ("Sábanas blancas cubren muebles viejos — sillas, mesas, un espejo. Las formas debajo son angulosas y mundanas. Son solo muebles.")
        } else {
          msg ("Las sábanas cubren formas que no son muebles. Son demasiado orgánicas, demasiado suaves, demasiado... humanas. Una de ellas se mueve. Levemente. Un temblor que podría ser tu imaginación. O podría no serlo. No te atreves a levantar la sábana. Algo te dice que lo que hay debajo no quiere ser descubierto. Y tú no quieres descubrirlo.")
        }
      ]]></look>
    </object>

    <object name="objetos_antiguos">
      <inherit name="editor_object" />
      <alias>objetos antiguos</alias>
      <alt type="simplestringlist">objetos;posesiones</alt>
      <look><![CDATA[Relojes detenidos a las 3:33 de la madrugada — todos a la misma hora. Gafas de diferentes graduaciones pero todas del mismo estilo. Diarios con la primera página llena y el resto en blanco. Cartas selladas que nunca se enviaron, dirigidas a personas que probablemente ya no existen. Un museo de vidas interrumpidas, cada objeto un epitafio silencioso.]]></look>
    </object>

    <exit alias="sur" to="escalera_segundo_piso">
      <inherit name="southdirection" />
    </exit>
  </object>

  <!-- ==================== HABITACIÓN DE DOÑA CARMEN ==================== -->

  <object name="habitacion_carmen">
    <inherit name="editor_room" />
    <alias>Habitación de Doña Carmen</alias>
    <description type="script"><![CDATA[
      msg ("La habitación de Doña Carmen es sorprendentemente normal. Ordenada, limpia, con una cama individual perfectamente hecha, un tocador con espejo cubierto por un paño, y fotos enmarcadas en cada superficie disponible. Huele a lavanda y a velas apagadas. Es la habitación de una mujer que ha vivido sola durante mucho tiempo y ha encontrado consuelo en la rutina.")
      msg ("")
      if (game.horror >= 14) {
        msg ("Pero las fotos... las fotos cuentan otra historia. Muestran a Carmen en cada década del siglo XX — los años 50, 60, 70, 80, 90, 2000. En CADA foto tiene la misma edad. Exactamente la misma edad. Las personas a su lado cambian, envejecen, desaparecen. Ella permanece idéntica, con la misma sonrisa, los mismos ojos oscuros, el mismo delantal.")
        msg ("")
        msg ("En una esquina de la habitación hay un cofre antiguo con un candado de combinación.")
      }
    ]]></description>

    <object name="fotos_carmen">
      <inherit name="editor_object" />
      <alias>fotos de Carmen</alias>
      <alt type="simplestringlist">fotos;fotografías;fotografias</alt>
      <look type="script"><![CDATA[
        msg ("Fotos enmarcadas en marcos de plata ennegrecida por el tiempo. Cada una muestra a Carmen con un grupo diferente de personas — siempre en la misma cocina, siempre con el mismo delantal, siempre con la misma sonrisa.")
        msg ("")
        msg ("1952: Carmen con una mujer joven de vestido de verano. 'Elena', dice la dedicatoria.")
        msg ("1967: Carmen con un hombre de barba y ojos tristes. 'Alejandro'.")
        msg ("1978: Carmen con un fotógrafo que sostiene una cámara. 'Jorge'.")
        msg ("1991: Carmen con una niña pequeña que se parece a Sofía. La dedicatoria está borrada.")
        msg ("2003: Carmen sola, mirando a la cámara con una expresión que no es una sonrisa.")
        msg ("")
        msg ("En TODAS las fotos, Carmen tiene exactamente la misma edad. Las personas cambian. Ella no.")
      ]]></look>
    </object>

    <object name="cama_carmen">
      <inherit name="editor_object" />
      <alias>cama de Carmen</alias>
      <look><![CDATA[Perfectamente hecha con sábanas de lino blanco que huelen a lavanda y a algo más antiguo — ámbar, tal vez, o mirra. La almohada no tiene marcas. Carmen no duerme. O si duerme, no deja huella.]]></look>
    </object>

    <object name="tocador_carmen">
      <inherit name="editor_object" />
      <alias>tocador de Carmen</alias>
      <alt type="simplestringlist">tocador</alt>
      <look><![CDATA[Un tocador de madera oscura con un espejo cubierto por un paño de terciopelo negro. Carmen no quiere ver su reflejo. O su reflejo no quiere ser visto. El paño está cosido al marco con hilo grueso, como si alguien se hubiera asegurado de que no se cayera accidentalmente.]]></look>
    </object>

    <object name="cofre_carmen">
      <inherit name="editor_object" />
      <alias>cofre</alias>
      <alt type="simplestringlist">cofre antiguo;baúl</alt>
      <look type="script"><![CDATA[
        if (game.cofre_abierto) {
          msg ("El cofre está abierto. Dentro están los documentos que revelan la verdad sobre Carmen.")
        } else {
          msg ("Un cofre de madera oscura con herrajes de hierro y un candado de combinación. Es antiguo — más antiguo que la casa, tal vez. La madera tiene grabados que parecen serpientes mordiéndose la cola.")
          msg ("")
          msg ("El candado necesita una combinación numérica. En el cuaderno de contabilidad del cuarto de servicio viste algo sobre una fecha escrita al revés...")
        }
      ]]></look>
      <use type="script"><![CDATA[
        if (game.cofre_abierto) {
          msg ("El cofre ya está abierto.")
        } else {
          msg ("El candado de combinación tiene varios diales numéricos. ¿Cuál es la combinación?")
          get input {
            reversed = ""
            i = LengthOf(game.fecha_nacimiento)
            while (i > 0) {
              reversed = reversed + Mid(game.fecha_nacimiento, i, 1)
              i = i - 1
            }
            if (result = reversed or result = game.fecha_nacimiento) {
              msg ("")
              msg ("Los diales giran con un chasquido satisfactorio. El cofre se abre.")
              msg ("")
              game.cofre_abierto = true
              msg ("Dentro del cofre hay documentos amarillentos y quebradizos. Son cartas, todas escritas por Carmen. Todas dirigidas a sí misma.")
              msg ("")
              msg ("La primera carta dice:")
              msg ("'Querida yo del futuro: Si estás leyendo esto, es porque otro huésped ha llegado demasiado lejos. Como todos los demás. Recuerda por qué te quedas. Los huéspedes deben llegar. La casa debe comer. Si la casa muere, todos los que están dentro mueren con ella. Incluida tú. — Carmen (la primera y la última)'")
              msg ("")
              msg ("La segunda carta dice:")
              msg ("'Querida Carmen: Hoy me miré en el espejo por última vez. Lo cubrí con un paño. No puedo seguir viéndome sin envejecer mientras todos a mi alrededor se consumen. Soy una trampera que se ha enamorado de sus presas. Cada huésped que alimento a la casa es una parte de mí que muere. Pero si dejo de hacerlo, la casa muere. Y yo con ella. Y todos los ecos dentro de ella.'")
              msg ("")
              msg ("La tercera carta dice:")
              msg ("'Querida Carmen: Han pasado 79 años. O tal vez 790. El tiempo no existe aquí de la forma que creemos. Lo que sé es esto: yo también fui huésped una vez. Yo también desperté en la recepción sin recordar cómo llegué. Y la Carmen anterior me recibió con la misma sonrisa que yo uso ahora. Y antes de ella hubo otra. Y otra. La casa no tiene dueña. La casa tiene víctimas que fingen ser dueñas.'")
              msg ("")
              msg ("Cierras el cofre. Sabes más de lo que quisieras. Pero todavía no sabes todo.")
              IncrementarHorror (3)
              game.ayudo_carmen = true
            } else {
              msg ("")
              msg ("La combinación es incorrecta. Los diales no ceden.")
            }
          }
        }
      ]]></use>
      <displayverbs type="simplestringlist">Examinar;Usar;Abrir</displayverbs>
    </object>

    <exit alias="oeste" to="escalera_segundo_piso">
      <inherit name="westdirection" />
    </exit>
  </object>

  <!-- ==================== CUARTO DE SERVICIO ==================== -->

  <object name="cuarto_servicio">
    <inherit name="editor_room" />
    <alias>Cuarto de Servicio</alias>
    <description type="script"><![CDATA[
      if (game.horror < 7) {
        msg ("Un cuarto de servicio polvoriento con estantes de madera llenos de productos de limpieza, escobas, trapos, y herramientas antiguas. Una mesa de trabajo ocupa el centro, cubierta de frascos, cepillos y un cuaderno viejo de contabilidad. El aire huele a amoníaco y a cera para pisos. Es una habitación utilitaria, sin pretensiones, el tipo de lugar que existe solo para mantener otro lugar en pie.")
      } else {
        msg ("Los productos de limpieza tienen fechas de caducidad de hace décadas. Las escobas se mueven imperceptiblemente cuando no las miras directamente, inclinándose hacia ti como girasoles hacia el sol. El cuaderno de contabilidad sobre la mesa parece más grueso que la última vez. Como si le crecieran páginas. En un rincón hay una linterna vieja cubierta de polvo.")
      }
    ]]></description>

    <object name="productos_limpieza">
      <inherit name="editor_object" />
      <alias>productos de limpieza</alias>
      <look><![CDATA[Frascos y botellas de marcas que dejaron de existir hace años. Lejía de una marca de los años sesenta. Cera para pisos de una empresa que cerró en 1974. Jabón con un logotipo que nadie reconocería hoy. Todo perfectamente conservado, como si el tiempo no pasara en estos estantes. O como si alguien los repusiera desde una fuente imposible.]]></look>
    </object>

    <object name="cuaderno_contabilidad">
      <inherit name="editor_object" />
      <alias>cuaderno de contabilidad</alias>
      <alt type="simplestringlist">cuaderno;contabilidad;registro</alt>
      <look type="script"><![CDATA[
        msg ("Un cuaderno de contabilidad grueso, encuadernado en cuero negro, con las esquinas dobladas por el uso. Lo abres.")
        msg ("")
        msg ("Cada página tiene columnas: Nombre, Fecha de Entrada, Habitación, Estado. La columna de 'Estado' dice lo mismo para todos: 'Residente'. No hay fechas de salida. Nadie se ha ido.")
        msg ("")
        msg ("Pasas las páginas. Son cientos de nombres. Miles. El cuaderno no debería poder contener tantas páginas, pero las contiene.")
        msg ("")
        msg ("Llegas a las últimas entradas:")
        msg ("")
        msg ("  Ramón Torres | 14/03/2019 | Hab. 4 | Residente")
        msg ("  Lucía (sin apellido) | ??/??/???? | Hab. 3 | Eco")
        msg ("  Sofía (sin apellido) | 12/06/1991 | Hab. 5 | Voluntaria")
        msg ("  Martín Echeverría | 03/09/2022 | Hab. 2 | Residente")
        msg ("")
        msg ("Y luego:")
        msg ("")
        msg ("  " + game.nombre_jugador + " | (tachado) | Hab. 1 | Residente")
        msg ("  " + game.nombre_jugador + " | (tachado) | Hab. 1 | Residente")
        msg ("  " + game.nombre_jugador + " | (tachado) | Hab. 1 | Residente")
        msg ("  " + game.nombre_jugador + " | (tachado) | Hab. 1 | Residente")
        msg ("  " + game.nombre_jugador + " | (tachado) | Hab. 1 | Residente")
        msg ("  " + game.nombre_jugador + " | (hoy) | Hab. 1 | Residente")
        msg ("")
        msg ("Tu nombre aparece SEIS veces. Las primeras cinco están tachadas. La sexta es de hoy.")
        msg ("")
        msg ("En el reverso del cuaderno, con letra apresurada, alguien escribió: 'La clave es recordar al revés. Tu primer día es la combinación del cofre.'")
        if (not game.vio_cuaderno_contabilidad) {
          game.vio_cuaderno_contabilidad = true
          game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          IncrementarHorror (3)
        }
      ]]></look>
    </object>

    <object name="linterna">
      <inherit name="editor_object" />
      <alias>linterna</alias>
      <take type="script"><![CDATA[
        msg ("Tomas la linterna. Es pesada y vieja, pero el mecanismo parece funcional.")
        MoveObject (linterna, player)
        game.tiene_linterna = true
        if (game.pilas_disponibles) {
          msg ("Colocas las pilas que encontraste en tu habitación. La linterna cobra vida con un zumbido eléctrico. Un haz de luz amarillenta corta la oscuridad.")
          game.linterna_con_pilas = true
        } else {
          msg ("No tiene pilas. Necesitas encontrar unas. Quizás en tu habitación haya algo útil.")
        }
      ]]></take>
      <look><![CDATA[Una linterna de mano antigua, de metal negro con el cristal ligeramente empañado. El interruptor está rígido pero funciona. Le faltan las pilas.]]></look>
      <displayverbs type="simplestringlist">Examinar;Tomar</displayverbs>
    </object>

    <object name="escobas">
      <inherit name="editor_object" />
      <alias>escobas</alias>
      <look><![CDATA[Escobas de paja alineadas contra la pared como centinelas. Una de ellas está húmeda — la paja gotea algo que tiene el color y la consistencia de la miel oscura. Otra tiene cabellos enredados entre las fibras — cabellos largos, negros, que podrían ser de Carmen. O de cualquiera de las cientos de Carmenes que hubo antes.]]></look>
    </object>

    <exit alias="este" to="escalera_segundo_piso">
      <inherit name="eastdirection" />
    </exit>
  </object>

  <!-- ==================== SÓTANO ==================== -->

  <object name="escalera_sotano">
    <inherit name="editor_room" />
    <alias>Escalera al Sótano</alias>
    <description type="script"><![CDATA[
      tiene_luz = false
      if (game.tiene_vela or game.linterna_con_pilas) {
        tiene_luz = true
      }
      if (not tiene_luz) {
        msg ("La oscuridad del sótano es total y absoluta. Es una oscuridad con peso, con textura, con intención. No ves nada. Ni siquiera la escalera bajo tus pies. El frío te golpea como una pared y el olor a tierra mojada y piedra antigua te llena los pulmones. Necesitas una fuente de luz para aventurarte más.")
      } else {
        if (game.tiene_vela) {
          luz = "tu vela"
        } else {
          luz = "tu linterna"
        }
        if (game.horror < 14) {
          msg ("Los escalones de piedra descienden a una oscuridad húmeda y fría. La luz de " + luz + " apenas ilumina unos metros, proyectando sombras largas y temblorosas sobre paredes de piedra que gotean un líquido transparente. El aire es denso, pesado, con un olor a tierra mojada, a musgo subterráneo, y a algo más: un olor dulce y desagradable que no puedes identificar. Los escalones están gastados en el centro por siglos de uso. Al pie de la escalera, dos pasillos se abren como las fauces de algo enorme.")
        } else {
          msg ("Desciendes al sótano con " + luz + " como único aliado. La escalera se ha alargado — juras que antes eran veinte escalones, ahora son cuarenta. Las paredes de piedra supuran algo oscuro y tibio. El olor dulce es más intenso aquí, casi nauseabundo, como fruta podrida mezclada con perfume. Los escalones tienen huellas — no de zapatos. De pies descalzos. Algunos son adultos. Algunos son de niño. Algunos tienen más dedos de los que deberían.")
        }
      }
    ]]></description>

    <object name="paredes_sotano">
      <inherit name="editor_object" />
      <alias>paredes del sótano</alias>
      <alt type="simplestringlist">paredes</alt>
      <look type="script"><![CDATA[
        if (game.horror < 14) {
          msg ("Piedra gris y húmeda, cubierta de una capa de musgo y condensación. Las juntas entre las piedras están rellenas de algo que podría ser mortero o podría ser algo orgánico. Gotas de agua caen a intervalos irregulares, cada una con un sonido diferente, como notas de un instrumento desafinado.")
        } else {
          msg ("Las paredes... palpitan. No es tu imaginación. La piedra se expande y contrae rítmicamente, como la caja torácica de un animal dormido. El musgo que las cubre tiene un color rojizo antinatural, y las gotas que caen son tibias. Demasiado tibias para ser agua.")
        }
      ]]></look>
    </object>

    <object name="goteo">
      <inherit name="editor_object" />
      <alias>goteo</alias>
      <look><![CDATA[El goteo constante marca un ritmo que no es aleatorio. Si lo escuchas con atención — demasiada atención — forma un patrón. Tres gotas rápidas, una lenta, tres rápidas, una lenta. Como un latido. Como el latido de un corazón enorme y antiguo que está debajo de tus pies.]]></look>
    </object>

    <object name="oscuridad_sotano">
      <inherit name="editor_object" />
      <alias>oscuridad</alias>
      <look><![CDATA[La oscuridad aquí tiene peso. Se siente como algo vivo que retrocede ante la luz pero nunca se va del todo. Está detrás de ti, encima de ti, debajo de ti. Es paciente. Ha esperado desde antes de que esta casa existiera. Puede esperar un poco más.]]></look>
    </object>

    <exit alias="subir" to="lavadero">
      <inherit name="updirection" />
    </exit>
    <exit alias="norte" to="bodega">
      <inherit name="northdirection" />
      <script type="script"><![CDATA[
        if (not game.tiene_vela and not game.linterna_con_pilas) {
          msg ("Está demasiado oscuro para aventurarte por ahí. Necesitas una fuente de luz.")
        } else {
          MoveObject (player, bodega)
        }
      ]]></script>
    </exit>
    <exit alias="sur" to="cuarto_frio">
      <inherit name="southdirection" />
      <script type="script"><![CDATA[
        if (not game.tiene_vela and not game.linterna_con_pilas) {
          msg ("Está demasiado oscuro para aventurarte por ahí. Necesitas una fuente de luz.")
        } else {
          MoveObject (player, cuarto_frio)
        }
      ]]></script>
    </exit>
  </object>

  <!-- ==================== BODEGA ==================== -->

  <object name="bodega">
    <inherit name="editor_room" />
    <alias>Bodega</alias>
    <description type="script"><![CDATA[
      if (game.horror < 14) {
        msg ("Una bodega de vinos con estantes de madera oscura que se extienden del suelo al techo. Las botellas descansan en sus nichos como cuerpos en un columbario, cubiertas de polvo y telarañas. Las etiquetas muestran fechas que no deberían existir: Cosecha de 1823. Reserva de 1756. Vendimia Especial de 1691. Algunas botellas son de antes de que el vino tuviera denominación de origen. El aire huele a corcho viejo, a uva fermentada, y al paso inexorable del tiempo.")
      } else {
        msg ("La bodega se ha transformado. Las botellas más antiguas — las de los estantes inferiores, las que tienen siglos — ya no contienen vino. El líquido dentro es de un rojo más oscuro, más espeso, con una viscosidad que no corresponde a ninguna bebida conocida. Algunas botellas tienen etiquetas con nombres en lugar de añadas. Los nombres de los huéspedes. Una botella tiene tu nombre. Está medio vacía. O medio llena. Depende de cuánto tiempo te quede.")
      }
    ]]></description>

    <object name="botellas_vino">
      <inherit name="editor_object" />
      <alias>botellas de vino</alias>
      <alt type="simplestringlist">botellas;vino</alt>
      <look type="script"><![CDATA[
        msg ("Examinas las botellas más de cerca. Las fechas son imposibles:")
        msg ("")
        msg ("  Tinto Reserva, Valle Quieto, 1543")
        msg ("  Cosecha Especial, 1298")
        msg ("  Vendimia de Otoño, 1047")
        msg ("  (Sin etiqueta), circa 800 a.C.")
        msg ("")
        if (game.horror >= 14) {
          msg ("La botella más antigua del estante inferior no tiene fecha. Su etiqueta dice simplemente: 'ANTES'. El líquido dentro no es vino. Es algo negro y denso que se mueve por sí solo cuando inclinas la botella, como si tuviera voluntad propia.")
          msg ("")
          msg ("Una botella tiene una etiqueta reciente con tu nombre: '" + game.nombre_jugador + "'. Está medio llena de un líquido del color exacto de tus ojos.")
        } else {
          msg ("Cada botella está perfectamente conservada. Como si el tiempo no existiera en estos estantes. O como si el vino — si es que es vino — no envejeciera.")
        }
      ]]></look>
    </object>

    <object name="estantes_bodega">
      <inherit name="editor_object" />
      <alias>estantes</alias>
      <look><![CDATA[Madera oscura y antigua que cruje pero no se rompe. Los estantes han sostenido estas botellas durante siglos sin ceder un milímetro. Tienen marcas — no de polilla ni de humedad, sino talladas deliberadamente. Símbolos que no reconoces: espirales, ojos, bocas abiertas. Los mismos símbolos que viste en el cofre de Carmen.]]></look>
    </object>

    <object name="polvo_bodega">
      <inherit name="editor_object" />
      <alias>polvo</alias>
      <look><![CDATA[El polvo aquí es diferente. Más fino. Más antiguo. Tiene un tono gris azulado que no corresponde al polvo normal. Si lo tocas, se siente cálido — no la calidez de algo expuesto al sol, sino la calidez de algo que está vivo.]]></look>
    </object>

    <exit alias="sur" to="escalera_sotano">
      <inherit name="southdirection" />
    </exit>
  </object>

  <!-- ==================== CUARTO FRÍO ==================== -->

  <object name="cuarto_frio">
    <inherit name="editor_room" />
    <alias>Cuarto Frío</alias>
    <description type="script"><![CDATA[
      msg ("Una habitación donde la temperatura cae en picado. Tu aliento forma nubes de vapor espeso. Las paredes tienen una capa de escarcha que brilla bajo la luz como diamantes diminutos. El frío no es natural — viene de algún lugar debajo del suelo, o de detrás de la pared del fondo.")
      msg ("")
      if (not game.cajas_movidas) {
        msg ("Hay cajas pesadas apiladas contra la pared del fondo, bloqueando lo que parece ser el contorno de una puerta. Las cajas están cubiertas de escarcha y parecen imposiblemente pesadas.")
      } else {
        msg ("Las cajas han sido apartadas, revelando una puerta antigua de madera oscura con una cerradura de hierro en forma de corazón. La puerta emite un calor suave que contrasta con el frío de la habitación, como si al otro lado hubiera algo vivo.")
      }
      if (game.horror >= 14) {
        msg ("")
        msg ("El frío es intencional. Es una barrera. Lo que sea que hay detrás de esa puerta está siendo contenido — no para protegerte a ti, sino para protegerlo a ello. El frío es su jaula. Y tú estás a punto de abrir la puerta de la jaula.")
      }
    ]]></description>

    <object name="cajas_cuarto_frio">
      <inherit name="editor_object" />
      <alias>cajas</alias>
      <alt type="simplestringlist">cajas apiladas;cajas pesadas</alt>
      <look type="script"><![CDATA[
        if (game.cajas_movidas) {
          msg ("Las cajas están apartadas a un lado, revelando la puerta oculta.")
        } else {
          msg ("Cajas de madera pesadas, cubiertas de escarcha, apiladas desde el suelo hasta casi el techo. Detrás de ellas ves el contorno de una puerta antigua. Las cajas no tienen marcas ni etiquetas, pero son imposiblemente pesadas — las empujas con todas tus fuerzas y no se mueven ni un centímetro.")
          msg ("")
          msg ("Necesitarías una fuerza sobrehumana para moverlas. O una fuerza que no sea del todo tuya.")
        }
      ]]></look>
      <use type="script"><![CDATA[
        if (game.cajas_movidas) {
          msg ("Las cajas ya están apartadas.")
        } else if (game.bebio_frasco) {
          msg ("La extraña energía del frasco recorre tus brazos como electricidad líquida. Tus músculos se tensan con una fuerza que no te pertenece — es la fuerza de la casa, canalizada a través de ti.")
          msg ("")
          msg ("Empujas las cajas. Se deslizan como si fueran de cartón, revelando una puerta de madera oscura con una cerradura en forma de corazón. La puerta está caliente al tacto. Desde el otro lado, escuchas algo. No un sonido. Una sensación. Como si algo al otro lado supiera que estás aquí.")
          game.cajas_movidas = true
        } else {
          msg ("Las cajas son imposiblemente pesadas. Tus brazos tiemblan por el esfuerzo pero no logras moverlas ni un milímetro. Necesitas algo que te dé fuerza — quizás algo de la despensa de la cocina, algo con tu nombre...")
        }
      ]]></use>
      <displayverbs type="simplestringlist">Examinar;Mover;Empujar;Usar</displayverbs>
    </object>

    <object name="escarcha">
      <inherit name="editor_object" />
      <alias>escarcha</alias>
      <look><![CDATA[La escarcha forma patrones geométricos perfectos en las paredes — hexágonos, espirales, fractales. Son demasiado precisos para ser naturales. Si los miras el tiempo suficiente, los patrones parecen moverse, expandiéndose y contrayéndose como si la escarcha respirara.]]></look>
    </object>

    <object name="puerta_oculta">
      <inherit name="editor_object" />
      <alias>puerta oculta</alias>
      <alt type="simplestringlist">puerta;puerta del fondo</alt>
      <look type="script"><![CDATA[
        if (not game.cajas_movidas) {
          msg ("Solo puedes ver el contorno de una puerta detrás de las cajas. Para examinarla mejor, primero necesitas moverlas.")
        } else {
          msg ("Una puerta de madera oscura, casi negra, con una cerradura de hierro forjado en forma de corazón. La madera está caliente al tacto — no la calidez de un fuego, sino la calidez de la piel viva. Tiene grabados en el marco: los mismos símbolos de espirales y ojos que aparecen por toda la casa.")
          msg ("")
          if (game.tiene_llave_sala_oculta) {
            msg ("Tienes la llave que Sofía te dio. La cerradura en forma de corazón coincide perfectamente con la llave.")
          } else {
            msg ("La cerradura necesita una llave especial. Una llave que solo alguien de confianza podría tener.")
          }
        }
      ]]></look>
      <use type="script"><![CDATA[
        if (not game.cajas_movidas) {
          msg ("Primero necesitas mover las cajas que bloquean la puerta.")
        } else if (not game.tiene_llave_sala_oculta) {
          msg ("La puerta tiene una cerradura en forma de corazón. No tienes la llave adecuada. Quizás uno de los huéspedes pueda ayudarte... alguien que conozca los secretos de la casa.")
        } else {
          msg ("Insertas la llave de Sofía en la cerradura con forma de corazón. Encaja perfectamente.")
          msg ("")
          msg ("Giras la llave. La cerradura hace un sonido que no es un clic — es un suspiro. Como si la puerta hubiera estado conteniendo el aliento durante décadas y por fin pudiera exhalar.")
          msg ("")
          msg ("La puerta se abre lentamente, sin que la toques. Del otro lado llega una oleada de aire caliente y un olor a cera derretida, a incienso, a algo vivo y antiguo.")
          msg ("")
          msg ("Has llegado al corazón de la casa.")
          MoveObject (player, sala_oculta)
          if (game.horror < 15) {
            IncrementarHorror (15 - game.horror)
          }
        }
      ]]></use>
      <displayverbs type="simplestringlist">Examinar;Abrir;Usar</displayverbs>
    </object>

    <exit alias="norte" to="escalera_sotano">
      <inherit name="northdirection" />
    </exit>
  </object>

  <!-- ==================== SALA OCULTA (FINAL) ==================== -->

  <object name="sala_oculta">
    <inherit name="editor_room" />
    <alias>Sala Oculta — El Corazón de la Casa</alias>
    <description type="script"><![CDATA[
      msg ("<div style='color:#cc4444; font-size:16px; text-align:center; text-shadow: 0 0 15px #440000; padding:10px 0;'>Has llegado al corazón de la casa.</div>")
      msg ("")
      msg ("<div style='color:#b8a898; line-height:1.8;'>Es una habitación circular de piedra antigua — no la piedra gris del sótano, sino una piedra negra y lisa que absorbe la luz en lugar de reflejarla. El techo se pierde en la oscuridad por encima de ti, como si la habitación fuera un pozo infinito invertido.</div>")
      msg ("")
      msg ("<div style='color:#aa9988; font-style:italic; text-align:center; padding:5px 0;'>En el centro hay tres cosas:</div>")
      msg ("")
      msg ("<div style='border-left:2px solid #440000; padding-left:15px; margin:8px 0;'><div style='color:#998888; line-height:1.8;'>Un <span style='color:#cc6666;'>ESPEJO</span> ovalado que no refleja nada — ni a ti, ni la habitación, ni la luz. Solo un vacío negro y profundo que parece extenderse hasta el infinito.</div></div>")
      msg ("")
      msg ("<div style='border-left:2px solid #443300; padding-left:15px; margin:8px 0;'><div style='color:#998877; line-height:1.8;'>Una <span style='color:#ccaa66;'>SILLA</span> de madera solitaria, gastada por el uso de miles de huéspedes que se sentaron aquí antes que tú. Algunos eligieron quedarse. Otros eligieron irse. Todos están aquí de alguna forma.</div></div>")
      msg ("")
      msg ("<div style='border-left:2px solid #333366; padding-left:15px; margin:8px 0;'><div style='color:#8888aa; line-height:1.8;'>Una <span style='color:#8888cc;'>MESA</span> con un <span style='color:#cc88cc;'>LIBRO</span> abierto. El libro tiene una página para cada huésped que existió. La última página está en blanco. Tu página. Esperando tu firma.</div></div>")
      msg ("")
      if (game.horror >= 18) {
        msg ("<div style='color:#cc4444; line-height:1.8; text-shadow: 0 0 5px #330000;'>La habitación late. Como un corazón. Porque ES un corazón. El corazón de la casa. Y ahora que estás aquí, te siente. Te conoce. Te ha estado esperando desde antes de que nacieras.</div>")
        msg ("")
        msg ("<div style='color:#ff6666; font-style:italic; text-align:center; font-size:15px; text-shadow: 0 0 10px #660000;'>'" + game.nombre_jugador + "', dice una voz que viene de todas partes y de ninguna. 'Has llegado. Al fin. Como siempre. Como cada vez.'</div>")
      }
      msg ("")
      msg ("<div style='text-align:center; padding:10px 0; border:1px solid #333; margin:10px 0; background:rgba(30,15,15,0.5);'><span style='color:#cc9966; font-style:italic;'>Puedes <span style='color:#ff8844;'>FIRMAR EL LIBRO</span> para elegir tu destino. Piensa bien lo que escribes.</span></div>")
      if (game.acto < 4) {
        game.acto = 4
      }
    ]]></description>

    <object name="espejo_oculto">
      <inherit name="editor_object" />
      <alias>espejo</alias>
      <alt type="simplestringlist">espejo negro;espejo oscuro</alt>
      <look type="script"><![CDATA[
        msg ("Te colocas frente al espejo. No ves tu reflejo. No ves nada.")
        msg ("")
        msg ("Solo un negro absoluto que parece profundo — infinitamente profundo. Como si el espejo fuera una ventana a un lugar donde la luz no existe, donde el espacio no tiene fondo, donde el concepto de 'aquí' y 'allá' no tiene significado.")
        msg ("")
        if (game.horror >= 18) {
          msg ("Y en esa profundidad, algo se mueve. No lo ves — lo sientes. Una presencia vasta y antigua que se desplaza lentamente en la oscuridad del otro lado del cristal. Se acerca al espejo desde dentro. Se acerca a ti.")
          msg ("")
          msg ("Por un instante — solo un instante — ves un rostro en el espejo. No es el tuyo. Es más viejo que cualquier rostro humano. Sus ojos son agujeros negros. Su boca está abierta en una sonrisa que es idéntica a la de Carmen.")
          msg ("")
          msg ("Luego desaparece. El espejo vuelve a ser un vacío negro.")
          msg ("")
          msg ("Pero ahora sabes qué hay al otro lado. Y eso no se puede desconocer.")
        } else {
          msg ("Hay algo en la profundidad del espejo. No lo ves. Pero sientes su mirada. Antigua. Paciente. Hambrienta.")
        }
      ]]></look>
    </object>

    <object name="silla_oculta">
      <inherit name="editor_object" />
      <alias>silla</alias>
      <look><![CDATA[Una silla de madera simple, sin barniz, sin adornos. La madera está gastada por el uso de cientos — quizás miles — de huéspedes que se sentaron aquí antes que tú. El asiento tiene la forma vaga de un cuerpo, pulida por innumerables horas de decisiones tomadas en este mismo lugar. Cada huésped se sentó aquí. Cada uno eligió. Y cada elección alimentó a la casa de una forma diferente.]]></look>
    </object>

    <object name="libro_abierto">
      <inherit name="editor_object" />
      <alias>libro abierto</alias>
      <alt type="simplestringlist">libro;libro de registro;registro</alt>
      <look type="script"><![CDATA[
        msg ("<div style='color:#b8a898; line-height:1.8;'>Un libro enorme, encuadernado en cuero negro que parece piel de algo que no es un animal. Está abierto sobre la mesa. Cada página contiene un nombre, una fecha, y unas líneas escritas — la historia de cada huésped, condensada en un párrafo.</div>")
        msg ("")
        msg ("<div style='color:#998877; font-style:italic;'>Pasas las páginas. Cientos. Miles. Cada vida resumida en unas pocas líneas:</div>")
        msg ("")
        msg ("<div style='border-left:2px solid #333; padding-left:15px; margin:8px 0; color:#887766; font-style:italic; line-height:2;'><div>'Elena Márquez, 1952. Buscaba olvidar un amor perdido. La casa la ayudó a olvidar. Lo olvidó todo.'</div><div>'Jorge Alvarado, 1978. Buscaba la foto perfecta. La encontró. Era la última.'</div><div>'María Teresa Ruiz, 1991. Buscaba a su hija. La encontró. <span style='color:#cc6666;'>Debajo.</span>'</div></div>")
        msg ("")
        msg ("<div style='color:#aa8866;'>La última página escrita tiene el nombre de Ramón:</div>")
        msg ("")
        msg ("<div style='border-left:2px solid #444400; padding-left:15px; margin:8px 0; color:#aaaa66; font-style:italic;'>'Ramón Torres. Buscaba paz. Encontró eternidad. Sigue buscando.'</div>")
        msg ("")
        msg ("<div style='color:#c8b89a; line-height:1.8;'>La siguiente página está en blanco. <span style='color:#ccaa88;'>TU página.</span> Una pluma antigua descansa junto al libro, con tinta que parece demasiado oscura para ser tinta.</div>")
        msg ("")
        msg ("<div style='text-align:center; padding:15px 0; border:1px solid #333; margin:10px 0; background:rgba(30,15,15,0.5);'><div style='color:#cc9966; font-style:italic; padding-bottom:10px;'>Puedes <span style='color:#ff8844;'>FIRMAR EL LIBRO</span>. Lo que escribas determinará tu destino.</div><br/><div style='color:#88cc88; line-height:2.2;'>Escribe '<span style='color:#44cc44;'>LIBERTAD</span>' para intentar escapar.</div><div style='color:#ccaa66; line-height:2.2;'>Escribe '<span style='color:#ffcc44;'>tu NOMBRE</span>' para aceptar tu lugar.</div><div style='color:#8888cc; line-height:2.2;'>Escribe '<span style='color:#6666ff;'>ELLA</span>' o '<span style='color:#6666ff;'>SOFÍA</span>' para sacrificarte por Sofía.</div></div>")
        if (game.easter_eggs_encontrados >= 15) {
          msg ("O escribe 'VERDAD' para descubrir el final secreto...")
        }
      ]]></look>
    </object>

    <exit alias="salir" to="cuarto_frio">
      <inherit name="outdirection" />
    </exit>
  </object>

  <!-- ==================== COMANDO: FIRMAR VERDAD (final secreto) ==================== -->

  <command name="firmar_verdad">
    <pattern>escribir verdad;firmar verdad;verdad</pattern>
    <script>
      if (player.parent = sala_oculta and game.easter_eggs_encontrados >= 15) {
        msg ("")
        msg ("Escribes 'VERDAD' en el libro. La tinta brilla con todos los colores a la vez y luego se hunde en la página como si el papel la tragara.")
        msg ("")
        FinalVerdad
      } else if (player.parent = sala_oculta) {
        msg ("Escribes 'VERDAD' pero la tinta se desvanece. No has descubierto suficientes secretos para merecer la verdad. Necesitas encontrar más easter eggs.")
        msg ("(Has encontrado " + game.easter_eggs_encontrados + " de 20. Necesitas al menos 15.)")
      }
    </script>
  </command>

  <!-- ==================== COMANDO: BEBER FRASCO ==================== -->

  <command name="beber_frasco">
    <pattern>beber frasco;tomar frasco;usar frasco;beber poción;beber el frasco</pattern>
    <script>
      if (game.frasco_disponible and not game.bebio_frasco) {
        msg ("Destapas el frasco con tu nombre. El líquido dentro es espeso y luminiscente, del color de la miel mezclada con luz de luna. Huele a ti — a tu champú, a tu ropa, a tu piel. Huele a casa.")
        msg ("")
        msg ("Lo bebes.")
        msg ("")
        msg ("El efecto es inmediato. Una calidez sobrehumana recorre tus venas. Tus músculos se tensan con una energía que no te pertenece — es la energía de la casa, canalizada a través de ti. Tus manos tiemblan. Tu visión se agudiza. El mundo parece más definido, más real, más...")
        msg ("")
        msg ("...más hambriento.")
        game.bebio_frasco = true
        IncrementarHorror (1)
      } else if (game.bebio_frasco) {
        msg ("Ya bebiste el contenido del frasco. La energía todavía recorre tus venas.")
      } else {
        msg ("No tienes ningún frasco para beber.")
      }
    </script>
  </command>

  <!-- ==================== COMANDO: VER FRASCO EN DESPENSA ==================== -->

  <command name="examinar_frascos">
    <pattern>examinar frascos;examinar frasco;examinar despensa;mirar frascos;ver frascos</pattern>
    <script>
      if (player.parent = cocina) {
        if (game.horror >= 7) {
          msg ("Los frascos de la despensa tienen etiquetas escritas a mano. Algunos tienen nombres de hierbas: romero, tomillo, laurel. Pero otros tienen nombres de personas.")
          msg ("")
          msg ("'Esencia de Elena', 'Extracto de Jorge', 'Destilado de Alejandro'...")
          msg ("")
          if (game.frasco_disponible or game.horror >= 10) {
            game.frasco_disponible = true
            msg ("Y en la parte de atrás, medio escondido: un frasco con tu nombre. '" + game.nombre_jugador + "'. El líquido dentro brilla suavemente.")
            msg ("")
            msg ("En la etiqueta de uno de los frascos ves un número: 4. (Tercer dígito del código.)")
            if (not GetBoolean(game, "digito_3_encontrado")) {
              SetObjectFlagOn (game, "digito_3_encontrado")
              msg ("(Tercer dígito del código descubierto: 4)")
            }
          } else {
            msg ("Uno de los frascos tiene escrito '4' en la etiqueta.")
            if (not GetBoolean(game, "digito_3_encontrado")) {
              SetObjectFlagOn (game, "digito_3_encontrado")
              msg ("(Tercer dígito del código descubierto: 4)")
            }
          }
        } else {
          msg ("La despensa tiene frascos de especias, conservas y hierbas secas. Todo perfectamente etiquetado y organizado. Romero, tomillo, canela, clavo. Normal. Completamente normal.")
        }
      } else {
        msg ("No hay frascos aquí que examinar.")
      }
    </script>
  </command>

  <!-- ==================== COMANDO: SALVAR A SOFÍA ==================== -->

  <command name="salvar_sofia">
    <pattern>salvar a sofía;salvar sofia;salvar a sofia;ayudar a sofía;ayudar sofia;proteger sofia</pattern>
    <script>
      if (game.hablo_sofia_capa3) {
        msg ("\"¿Salvarme?\" Sofía te mira con sus ojos negros. \"Nadie puede salvarme, " + game.nombre_jugador + ". Pero si de verdad quieres intentarlo... cuando firmes el libro, escribe mi nombre. Escribe 'ella'. Escribe 'Sofía'. Y yo saldré. Pero tú te quedarás.\"")
        msg ("")
        msg ("\"¿Estás seguro de que quieres hacer eso?\"")
        game.salvo_sofia = true
      } else {
        msg ("No estás seguro de cómo o a quién salvar.")
      }
    </script>
  </command>

  <!-- ==================== LLAVE DEL ÁTICO (creada por puzzle de libros) ==================== -->

  <command name="usar_llave_atico">
    <pattern>usar llave del ático;usar llave atico;abrir ático;abrir atico;usar llave oxidada</pattern>
    <script>
      if (game.tiene_llave_atico and player.parent = escalera_segundo_piso) {
        msg ("Usas la llave oxidada en la cerradura del ático. Gira con dificultad, emitiendo un chirrido agudo que resuena por toda la escalera. La puerta se abre.")
        exit_atico.locked = false
      } else if (not game.tiene_llave_atico) {
        msg ("No tienes la llave del ático.")
      } else {
        msg ("No hay ninguna puerta que abrir aquí con esa llave.")
      }
    </script>
  </command>

  <!-- ==================== LLAVE DE CARMEN (dada al tener la de sofia) ==================== -->

  <command name="usar_llave_carmen">
    <pattern>usar llave de carmen;abrir puerta de carmen;abrir habitación de carmen;abrir habitacion de carmen;usar llave especial</pattern>
    <script>
      if (game.tiene_llave_carmen and player.parent = escalera_segundo_piso) {
        msg ("Usas la llave especial en la cerradura de la habitación de Carmen. La puerta se abre con un suspiro, como si hubiera estado esperando este momento.")
        exit_carmen.locked = false
      } else if (game.hablo_sofia_capa3 and player.parent = escalera_segundo_piso) {
        msg ("La cerradura cede ante tu toque. Ahora que conoces los secretos de la casa, las puertas se abren para ti.")
        game.tiene_llave_carmen = true
        exit_carmen.locked = false
      } else if (not game.tiene_llave_carmen) {
        msg ("No tienes la llave de la habitación de Carmen. Quizás alguien que conozca los secretos de la casa pueda ayudarte.")
      } else {
        msg ("No hay ninguna puerta que abrir aquí.")
      }
    </script>
  </command>

  <!-- ==================== COMANDO: EXAMINAR RELOJ ==================== -->

  <command name="examinar_reloj">
    <pattern>examinar reloj;mirar reloj;ver reloj;mirar la hora;ver la hora;qué hora es</pattern>
    <script><![CDATA[
      if (player.parent = comedor) {
        hora_falsa = GetRandomInt(1, 30)
        minutos_falsos = GetRandomInt(0, 99)
        if (game.horror < 4) {
          msg ("El reloj de péndulo marca las " + hora_falsa + ":" + minutos_falsos + ". No parece una hora correcta, pero quizás tu reloj interior está desajustado por el viaje.")
        } else if (game.horror < 10) {
          msg ("El reloj marca las " + hora_falsa + ":" + minutos_falsos + ". Eso es imposible. La última vez marcaba otra hora igualmente imposible. El péndulo se balancea con un ritmo que no coincide con el tic-tac. Como si el reloj midiera un tiempo diferente al tuyo.")
        } else {
          msg ("El reloj marca una hora que te hiela la sangre.")
          msg ("")
          JS.eval ("var d=new Date(); var h=d.getHours(); var m=d.getMinutes(); ASLEvent('MostrarHoraReal', h+':'+('0'+m).slice(-2))")
          if (not GetBoolean(game, "reloj_easter_egg")) {
            SetObjectFlagOn (game, "reloj_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
        }
      } else {
        msg ("No hay ningún reloj aquí.")
      }
    ]]></script>
  </command>

  <function name="MostrarHoraReal" parameters="hora">
    msg ("El reloj marca las " + hora + ".")
    msg ("")
    msg ("Esa es la hora real. TU hora real. La hora de tu mundo. El reloj de la casa está mostrando la hora de tu sistema, de tu computadora, de tu vida fuera de esta pantalla.")
    msg ("")
    msg ("..." + hora + " ...es la hora. Tu hora.")
  </function>

  <!-- ==================== COMANDO: EXAMINAR ESPEJO VISITAS ==================== -->

  <command name="examinar_espejo_visitas">
    <pattern>examinar espejo</pattern>
    <script><![CDATA[
      if (player.parent = bano_visitas) {
        game.veces_espejo_visitas = game.veces_espejo_visitas + 1
        if (game.veces_espejo_visitas < 5) {
          if (game.horror < 7) {
            msg ("Tu reflejo te devuelve la mirada. Te ves normal. Cansado, quizás, pero normal. ¿Verdad?")
          } else {
            msg ("Tu reflejo se mueve con un ligero retraso. O eres tú quien se mueve con retraso respecto a él. Es difícil saber quién imita a quién.")
          }
        } else {
          msg ("<div style='color:#998888;'>Miras el espejo por quinta vez.</div>")
          msg ("")
          msg ("<div style='color:#cc4444; font-size:16px; text-align:center; text-shadow: 0 0 10px #440000;'>Tu reflejo sonríe.</div>")
          msg ("")
          msg ("<div style='color:#ff4444; font-size:14px; text-align:center; font-style:italic;'>Tú no estás sonriendo.</div>")
          msg ("")
          msg ("<div style='color:#aa6666; line-height:1.8;'>Retrocedes instintivamente. Tu reflejo no retrocede. Se queda ahí, sonriendo, con tus ojos pero no tu expresión, con tu cara pero no tu alma.</div>")
          if (not GetBoolean(game, "espejo_visitas_easter_egg")) {
            SetObjectFlagOn (game, "espejo_visitas_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
          game.veces_espejo_visitas = 0
        }
      } else if (player.parent = bano_primer_piso) {
        game.veces_espejo_bano = game.veces_espejo_bano + 1
        if (game.veces_espejo_bano < 5) {
          msg ("Tu reflejo te devuelve una mirada cansada desde el espejo del baño.")
        } else {
          msg ("<div style='color:#cc4444; text-shadow: 0 0 8px #440000;'>Tu reflejo sonríe. Tú no estás sonriendo. <span style='color:#ff4444;'>La sonrisa se ensancha más de lo humanamente posible.</span></div>")
          if (not GetBoolean(game, "espejo_easter_egg")) {
            SetObjectFlagOn (game, "espejo_easter_egg")
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
          game.veces_espejo_bano = 0
        }
      } else {
        msg ("No hay ningún espejo aquí.")
      }
    ]]></script>
  </command>

  <!-- ==================== COMANDOS PARTE 2 ==================== -->

  <command name="rezar">
    <pattern>rezar;orar;pedir ayuda divina;dios</pattern>
    <script><![CDATA[
      if (not game.easter_rezar) {
        game.easter_rezar = true
        game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
      }
      if (game.horror < 7) {
        msg ("Cierras los ojos y rezas en silencio. No pasa nada. Pero sientes una breve calma.")
      }
      else if (game.horror < 14) {
        msg ("Cierras los ojos y rezas. Las palabras se sienten huecas, como si el techo las absorbiera antes de que lleguen a ningun lado.")
      }
      else if (game.horror < 18) {
        msg ("Cierras los ojos y rezas. Una voz responde. No es la voz que esperabas. Dice: 'Aqui no llega nadie. Aqui solo estoy yo.' La voz suena exactamente como la tuya.")
        IncrementarHorror (1)
      }
      else {
        msg ("Rezas. La respuesta es risa. Tu propia risa, pero distorsionada, viniendo de las paredes, del suelo, del techo. Suena como si cien versiones de ti se estuvieran riendo a la vez.")
        IncrementarHorror (1)
      }
    ]]></script>
  </command>

  <command name="gritar">
    <pattern>gritar;grito;GRITAR;aaaa;AAAA;aaaah</pattern>
    <script><![CDATA[
      if (not game.easter_gritar) {
        game.easter_gritar = true
        game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
      }
      if (game.horror < 7) {
        msg ("Gritas. Tu voz rebota por los pasillos. Carmen se asoma desde la cocina con expresion preocupada. 'Estas bien, querido?'")
      }
      else if (game.horror < 14) {
        msg ("Gritas. Tu voz rebota por los pasillos. Pero el eco vuelve con un segundo de retraso. Y el eco suena diferente. Mas grave. Mas largo. Como si algo gritara contigo.")
      }
      else if (game.horror < 18) {
        msg ("Gritas. Tu voz no produce eco. La casa la absorbe como una esponja. El silencio que queda despues es peor que el grito. Es un silencio hambriento.")
      }
      else {
        msg ("Gritas. Pero tu boca no se abre. El grito viene de dentro de las paredes. Es tu voz, gritando tu nombre, una y otra vez, en un loop que va acelerandose hasta convertirse en un zumbido agudo. Luego se detiene. Y una voz tranquila dice: 'Ya terminaste? Bien. Ahora sigue jugando.'")
      }
    ]]></script>
  </command>

  <command name="interactuar_npc">
    <pattern>abrazar a #text#;tocar a #text#;empujar a #text#;atacar a #text#;abrazar #text#;tocar #text#;empujar #text#;atacar #text#</pattern>
    <script><![CDATA[
      accion = ""
      npc = LCase(text)
      if (StartsWith(npc, "a ")) {
        npc = Mid(npc, 3)
      }
      input_cmd = LCase(game.pov_alias)
      if (Instr(npc, "carmen") > 0) {
        if (game.horror < 7) {
          msg ("Carmen te abraza de vuelta. Sus brazos son sorprendentemente fuertes. Te retiene un segundo mas de lo comodo. Su aliento huele a hierbas y a algo dulce que no puedes identificar.")
        }
        else if (game.horror < 14) {
          msg ("Te acercas a Carmen. Su piel esta fria como la piedra. Te mira con ojos que parecen mas hundidos que antes. 'No me toques, querido,' dice con una sonrisa que no llega a sus ojos. 'Podrias romperte.'")
        }
        else {
          msg ("Intentas tocar a Carmen. Tus manos la atraviesan como si estuviese hecha de humo. Por un instante, ves lo que hay debajo de su apariencia: algo oscuro, viejo, y hambriento. Luego se solidifica de nuevo y te sonrie como si nada hubiera pasado.")
          IncrementarHorror (1)
        }
      }
      else if (Instr(npc, "martin") > 0) {
        if (game.horror < 14) {
          msg ("Martin retrocede nerviosamente. 'No, no, por favor. Necesito mi espacio. Necesito seguir escribiendo. Los registros no se completan solos.' Sus ojos nunca dejan la maquina de escribir.")
        }
        else {
          msg ("Tus manos pasan a traves de Martin. Por un segundo, ves que la maquina de escribir esta escribiendo sola. Martin no es quien escribe. Martin es lo que se escribe.")
          IncrementarHorror (1)
        }
      }
      else if (Instr(npc, "lucia") > 0) {
        if (game.horror < 14) {
          msg ("Lucia se aparta suavemente. 'No me toques. No quiero que sientas lo que yo siento.' Su voz tiene un eco, como si hablaran dos personas a la vez.")
        }
        else {
          msg ("Tocas a Lucia. Tu mano se hunde en su brazo como en agua tibia. Sientes algo moverse debajo — algo con demasiadas extremidades. Retiras la mano. Lucia no parece haberse dado cuenta.")
          IncrementarHorror (1)
        }
      }
      else if (Instr(npc, "ramon") > 0) {
        if (game.horror < 14) {
          msg ("Ramon te mira con ojos vacios. 'El tiempo,' dice. 'El tiempo no perdona el contacto humano. Cada toque es un recordatorio de que los segundos pasan. Dejame en paz con mis marcas.'")
        }
        else {
          msg ("Tocas a Ramon. Su piel se deshace bajo tus dedos como papel viejo. Debajo no hay carne ni hueso — solo mas marcas. Marcas sobre marcas sobre marcas, apiladas hasta el infinito.")
          IncrementarHorror (1)
        }
      }
      else if (Instr(npc, "sofia") > 0) {
        if (game.horror < 14) {
          msg ("Sofia te toma de la mano. Sus dedos son pequenos y frios. 'Tienes manos grandes,' dice. 'Como las de alguien que solia visitarnos. Ya no viene.' Te suelta y vuelve a jugar.")
        }
        else {
          msg ("Sofia te mira con ojos demasiado viejos para su cara. 'No me toques,' dice con una voz que no es de nina. 'Si me tocas, sabras lo que soy. Y si sabes lo que soy, no podras irte.' Retrocedes.")
          IncrementarHorror (1)
        }
      }
      else {
        msg ("No hay nadie con ese nombre aqui.")
      }
    ]]></script>
  </command>

  <command name="atacar_npc">
    <pattern>atacar a #text#;golpear a #text#;pegar a #text#;atacar #text#;golpear #text#;pegar #text#</pattern>
    <script><![CDATA[
      npc = LCase(text)
      if (Instr(npc, "carmen") > 0 or Instr(npc, "martin") > 0 or Instr(npc, "lucia") > 0 or Instr(npc, "ramon") > 0 or Instr(npc, "sofia") > 0) {
        msg ("Levantas el puno. Tu brazo se detiene en el aire. No es voluntad propia — es la casa. La casa no permite violencia contra sus residentes. Aun.")
        msg ("")
        msg ("Una voz susurra: 'La violencia no es la respuesta. La respuesta esta abajo.'")
        IncrementarHorror (1)
      }
      else {
        msg ("No hay nadie con ese nombre aqui a quien atacar.")
      }
    ]]></script>
  </command>

  <command name="secretos">
    <pattern>secretos;logros;easter eggs;progreso;cuantos secretos</pattern>
    <script><![CDATA[
      msg ("========================================")
      msg ("     PROGRESO - NICANOR MOLINARE")
      msg ("========================================")
      msg ("")
      msg ("  Secretos descubiertos: " + game.easter_eggs_encontrados + " / 25")
      msg ("  Nivel de horror: " + game.horror + " / 20")
      msg ("  Acto actual: " + game.acto)
      msg ("  Turnos: " + game.turnos)
      msg ("")
      msg ("========================================")
    ]]></script>
  </command>

  <command name="nicanor_cmd">
    <pattern>nicanor molinare;nicanor;molinare</pattern>
    <script><![CDATA[
      if (not game.easter_nicanor) {
        game.easter_nicanor = true
        game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
      }
      if (game.horror < 7) {
        msg ("Nicanor Molinare. El nombre del hotel. Suena elegante. Verdad?")
      }
      else if (game.horror < 14) {
        msg ("Nicanor Molinare. Quien fue Nicanor Molinare? No es el nombre de la casa. Es el nombre de alguien. Alguien que estuvo aqui antes que Carmen. Antes que todos. El primer huesped. O el primer prisionero.")
      }
      else if (game.horror < 18) {
        msg ("Nicanor Molinare no es un lugar. Nicanor Molinare fue una persona. Un hombre que construyo esta casa en 1826 como refugio para viajeros. Murio aqui. Solo. Loco. Hablando con las paredes. Las paredes le respondian.")
        msg ("")
        msg ("Dicen que su cuerpo nunca fue encontrado. Dicen que la casa lo absorbio. Que Nicanor Molinare SE CONVIRTIO en la casa. Que cada pared es su carne. Que cada puerta es su boca. Que cada ventana es su ojo. Y que cada huesped es una comida.")
      }
      else {
        msg ("Nicanor Molinare eres tu. Siempre fuiste tu. El primer nombre en el registro. El ultimo. La casa no te atrapo — tu la creaste.")
        msg ("")
        msg ("En algun momento, hace mucho, eras Nicanor. Y construiste un lugar para no estar solo. Un lugar que atrae viajeros, que los retiene, que los absorbe. No porque seas malvado. Porque tienes miedo de la soledad.")
        msg ("")
        msg ("Y la soledad es lo unico que hay al otro lado de esas paredes.")
        IncrementarHorror (2)
      }
    ]]></script>
  </command>

  <command name="examinar_registro_easter">
    <pattern>examinar libro de registro;examinar registro;leer registro;mirar registro;examinar libro registro</pattern>
    <script><![CDATA[
      if (not player.parent = recepcion) {
        msg ("No ves ningun libro de registro aqui.")
      }
      else {
        msg ("El libro de registro esta abierto sobre el mostrador. Paginas y paginas de nombres, fechas, y notas escritas con distintas caligrafias. Algunos nombres estan tachados. Otros estan subrayados en rojo.")
        if (game.horror >= 16) {
          msg ("")
          msg ("Mientras lees, notas algo extrano en la ultima pagina. Debajo de tu nombre, con letra diminuta, hay una nota:")
          msg ("")
          msg ("'Nombre completo: " + game.nombre_jugador + ". Fecha de nacimiento: " + game.fecha_nacimiento + ". Dispositivo: conectado. Ubicacion: detectada. Estado: JUGANDO.'")
          msg ("")
          msg ("(Como sabe la casa en que dispositivo estas?)")
          if (not game.easter_buscar) {
            game.easter_buscar = true
            game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
          }
        }
      }
    ]]></script>
  </command>

  <command name="ir_pueblo_3">
    <pattern>ir al pueblo;pueblo;volver al pueblo;caminar al pueblo;ir sur</pattern>
    <script><![CDATA[
      if (player.parent = jardin_frontal and game.pueblo_desaparecido and not game.easter_pueblo3) {
        game.easter_pueblo3 = true
        game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
        msg ("Sales al jardin. El camino al sur sigue ahi, pero esta... diferente. Los arboles son mas altos. La tierra es mas oscura.")
        msg ("")
        msg ("Caminas durante lo que parecen horas. No llegas al pueblo.")
        msg ("")
        msg ("Llegas a un lugar que se parece al pasillo del primer piso de la casa. Pero al aire libre. Los cuadros cuelgan de los arboles. Las puertas de las habitaciones estan incrustadas en la corteza de los robles.")
        msg ("")
        msg ("Oyes a Carmen llamandote desde algun lugar.")
        msg ("")
        msg ("Despiertas en tu cama. No recuerdas haber dormido.")
        IncrementarHorror (3)
        MoveObject (player, tu_habitacion)
      }
    ]]></script>
  </command>

  <command name="abrir_sotano">
    <pattern>abrir trampilla;abrir candado;usar codigo;ingresar codigo;abrir sotano;abrir el sotano;codigo sotano</pattern>
    <script><![CDATA[
      if (not player.parent = lavadero) {
        msg ("No hay ninguna trampilla aqui.")
      }
      else if (game.abrio_sotano) {
        msg ("La trampilla ya esta abierta. Puedes bajar al sotano.")
      }
      else {
        msg ("La trampilla tiene un candado de combinacion con cuatro digitos. Ingresa el codigo:")
        get input {
          if (result = "1947") {
            msg ("")
            msg ("Los numeros giran con un click satisfactorio: 1... 9... 4... 7.")
            msg ("")
            msg ("El candado se abre con un suspiro metalico. La trampilla cede. Una bocanada de aire frio y antiguo sube desde la oscuridad. Huele a tierra mojada, a piedra vieja, y a algo dulce que no quieres identificar.")
            game.abrio_sotano = true
            IncrementarHorror (3)
            PlaySonido ("chirrido")
          }
          else {
            msg ("")
            msg ("Los numeros no encajan. El candado permanece cerrado.")
            msg ("")
            msg ("Desde el otro lado, muy abajo, juras escuchar un suspiro de decepcion.")
          }
        }
      }
    ]]></script>
  </command>

  <!-- ==================== NUEVOS COMANDOS INTERACTIVOS ==================== -->

  <command name="dormir_cmd">
    <pattern>dormir;descansar;echarme;acostarme;cerrar los ojos;cerrar ojos</pattern>
    <script><![CDATA[
      if (player.parent = tu_habitacion) {
        if (game.horror < 7) {
          msg ("Te acuestas en la cama. El colchon se amolda a tu cuerpo con una precision perturbadora, como si recordara tu forma de visitas anteriores. Te quedas dormido casi al instante.")
          msg ("")
          msg ("Suenas con un pasillo largo, lleno de puertas. Todas estan cerradas. Al final del pasillo hay un espejo. Te acercas. Tu reflejo no esta. Solo hay oscuridad.")
          msg ("")
          msg ("Despiertas. No sabes cuanto tiempo ha pasado. La luz es exactamente la misma que cuando te dormiste.")
        } else if (game.horror < 14) {
          msg ("Cierras los ojos. El sueno llega rapido, demasiado rapido, como si alguien te empujara hacia abajo.")
          msg ("")
          msg ("Suenas que estas de pie en la recepcion. Carmen te mira y dice: 'Bienvenido.' Pero su boca no se mueve. El sonido viene del techo. Miras arriba y ves docenas de bocas abiertas en el yeso, todas diciendo 'bienvenido' al unisono.")
          msg ("")
          msg ("Despiertas empapado en sudor frio. Hay marcas de dedos en tu muneca. No son tuyas.")
          IncrementarHorror (1)
        } else {
          msg ("No puedes dormir. Cada vez que cierras los ojos, ves lo mismo: tu propia cara mirandote desde el otro lado de tus parpados. Como si hubiera alguien dentro de tu cabeza, asomandose por las ventanas de tus ojos cerrados.")
          msg ("")
          msg ("'No duermas,' susurra una voz que podria ser la tuya. 'Si duermes, yo despierto.'")
          IncrementarHorror (1)
        }
      } else {
        if (game.horror < 10) {
          msg ("No es un buen lugar para dormir. Ademas, algo te dice que bajar la guardia aqui seria un error.")
        } else {
          msg ("Intentas cerrar los ojos donde estas. El suelo vibra. Las paredes se inclinan ligeramente hacia ti. La casa no quiere que duermas aqui. La casa quiere que sigas explorando.")
        }
      }
    ]]></script>
  </command>

  <command name="sentarse_cmd">
    <pattern>sentarse;sentarme;me siento;descansar un momento</pattern>
    <script><![CDATA[
      if (player.parent = sala_estar) {
        if (game.horror < 10) {
          msg ("Te sientas en uno de los sofas. Es increiblemente comodo. Tanto que sientes que podrias hundirte en el y no salir jamas. El fuego de la chimenea crepita suavemente.")
          msg ("")
          msg ("Por un instante, crees sentir que alguien se sienta a tu lado. El sofa se hunde ligeramente a tu derecha. Pero no hay nadie.")
        } else {
          msg ("Te sientas. El sofa te abraza. Literalmente. La tela se cierra suavemente sobre tus brazos, sobre tus piernas, como manos que intentan retenerte. Te levantas de un salto. Las marcas en el terciopelo tienen la forma de tu cuerpo.")
          IncrementarHorror (1)
        }
      } else if (player.parent = comedor) {
        msg ("Te sientas en una de las seis sillas. Esta fria. Demasiado fria para madera. Como si alguien acabara de levantarse despues de estar sentado aqui durante mucho, mucho tiempo.")
        if (game.horror >= 10) {
          msg ("")
          msg ("Las otras cinco sillas crujen. Como si sus ocupantes invisibles se acomodaran para mirarte mejor.")
        }
      } else if (player.parent = sala_oculta) {
        msg ("Te sientas en la silla del centro de la habitacion. La madera esta caliente, como la piel de algo vivo. Sientes un latido a traves del asiento. Es el corazon de la casa. Y ahora que estas sentado aqui, la casa te siente como tu la sientes a ella.")
        msg ("")
        msg ("Por un instante, ves la casa entera desde arriba. Cada habitacion, cada pasillo, cada persona. Los ves a todos. Y todos te ven a ti.")
      } else {
        msg ("Te sientas en el suelo un momento. El frio de la piedra se filtra a traves de tu ropa. No es un lugar comodo, pero necesitabas un momento de quietud.")
      }
    ]]></script>
  </command>

  <command name="cantar_cmd">
    <pattern>cantar;tararear;silbar;hacer musica</pattern>
    <script><![CDATA[
      if (game.horror < 7) {
        msg ("Tarareas una melodia. El sonido rebota por las paredes con una acustica sorprendentemente buena, como si la casa estuviera disenada para amplificar la musica. Carmen asoma la cabeza desde algun lugar y sonrie. 'Que bonito. Hace tiempo que nadie cantaba aqui.'")
      } else if (game.horror < 14) {
        msg ("Empiezas a tararear. La melodia sale bien al principio, pero poco a poco notas que no es la cancion que querias cantar. Es otra cosa. Algo mas viejo, mas triste. Una nana que no conoces pero que tus labios parecen recordar.")
        msg ("")
        msg ("Desde la habitacion de Sofia, llega el eco de la misma melodia. Ella la esta tarareando al mismo tiempo que tu. La misma cancion. Nota por nota.")
      } else {
        msg ("Abres la boca para cantar. Lo que sale no es tu voz. Es un coro. Docenas de voces, todas ligeramente diferentes, todas cantando la misma nota discordante. Viene de dentro de ti, de las paredes, del suelo.")
        msg ("")
        msg ("La cancion no tiene letra. Solo un sonido sostenido que crece en intensidad hasta que cierras la boca. El silencio que queda despues vibra como un instrumento desafinado.")
        IncrementarHorror (1)
      }
    ]]></script>
  </command>

  <command name="llorar_cmd">
    <pattern>llorar;lamento;sollozo;sollozar;lagrimear</pattern>
    <script><![CDATA[
      if (game.horror < 7) {
        msg ("Sientes un nudo en la garganta pero las lagrimas no llegan. No hay razon para llorar. Aun.")
      } else if (game.horror < 14) {
        msg ("Lloras. Las lagrimas caen al suelo y la madera las absorbe al instante, como si tuviera sed. Como si la casa se alimentara de tu tristeza igual que se alimenta de tu miedo.")
        msg ("")
        msg ("Carmen aparece a tu lado sin que la hayas oido llegar. Te pone una mano en el hombro. 'Llora, querido. Aqui todos lloraron al principio. Luego se acostumbraron.'")
      } else {
        msg ("Lloras. Pero las lagrimas que caen de tus ojos no son transparentes. Son oscuras. Del color de la tinta del libro de registro. Caen al suelo y forman letras.")
        msg ("")
        msg ("Las letras dicen: 'ESTOY AQUI ABAJO. VEN.'")
        msg ("")
        msg ("Las lagrimas se secan. Las letras permanecen un momento antes de ser absorbidas por el suelo.")
        IncrementarHorror (1)
      }
    ]]></script>
  </command>

  <command name="oler_cmd">
    <pattern>oler;olfatear;que huele;como huele;huele a</pattern>
    <script><![CDATA[
      if (player.parent = cocina) {
        if (game.horror < 7) {
          msg ("El aroma del estofado de Carmen lo impregna todo: tomillo, romero, cebolla caramelizada, y algo mas. Un ingrediente que no puedes identificar pero que hace que tu estomago ruja de hambre.")
        } else {
          msg ("Debajo del aroma del estofado hay otro olor. Dulce. Metalico. Como la sangre mezclada con miel. Es sutil, pero una vez que lo detectas, no puedes dejar de olerlo. Emana del estofado.")
        }
      } else if (player.parent = jardin_frontal) {
        if (game.horror < 10) {
          msg ("Flores. Tierra humeda. Hierba cortada. Un jardin como cualquier otro. Excepto que los olores son demasiado perfectos, como sacados de un frasco de esencias. Demasiado reales para ser reales.")
        } else {
          msg ("Debajo del perfume de las flores hay un olor a descomposicion. Algo esta pudriendose bajo la tierra del jardin. Algo grande.")
        }
      } else if (player.parent = escalera_sotano or player.parent = bodega or player.parent = cuarto_frio) {
        msg ("Tierra mojada. Piedra antigua. Moho. Y algo dulce que viene de mas abajo, de detras de las paredes, de los cimientos mismos de la casa. Es el olor de algo que lleva vivo mucho mas tiempo del que deberia.")
      } else if (player.parent = habitacion_sofia) {
        msg ("Lavanda. Crayones de cera. Y algo mas, debajo de todo, tan leve que casi no lo percibes: el olor de una vela apagada hace mucho tiempo. Humo antiguo. Cera fria.")
      } else {
        if (game.horror < 7) {
          msg ("Madera vieja, cera de abeja, polvo. Los olores de una casa antigua bien cuidada. Reconfortante, de una forma nostalgica.")
        } else if (game.horror < 14) {
          msg ("El aire huele a humedad y a algo dulce que se ha ido agriando con el tiempo. Como fruta que se pudre dentro de las paredes.")
        } else {
          msg ("Huele a ti. Tu propio olor, pero amplificado, distorsionado. Como si la casa se hubiera impregnado de tu esencia. O como si tu te hubieras impregnado de la suya.")
        }
      }
    ]]></script>
  </command>

  <command name="mirar_ventana_cmd">
    <pattern>mirar ventana;mirar por la ventana;mirar afuera;ver ventana;asomarse;asomarme a la ventana</pattern>
    <script><![CDATA[
      if (player.parent = tu_habitacion or player.parent = habitacion_martin or player.parent = habitacion_lucia or player.parent = habitacion_ramon or player.parent = habitacion_sofia or player.parent = bano_primer_piso) {
        if (game.horror < 7) {
          msg ("Miras por la ventana. El jardin se extiende abajo, banado por una luz dorada y calida. A lo lejos, el camino de tierra se pierde entre los arboles. Todo parece tranquilo. Normal. Casi demasiado normal.")
        } else if (game.horror < 14) {
          msg ("Miras por la ventana. El jardin esta ahi, pero los colores son distintos. Mas apagados. El cielo tiene un tono verdoso que no es natural. Y en el camino de tierra, muy lejos, hay una figura. Esta quieta. Te esta mirando.")
          msg ("")
          msg ("Parpadeas. La figura ya no esta. Pero ahora hay dos figuras mas cerca. No recuerdas haberlas visto moverse.")
        } else {
          msg ("La ventana ya no muestra el exterior. Muestra otra habitacion. Una habitacion identica a esta, pero invertida, como un reflejo. Y en esa habitacion hay alguien sentado de espaldas a ti.")
          msg ("")
          msg ("Tiene tu misma ropa. Tu mismo pelo. Esta perfectamente inmovil.")
          msg ("")
          msg ("Lentamente, muy lentamente, empieza a girar la cabeza.")
          msg ("")
          msg ("Apartas la vista antes de ver su cara. Algunas cosas es mejor no saberlas.")
          IncrementarHorror (1)
        }
      } else if (player.parent = recepcion or player.parent = sala_estar or player.parent = comedor) {
        if (game.horror < 10) {
          msg ("Miras por la ventana de la planta baja. El jardin frontal, el camino, los arboles. Todo en su sitio. Todo inmovil, como una fotografia.")
        } else {
          msg ("La ventana muestra el exterior, pero hay algo mal. El jardin esta ahi. El camino esta ahi. Pero no hay sol. No hay luna. No hay cielo. Solo una oscuridad plana y uniforme donde deberia estar el cielo, como si alguien hubiera borrado todo lo que esta por encima de los arboles.")
        }
      } else {
        msg ("No hay ventanas aqui.")
      }
    ]]></script>
  </command>

  <command name="escuchar_cmd">
    <pattern>escuchar;oir;prestar atencion;que se oye;que se escucha;poner la oreja</pattern>
    <script><![CDATA[
      if (game.horror < 5) {
        msg ("Silencio. Un silencio denso y completo, roto unicamente por el lejano crepitar de la chimenea y el burbujeo del estofado de Carmen. Es un silencio confortable. De momento.")
      } else if (game.horror < 10) {
        msg ("Prestas atencion. Debajo del silencio hay algo. Un sonido tan bajo que esta en el limite de la audicion. Un zumbido grave y constante, como un transformador electrico enterrado bajo el suelo. O como algo grande que respira muy, muy lentamente.")
      } else if (game.horror < 15) {
        msg ("Escuchas. La casa no esta en silencio. Nunca lo estuvo. Hay capas de sonido, cada una mas profunda que la anterior:")
        msg ("")
        msg ("  - Las paredes crujen al ritmo de una respiracion.")
        msg ("  - Bajo el suelo, algo se arrastra con un sonido humedo.")
        msg ("  - Desde el atico, un golpeteo ritmico: toc, toc, toc.")
        msg ("  - Y debajo de todo, tu nombre. Pronunciado al reves. Una y otra vez.")
      } else {
        msg ("Escuchas todo. La casa ya no se esconde de ti.")
        msg ("")
        msg ("Cada tablon de madera gime con el peso de los anos. Cada piedra del sotano susurra nombres de los que estuvieron antes. El viento que no existe aulla por pasillos que no ves. Y en el centro de todo, un latido. Constante. Hambriento.")
        msg ("")
        msg ("Es el corazon de la casa. Y late al mismo ritmo que el tuyo.")
      }
    ]]></script>
  </command>

  <command name="contar_turnos_cmd">
    <pattern>contar turnos;cuantos turnos;cuanto llevo;cuanto tiempo llevo</pattern>
    <script><![CDATA[
      msg ("Llevas " + game.turnos + " turnos en Nicanor Molinare.")
      if (game.turnos < 50) {
        msg ("Recien llegas. Aun hay esperanza.")
      } else if (game.turnos < 150) {
        msg ("Empiezas a perder la nocion del tiempo. Los turnos se acumulan como las marcas de Ramon.")
      } else if (game.turnos < 300) {
        msg ("Demasiado tiempo. Mucho mas del que deberia llevar un huesped normal. Carmen sonrie cada vez que te ve, como si supiera que ya no te iras.")
      } else {
        msg ("Has perdido la cuenta hace mucho. Los numeros ya no significan nada. Solo son marcas en una pared. Como las de Ramon. Exactamente como las de Ramon.")
        if (not GetBoolean(game, "turnos_cmd_easter_egg")) {
          SetObjectFlagOn (game, "turnos_cmd_easter_egg")
          game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
        }
      }
    ]]></script>
  </command>

  <command name="pensar_cmd">
    <pattern>pensar;reflexionar;que hago;que debo hacer</pattern>
    <script><![CDATA[
      if (game.horror < 5) {
        msg ("Piensas en tu situacion. Eres un viajero en una casa de huespedes. Los anfitriones son amables. La comida huele bien. Todo esta en orden. Verdad?")
      } else if (game.horror < 10) {
        msg ("Algo no encaja. Las marcas de Ramon. Los dibujos de Sofia. El estofado eterno de Carmen. La maquina de escribir de Martin. El eco de Lucia. Cada pieza por separado es extrana. Juntas, forman un patron que no quieres ver.")
      } else if (game.horror < 15) {
        msg ("Sabes lo que esta pasando. No quieres admitirlo, pero lo sabes. Esta casa no es una casa. Es una trampa. Una trampa hermosa, acogedora, perfumada con estofado y lavanda, pero una trampa. Y tu llevas demasiado tiempo dentro para salir sin dejar algo atras.")
      } else {
        msg ("Tus pensamientos ya no son solo tuyos. Cada idea que tienes tiene un eco, una sombra, como si alguien pensara contigo. La casa esta dentro de tu cabeza ahora. O tu estas dentro de la suya. La diferencia ha dejado de importar.")
      }
    ]]></script>
  </command>

  <command name="mirar_manos_cmd">
    <pattern>mirar mis manos;mirarme las manos;ver mis manos;examinar mis manos;mirar manos</pattern>
    <script><![CDATA[
      if (game.horror < 7) {
        msg ("Tus manos. Diez dedos. Unas cortas. La linea de la vida cruza tu palma izquierda como un rio en un mapa. Son tus manos. Normales. Familiares.")
      } else if (game.horror < 14) {
        msg ("Miras tus manos. Estan... diferentes? Las lineas de la palma parecen mas profundas. Tus unas tienen un tono ligeramente azulado que no tenian antes. Y en la punta de los dedos, casi invisible, hay un polvo gris. El mismo polvo que cubre todo en la bodega.")
      } else {
        msg ("Tus manos tiemblan. Las lineas de la palma se mueven lentamente, reconfigurandose como un mapa que se redibuja. Por un instante, las lineas forman letras. Deletrean algo. Tu nombre. Pero al reves.")
        msg ("")
        msg ("Cierras los punos. Cuando los abres, las lineas estan donde siempre estuvieron. O donde la casa quiere que esten.")
        if (not GetBoolean(game, "manos_easter_egg")) {
          SetObjectFlagOn (game, "manos_easter_egg")
          game.easter_eggs_encontrados = game.easter_eggs_encontrados + 1
        }
      }
    ]]></script>
  </command>

</asl>
